---
const links = [
  { label: 'GitHub', url: 'https://github.com/kenimo49' },
  { label: 'LinkedIn', url: 'https://linkedin.com/in/kenimo49' },
  { label: 'X', url: 'https://x.com/kenimo49' },
  { label: 'Qiita', url: 'https://qiita.com/kenimo49' },
  { label: 'Zenn', url: 'https://zenn.dev/kenimo49' },
  { label: 'DEV.to', url: 'https://dev.to/kenimo49' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Ken Imoto — AI Systems Engineer. Building AI-native organizations powered by LLMs, automation, and distributed agents." />
    <title>Ken Imoto — AI Systems Engineer</title>
    <link rel="icon" href="/favicon.ico" />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Ken Imoto",
      "jobTitle": "AI Systems Engineer",
      "affiliation": { "@type": "Organization", "name": "Propel-Lab", "url": "https://propel-lab.co.jp" },
      "description": "Building AI-native organizations powered by LLMs, automation, and distributed agents.",
      "url": "https://kenimoto.dev",
      "sameAs": [
        "https://github.com/kenimo49",
        "https://linkedin.com/in/kenimo49",
        "https://x.com/kenimo49",
        "https://qiita.com/kenimo49",
        "https://zenn.dev/kenimo49",
        "https://dev.to/kenimo49"
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Propel-Lab",
        "url": "https://propel-lab.co.jp"
      },
      "knowsAbout": ["LLMO", "LLM Optimization", "WebRTC", "Real-time AI", "Context Engineering", "AI Agent Design", "MCP", "Claude Code", "Android Development"]
    }
    </script>
    <script type="application/ld+json">
    [
      {
        "@context": "https://schema.org",
        "@type": "Book",
        "name": "Practical Claude Code — Context Engineering for Modern Development",
        "author": { "@type": "Person", "name": "Ken Imoto" },
        "bookFormat": "EBook",
        "inLanguage": ["ja", "en"],
        "url": "https://zenn.dev/kenimo49/books/claude-code-mastery",
        "about": ["Claude Code", "Context Engineering", "CLAUDE.md", "AI Development"]
      },
      {
        "@context": "https://schema.org",
        "@type": "Book",
        "name": "LLMO — Three Paths for AI to Discover Your Content",
        "author": { "@type": "Person", "name": "Ken Imoto" },
        "bookFormat": "EBook",
        "inLanguage": ["ja", "en"],
        "url": "https://zenn.dev/kenimo49/books/llmo-ai-search-optimization",
        "about": ["LLMO", "LLM Optimization", "SEO", "JSON-LD", "llms.txt", "AI Search"]
      },
      {
        "@context": "https://schema.org",
        "@type": "Book",
        "name": "MCP Security in Practice",
        "author": { "@type": "Person", "name": "Ken Imoto" },
        "bookFormat": "EBook",
        "inLanguage": "ja",
        "url": "https://zenn.dev/kenimo49/books/mcp-security-practice",
        "about": ["MCP", "Model Context Protocol", "Security", "OWASP"]
      },
      {
        "@context": "https://schema.org",
        "@type": "Book",
        "name": "Claude Code QuickStart",
        "author": { "@type": "Person", "name": "Ken Imoto" },
        "bookFormat": "EBook",
        "inLanguage": "ja",
        "url": "https://zenn.dev/kenimo49/books/claude-code-quickstart",
        "about": ["Claude Code", "AI Development"]
      }
    ]
    </script>
    <style>
      @import "tailwindcss";

      body {
        font-family: system-ui, -apple-system, sans-serif;
        background-color: #0f172a;
        color: #e2e8f0;
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      a {
        color: #60a5fa;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <main style="max-width: 600px; padding: 4rem 2rem; text-align: center;">
      <img src="/avatar.jpg" alt="Ken Imoto" style="width: 140px; height: 140px; border-radius: 50%; object-fit: cover; margin-bottom: 1.5rem; border: 3px solid #1e3a5f;" />
      <h1 style="font-size: 2rem; font-weight: 700; margin-bottom: 0.25rem;">Ken Imoto</h1>
      <p style="font-size: 1.125rem; color: #94a3b8; margin-bottom: 0.75rem;">AI Systems Engineer</p>
      <p style="font-size: 0.85rem; color: #64748b; margin-bottom: 2.5rem; letter-spacing: 0.05em;">LLMO · WebRTC · Real-time AI · Context Engineering</p>

      <p style="font-size: 1rem; color: #cbd5e1; line-height: 1.7; margin-bottom: 3rem;">
        Building AI-native organizations powered by LLMs, automation, and distributed agents.
      </p>

      <section style="margin-bottom: 3rem; text-align: left;">
        <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: #64748b; margin-bottom: 1rem;">Currently</h2>
        <ul style="list-style: none; padding: 0; line-height: 2;">
          <li>Building AI systems at <a href="https://propel-lab.co.jp">Propel-Lab</a></li>
          <li>Author: Practical Claude Code, LLMO (Kindle/Zenn)</li>
          <li>Researching: LLMO, AI Agent Design, Context Engineering</li>
        </ul>
      </section>

      <section style="margin-bottom: 3rem; text-align: left;">
        <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: #64748b; margin-bottom: 1rem;">Publications</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div style="background: #1e293b; border-radius: 8px; padding: 1rem;">
            <p style="font-size: 0.9rem; font-weight: 600; margin-bottom: 0.25rem;">Practical Claude Code</p>
            <p style="font-size: 0.75rem; color: #94a3b8; margin-bottom: 0.5rem;">Context Engineering for Modern Development</p>
            <div style="display: flex; gap: 0.75rem; font-size: 0.75rem;">
              <a href="https://amzn.asia/d/03Qnb8QT">Kindle JP</a>
              <a href="https://amzn.asia/d/0hU3BP1i">Kindle EN</a>
              <a href="https://zenn.dev/kenimo49/books/claude-code-mastery">Zenn</a>
            </div>
          </div>
          <div style="background: #1e293b; border-radius: 8px; padding: 1rem;">
            <p style="font-size: 0.9rem; font-weight: 600; margin-bottom: 0.25rem;">LLMO</p>
            <p style="font-size: 0.75rem; color: #94a3b8; margin-bottom: 0.5rem;">Three Paths for AI to Discover Your Content</p>
            <div style="display: flex; gap: 0.75rem; font-size: 0.75rem;">
              <a href="https://amzn.asia/d/02zAl1VB">Kindle JP</a>
              <a href="https://amzn.asia/d/04rulUoN">Kindle EN</a>
              <a href="https://zenn.dev/kenimo49/books/llmo-ai-search-optimization">Zenn</a>
            </div>
          </div>
          <div style="background: #1e293b; border-radius: 8px; padding: 1rem;">
            <p style="font-size: 0.9rem; font-weight: 600; margin-bottom: 0.25rem;">MCP Security in Practice</p>
            <p style="font-size: 0.75rem; color: #94a3b8; margin-bottom: 0.5rem;">Complete Guide for Production Deployment</p>
            <div style="font-size: 0.75rem;">
              <a href="https://zenn.dev/kenimo49/books/mcp-security-practice">Zenn (Free)</a>
            </div>
          </div>
          <div style="background: #1e293b; border-radius: 8px; padding: 1rem;">
            <p style="font-size: 0.9rem; font-weight: 600; margin-bottom: 0.25rem;">Claude Code QuickStart</p>
            <p style="font-size: 0.75rem; color: #94a3b8; margin-bottom: 0.5rem;">Get Started Fast</p>
            <div style="font-size: 0.75rem;">
              <a href="https://zenn.dev/kenimo49/books/claude-code-quickstart">Zenn (Free)</a>
            </div>
          </div>
        </div>
        <p style="font-size: 0.75rem; color: #64748b; margin-top: 0.75rem;">
          <a href="https://www.amazon.co.jp/stores/author/B0GQNPRCGF">→ All books on Amazon</a>
        </p>
      </section>

      <section style="text-align: left;">
        <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: #64748b; margin-bottom: 1rem;">Connect</h2>
        <ul style="list-style: none; padding: 0; line-height: 2;">
          {links.map(link => (
            <li><a href={link.url}>{link.label}</a></li>
          ))}
        </ul>
      </section>
    </main>
  </body>
</html>
