---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import { getCollection } from 'astro:content';
import { staticAlternates } from '../lib/alternates';
import { buildScholarlyArticleJsonLd } from '../lib/research-papers';
import { PERSON_SAMEAS, buildWebSiteEntity } from '../lib/person-entity';

// "Now" セクションの更新月はビルド日から自動生成する (毎日ビルドされるので陳腐化しない)
const updatedLabel = new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });

// Connect セクション: EN ページなので EN プラットフォームのみ表示
// 他言語版は Nav の言語スイッチャーで遷移可。JSON-LD sameAs には全部記載 (SEO/LLMO)
const links = [
  { label: 'GitHub', url: 'https://github.com/kenimo49' },
  { label: 'LinkedIn', url: 'https://linkedin.com/in/kenimo49' },
  { label: 'X', url: 'https://x.com/kenimo49' },
  { label: 'DEV.to', url: 'https://dev.to/kenimo49' },
  { label: 'Hashnode', url: 'https://kenimo49.hashnode.dev' },
  { label: 'Medium', url: 'https://medium.com/@kenimo49' },
  { label: 'Reddit', url: 'https://www.reddit.com/user/AccountOk6578/' },
];

const SITE_URL = 'https://kenimoto.dev';

// --- Latest Articles: EN ブログコレクションの最新6件から自動生成 ---
// 以前はインラインの外部リンク手書きで ja ページと二重管理になり、ドリフトの温床だった。
// 記事リンク・日付をコレクション駆動にして自動化する。
const enPosts = (await getCollection('blog', ({ data }) => data.lang === 'en'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

// --- Book JSON-LD: books コレクションから自動生成 ---
// en エディションのうち実際に出版済み (Kindle/Zenn URL を持つ) の書籍のみ。
// inLanguage と sameAs は同一 slug の全言語エディションを束ねて単一ソース化する。
const allBooks = await getCollection('books');
const editionsBySlug = new Map<string, typeof allBooks>();
for (const b of allBooks) {
  const slug = b.id.replace(/^(en|ja|pt|es)\//, '');
  const list = editionsBySlug.get(slug) ?? [];
  list.push(b);
  editionsBySlug.set(slug, list);
}
const bookJsonLd = allBooks
  .filter((b) => b.data.lang === 'en' && (b.data.kindle_url || b.data.zenn_url))
  .sort((a, b) => b.data.published_date.valueOf() - a.data.published_date.valueOf())
  .map((b) => {
    const slug = b.id.replace(/^en\//, '');
    const editions = editionsBySlug.get(slug) ?? [b];
    const langs = [...new Set(editions.map((e) => e.data.lang))].sort();
    const sameAs = [...new Set(
      editions
        .flatMap((e) => [e.data.zenn_url, e.data.kindle_url, ...e.data.other_urls.map((u) => u.url)])
        .filter(Boolean),
    )];
    return {
      '@context': 'https://schema.org',
      '@type': 'Book',
      name: b.data.title,
      author: { '@id': `${SITE_URL}/#person` },
      bookFormat: 'EBook',
      inLanguage: langs.length > 1 ? langs : langs[0],
      url: `${SITE_URL}/books/${slug}/`,
      ...(sameAs.length ? { sameAs } : {}),
      ...(b.data.topics.length ? { about: b.data.topics } : {}),
    };
  });

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${SITE_URL}/#person`,
  name: 'Ken Imoto',
  jobTitle: 'AI Systems Engineer',
  affiliation: { '@type': 'Organization', name: 'Propel-Lab', url: 'https://propel-lab.co.jp' },
  description: 'Building AI-native organizations powered by LLMs, automation, and distributed agents.',
  url: SITE_URL,
  sameAs: PERSON_SAMEAS,
  worksFor: { '@type': 'Organization', name: 'Propel-Lab', url: 'https://propel-lab.co.jp' },
  knowsAbout: ['LLMO', 'LLM Optimization', 'AI-Native MEO', 'WebRTC', 'Real-time AI', 'Context Engineering', 'AI Agent Design', 'MCP', 'Claude Code', 'Android Development', 'Vision-Language Models', 'Color Perception'],
};
const websiteJsonLd = { '@context': 'https://schema.org', ...buildWebSiteEntity('en') };
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE_URL}/#organization`,
  name: 'Propel-Lab',
  url: 'https://propel-lab.co.jp/',
  logo: `${SITE_URL}/og-image.png`,
  founder: { '@id': `${SITE_URL}/#person` },
};
---

<BaseLayout
  title="Ken Imoto — AI Systems Engineer"
  description="Ken Imoto — AI Systems Engineer. Building AI-native organizations powered by LLMs, automation, and distributed agents."
  lang="en"
  ogUrl="https://kenimoto.dev/"
  ogDescription="LLMO Framework Author. Building AI-native organizations powered by LLMs, real-time AI, and context engineering."
  alternates={staticAlternates('/')}
  jsonLd={[personJsonLd, websiteJsonLd, orgJsonLd, ...buildScholarlyArticleJsonLd(`${SITE_URL}/#person`), ...bookJsonLd]}
>
    <Nav lang="en" current="home" />

    <main style="max-width: 720px; margin: 0 auto; padding: 4rem 2rem; text-align: center;">
      <!-- Hero (600px inner wrapper) -->
      <div style="max-width: 600px; margin: 0 auto;">
        <img src="/avatar.jpg" alt="Ken Imoto" style="width: 140px; height: 140px; border-radius: 50%; object-fit: cover; margin-bottom: 1.5rem; border: 3px solid var(--border-avatar);" />
        <h1 style="font-size: 2rem; font-weight: 700; margin-bottom: 0.25rem;">Ken Imoto</h1>
        <p style="font-size: 1.125rem; color: var(--text-label); margin-bottom: 0.75rem;">AI Systems Engineer</p>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 2.5rem; letter-spacing: 0.05em;">LLMO · WebRTC · Real-time AI · Context Engineering</p>

        <p style="font-size: 1rem; color: var(--text-secondary); line-height: 1.7; margin-bottom: 3rem;">
          Building AI-native organizations powered by LLMs, automation, and distributed agents.
        </p>
      </div>

      <!-- Stats (Step 3: Big numbers) -->
      <section style="margin-bottom: 2.5rem;">
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 480px; margin: 0 auto;">
          <div>
            <p style="font-size: 2rem; font-weight: 800; color: var(--text-primary); margin: 0; line-height: 1.2;">123K+</p>
            <p style="font-size: 0.7rem; color: var(--text-label); text-transform: uppercase; letter-spacing: 0.08em; margin: 0.25rem 0 0;">PV on Qiita</p>
          </div>
          <div>
            <p style="font-size: 2rem; font-weight: 800; color: var(--text-primary); margin: 0; line-height: 1.2;">14</p>
            <p style="font-size: 0.7rem; color: var(--text-label); text-transform: uppercase; letter-spacing: 0.08em; margin: 0.25rem 0 0;">Books</p>
          </div>
          <div>
            <p style="font-size: 2rem; font-weight: 800; color: var(--text-primary); margin: 0; line-height: 1.2;">3</p>
            <p style="font-size: 0.7rem; color: var(--text-label); text-transform: uppercase; letter-spacing: 0.08em; margin: 0.25rem 0 0;">Research Papers</p>
          </div>
        </div>
      </section>

      <!-- Now (Step 4) -->
      <section style="margin-bottom: 3rem; text-align: left;">
        <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 1rem;">Now</h2>
        <div style="background: var(--bg-card); border-radius: 8px; padding: 1.25rem 1.5rem; border-left: 3px solid var(--accent-blue);">
          <ul style="list-style: none; padding: 0; line-height: 2; margin: 0;">
            <li>Building the LLMO Framework, LLMO Checker, and the Open LLMO Research Initiative</li>
            <li>Documenting AI-Native MEO as the local-business implementation of LLMO</li>
            <li>Applying Harness Engineering to products — dev, ops, and marketing with AI agents</li>
            <li>Publishing books & articles from hands-on practice</li>
          </ul>
          <p style="font-size: 0.7rem; color: var(--text-muted); margin: 1rem 0 0; border-top: 1px solid var(--text-separator); padding-top: 0.75rem;">
            Updated {updatedLabel}
          </p>
        </div>
      </section>

      <!-- Publications (Step 5: Cover-centric grid) -->
      <section style="margin-bottom: 3rem; text-align: left;">
        <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 1rem;">Publications</h2>

        <h3 style="font-size: 0.75rem; font-weight: 600; color: var(--accent-blue); margin-bottom: 0.5rem; letter-spacing: 0.05em;">🔧 AI DEVELOPMENT</h3>
        <div class="book-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem;">
          <div class="book-card" data-lp-url="/books/voice-ai-300ms-ux/" style="position: relative; border: 1px solid var(--accent-blue);">
            <span style="position: absolute; top: 0.4rem; right: 0.4rem; font-size: 0.6rem; background: var(--accent-blue); color: #fff; padding: 0.1rem 0.4rem; border-radius: 3px; font-weight: 600;">NEW</span>
            <img src="/images/books/thumbs/voice-ai-300ms-ux-en.webp" loading="lazy" decoding="async" width="140" height="196" alt="The 300ms Threshold" style="width: 100%; max-width: 140px; height: auto; border-radius: 4px; margin-bottom: 0.5rem;" />
            <p style="font-size: 0.8rem; font-weight: 600; margin-bottom: 0.2rem; line-height: 1.3;">The 300ms Threshold</p>
            <p style="font-size: 0.7rem; color: var(--text-label); margin-bottom: 0.4rem; line-height: 1.3;">Why Talking to AI Feels Wrong</p>
            <div style="font-size: 0.7rem; display: flex; gap: 0.5rem; justify-content: center;"><a href="https://www.amazon.com/dp/B0GYQ4L2KP">Kindle</a><a href="https://zenn.dev/kenimo49/books/voice-ai-300ms-ux">Zenn</a></div>
          </div>
          <div class="book-card" data-lp-url="/books/harness-engineering-guide/">
            <img src="/images/books/thumbs/harness-engineering-guide-en.webp" loading="lazy" decoding="async" width="140" height="196" alt="Harness Engineering" style="width: 100%; max-width: 140px; height: auto; border-radius: 4px; margin-bottom: 0.5rem;" />
            <p style="font-size: 0.8rem; font-weight: 600; margin-bottom: 0.2rem; line-height: 1.3;">Harness Engineering</p>
            <p style="font-size: 0.7rem; color: var(--text-label); margin-bottom: 0.4rem; line-height: 1.3;">From Using AI to Controlling AI</p>
            <div style="font-size: 0.7rem;"><a href="https://www.amazon.com/dp/B0FZNL8D1V">Kindle</a></div>
          </div>
          <div class="book-card" data-lp-url="/books/claude-code-mastery/">
            <img src="/images/books/thumbs/claude-code-mastery-en.webp" loading="lazy" decoding="async" width="140" height="196" alt="Practical Claude Code" style="width: 100%; max-width: 140px; height: auto; border-radius: 4px; margin-bottom: 0.5rem;" />
            <p style="font-size: 0.8rem; font-weight: 600; margin-bottom: 0.2rem; line-height: 1.3;">Practical Claude Code</p>
            <p style="font-size: 0.7rem; color: var(--text-label); margin-bottom: 0.4rem; line-height: 1.3;">Context Engineering for Modern Development</p>
            <div style="font-size: 0.7rem; display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;"><a href="https://www.amazon.com/dp/B0GPWPKNB7">Kindle</a><a href="/pt/books/claude-code-mastery/" style="font-size: 0.65rem; padding: 0.05rem 0.35rem; border: 1px solid var(--text-separator); border-radius: 3px; color: var(--text-label);">PT-BR</a><a href="/es/books/claude-code-mastery/" style="font-size: 0.65rem; padding: 0.05rem 0.35rem; border: 1px solid var(--text-separator); border-radius: 3px; color: var(--text-label);">ES</a></div>
          </div>
          <div class="book-card" data-lp-url="/books/context-engineering/">
            <img src="/images/books/thumbs/context-engineering-en.webp" loading="lazy" decoding="async" width="140" height="196" alt="Context Engineering" style="width: 100%; max-width: 140px; height: auto; border-radius: 4px; margin-bottom: 0.5rem;" />
            <p style="font-size: 0.8rem; font-weight: 600; margin-bottom: 0.2rem; line-height: 1.3;">Context Engineering in Practice</p>
            <p style="font-size: 0.7rem; color: var(--text-label); margin-bottom: 0.4rem; line-height: 1.3;">Turning LLMs from Liars into Experts</p>
            <div style="font-size: 0.7rem;"><a href="https://www.amazon.com/dp/B0GHRJX36Z">Kindle</a></div>
          </div>
        </div>

        <h3 style="font-size: 0.75rem; font-weight: 600; color: var(--accent-amber); margin-bottom: 0.5rem; letter-spacing: 0.05em;">🔍 LLMO / AI SEARCH OPTIMIZATION</h3>
        <div class="book-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem;">
          <div class="book-card accent-amber" data-lp-url="/books/llmo-ai-search-optimization/">
            <img src="/images/books/thumbs/llmo-en.webp" loading="lazy" decoding="async" width="140" height="196" alt="LLMO" style="width: 100%; max-width: 140px; height: auto; border-radius: 4px; margin-bottom: 0.5rem;" />
            <p style="font-size: 0.8rem; font-weight: 600; margin-bottom: 0.2rem; line-height: 1.3;">LLMO Practical Guide</p>
            <p style="font-size: 0.7rem; color: var(--text-label); margin-bottom: 0.4rem; line-height: 1.3;">Why ChatGPT Ignores Your Website</p>
            <div style="font-size: 0.7rem;"><a href="https://www.amazon.com/dp/B0GQ2L5HQY">Kindle</a></div>
          </div>
          <div class="book-card accent-amber" data-lp-url="/books/llmo-quickstart/">
            <img src="/images/books/thumbs/llmo-quickstart-en.webp" loading="lazy" decoding="async" width="140" height="196" alt="LLMO Quickstart" style="width: 100%; max-width: 140px; height: auto; border-radius: 4px; margin-bottom: 0.5rem;" />
            <p style="font-size: 0.8rem; font-weight: 600; margin-bottom: 0.2rem; line-height: 1.3;">LLMO Quickstart</p>
            <p style="font-size: 0.7rem; color: var(--text-label); margin-bottom: 0.4rem; line-height: 1.3;">AI Search Optimization for Engineers</p>
            <div style="font-size: 0.7rem;"><a href="https://www.amazon.com/dp/B0GHJLJ611">Kindle</a></div>
          </div>
        </div>

        <h3 style="font-size: 0.75rem; font-weight: 600; color: var(--accent-green); margin-bottom: 0.5rem; letter-spacing: 0.05em;">🛡️ SECURITY & QUALITY</h3>
        <div class="book-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;">
          <div class="book-card accent-green" data-lp-url="/books/mcp-security-practice/">
            <img src="/images/books/thumbs/mcp-security-en.webp" loading="lazy" decoding="async" width="140" height="196" alt="MCP Security" style="width: 100%; max-width: 140px; height: auto; border-radius: 4px; margin-bottom: 0.5rem;" />
            <p style="font-size: 0.8rem; font-weight: 600; margin-bottom: 0.2rem; line-height: 1.3;">MCP Security in Practice</p>
            <p style="font-size: 0.7rem; color: var(--text-label); margin-bottom: 0.4rem; line-height: 1.3;">What OWASP Won't Tell You</p>
            <div style="font-size: 0.7rem;"><a href="https://www.amazon.com/dp/B0GHZHC3PY">Kindle</a></div>
          </div>
          <div class="book-card accent-green" data-lp-url="/books/harness-code-review/">
            <img src="/images/books/thumbs/harness-code-review.webp" loading="lazy" decoding="async" width="140" height="196" alt="Systematizing AI Code Review" style="width: 100%; max-width: 140px; height: auto; border-radius: 4px; margin-bottom: 0.5rem;" />
            <p style="font-size: 0.8rem; font-weight: 600; margin-bottom: 0.2rem; line-height: 1.3;">Systematizing AI Code Review</p>
            <p style="font-size: 0.7rem; color: var(--text-label); margin-bottom: 0.4rem; line-height: 1.3;">The 3-Layer Model for 60% Faster Reviews</p>
            <div style="font-size: 0.7rem;"><a href="https://www.amazon.com/Systematizing-AI-Code-Review-Propel-Lab-ebook/dp/B0GX71K2BV">Kindle</a></div>
          </div>
        </div>
        <h3 style="font-size: 0.75rem; font-weight: 600; color: var(--accent-purple, #7c3aed); margin-bottom: 0.5rem; margin-top: 1.5rem; letter-spacing: 0.05em;">📊 KNOWLEDGE & DATA</h3>
        <div class="book-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem;">
          <div class="book-card accent-purple" data-lp-url="/books/knowledge-graph-practical-guide/">
            <img src="/images/books/thumbs/knowledge-graph-en.webp" loading="lazy" decoding="async" width="140" height="196" alt="Knowledge Graph Guide" style="width: 100%; max-width: 140px; height: auto; border-radius: 4px; margin-bottom: 0.5rem;" />
            <p style="font-size: 0.8rem; font-weight: 600; margin-bottom: 0.2rem; line-height: 1.3;">Knowledge Graph Guide</p>
            <p style="font-size: 0.7rem; color: var(--text-label); margin-bottom: 0.4rem; line-height: 1.3;">Structure Your Data, Sharpen Your AI</p>
            <div style="font-size: 0.7rem;"><a href="https://www.amazon.com/dp/B0GX2Z73JV">Kindle</a></div>
          </div>
        </div>

        <h3 style="font-size: 0.75rem; font-weight: 600; color: var(--accent-rose, #e11d48); margin-bottom: 0.5rem; letter-spacing: 0.05em;">💡 ENGINEERING CULTURE</h3>
        <div class="book-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem;">
          <div class="book-card accent-rose" data-lp-url="/books/engineer-it-quotes/">
            <img src="/images/books/thumbs/engineer-it-quotes-en.webp" loading="lazy" decoding="async" width="140" height="196" alt="100 Engineering Quotes" style="width: 100%; max-width: 140px; height: auto; border-radius: 4px; margin-bottom: 0.5rem;" />
            <p style="font-size: 0.8rem; font-weight: 600; margin-bottom: 0.2rem; line-height: 1.3;">100 Engineering Quotes</p>
            <p style="font-size: 0.7rem; color: var(--text-label); margin-bottom: 0.4rem; line-height: 1.3;">Why Do Some Words Stay With You?</p>
            <div style="font-size: 0.7rem;"><a href="https://www.amazon.com/dp/B0GX3CS95M">Kindle</a></div>
          </div>
        </div>

        <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.75rem;">
          <a href="https://www.amazon.com/stores/author/B0GQNPRCGF">→ All books on Amazon</a>
        </p>
      </section>

      <!-- Latest Articles (collection-driven: blog コレクションの最新6件) -->
      <section style="margin-bottom: 3rem; text-align: left;">
        <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 1rem;">Latest Articles</h2>
        <ul style="list-style: none; padding: 0; line-height: 2.2;">
          {enPosts.map((post) => {
            const slug = post.id.replace(/^en\//, '');
            const dateLabel = post.data.date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
            return (
              <li>📝 <a href={`/blog/${slug}/`}>{post.data.title}</a> <span style="color: var(--text-muted); font-size: 0.75rem;">{dateLabel}</span></li>
            );
          })}
        </ul>
        <p style="font-size: 0.75rem; color: var(--text-muted); margin-top: 0.75rem;">
          <a href="/blog/">→ All articles</a>
        </p>
      </section>

      <!-- Papers -->
      <section style="margin-bottom: 3rem; text-align: left;">
        <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 1rem;">Papers</h2>
        <div style="background: var(--bg-card); border-radius: 8px; padding: 1.25rem; border-left: 3px solid var(--accent-green); margin-bottom: 1rem;">
          <p style="font-size: 0.95rem; font-weight: 600; margin-bottom: 0.5rem;">📊 Excess Vocabulary in Japanese AI-Generated Text: A Cross-Model Quantitative Analysis</p>
          <p style="font-size: 0.8rem; color: var(--text-label); margin-bottom: 0.75rem;">350 samples from 7 LLMs vs. 977 human articles. 651 statistically significant excess words identified. Newer Claude generations show increasing vocabulary bias (TTR: 0.52→0.29). Cross-domain classifier achieves AUC=0.946 in-domain but fails completely across genres. First Japanese excess vocabulary study with coevolution evidence.</p>
          <div style="font-size: 0.75rem; display: flex; gap: 1rem; flex-wrap: wrap;">
            <a href="https://doi.org/10.5281/zenodo.19233934">📄 Paper (DOI)</a>
            <a href="https://github.com/kenimo49/excess-vocabulary-ja">💻 Code & Data</a>
            <span style="color: var(--text-muted);">March 2026 · Zenodo</span>
          </div>
        </div>
        <div style="background: var(--bg-card); border-radius: 8px; padding: 1.25rem; border-left: 3px solid var(--accent-amber); margin-bottom: 1rem;">
          <p style="font-size: 0.95rem; font-weight: 600; margin-bottom: 0.5rem;">📝 AI Text Slop: Stylistic Convergence Across Six LLMs in Japanese Technical Writing</p>
          <p style="font-size: 0.8rem; color: var(--text-label); margin-bottom: 0.75rem;">180 samples (6 models × 10 topics × 3 trials) measured with 16 pattern indicators. RLHF-aligned commercial models score significantly higher than OSS (Cohen's d = 1.01). Vocabulary and structural patterns dissociate ("Swallow Paradox"). Human Qiita articles score higher than AI on structural metrics, revealing cultural confounding.</p>
          <div style="font-size: 0.75rem; display: flex; gap: 1rem; flex-wrap: wrap;">
            <a href="https://doi.org/10.5281/zenodo.19173035">📄 Paper (DOI)</a>
            <a href="https://github.com/kenimo49/ai-text-slop">💻 Code & Data</a>
            <span style="color: var(--text-muted);">March 2026 · Zenodo</span>
          </div>
        </div>
        <div style="background: var(--bg-card); border-radius: 8px; padding: 1.25rem; border-left: 3px solid var(--accent-blue);">
          <p style="font-size: 0.95rem; font-weight: 600; margin-bottom: 0.5rem;">🔵 AI Blue: Systematic Color Recognition Bias in Vision-Language Models</p>
          <p style="font-size: 0.8rem; color: var(--text-label); margin-bottom: 0.75rem;">We tested 4 VLMs × 40 colors × 480 observations. Commercial models miss intermediate hues. 95% of AI-generated UI colors land on blue-purple. First quantitative link between VLM color bias and the "AI Slop" phenomenon.</p>
          <div style="font-size: 0.75rem; display: flex; gap: 1rem; flex-wrap: wrap;">
            <a href="https://doi.org/10.5281/zenodo.19159702">📄 Paper (DOI)</a>
            <a href="https://github.com/kenimo49/ai-blue-color-bias">💻 Code & Data</a>
            <span style="color: var(--text-muted);">March 2026 · Zenodo</span>
          </div>
        </div>
      </section>

      <!-- Research -->
