---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';
import { staticAlternates } from '../../lib/alternates';
import { buildScholarlyArticleJsonLd } from '../../lib/research-papers';
import { coverThumb } from '../../lib/thumb';
import { PERSON_SAMEAS } from '../../lib/person-entity';

const ptBooks = (await getCollection('books', ({ data }) => data.lang === 'pt'))
  .sort((a, b) => b.data.published_date.valueOf() - a.data.published_date.valueOf());

const ptPosts = (await getCollection('blog', ({ data }) => data.lang === 'pt'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const SITE_URL = 'https://kenimoto.dev';
const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${SITE_URL}/#person`,
  name: 'Ken Imoto',
  jobTitle: 'AI Systems Engineer',
  url: `${SITE_URL}/`,
  sameAs: PERSON_SAMEAS,
  worksFor: { '@id': `${SITE_URL}/#organization` },
};
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE_URL}/#website-pt`,
  name: 'Ken Imoto — Edições em Português',
  url: `${SITE_URL}/pt/`,
  description: 'Livros sobre Claude Code, Engenharia de Contexto e desenvolvimento com IA, em português.',
  inLanguage: 'pt-BR',
  publisher: { '@id': `${SITE_URL}/#organization` },
};
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE_URL}/#organization`,
  name: 'Propel-Lab',
  url: 'https://propel-lab.co.jp/',
  logo: `${SITE_URL}/og-image.png`,
  founder: { '@id': `${SITE_URL}/#person` },
};
---

<BaseLayout
  title="Ken Imoto — Edições em Português"
  description="Livros do Ken Imoto disponíveis em português. Engenharia de Contexto, Claude Code, e desenvolvimento com IA."
  lang="pt"
  ogUrl="https://kenimoto.dev/pt/"
  ogDescription="Livros sobre Claude Code, Engenharia de Contexto e desenvolvimento com IA, em português."
  alternates={staticAlternates('/')}
  jsonLd={[personJsonLd, websiteJsonLd, orgJsonLd, ...buildScholarlyArticleJsonLd(`${SITE_URL}/#person`)]}
>
  <Nav lang="pt" current="home" />

  <main class="pt-home">
    <h1>Edições em Português</h1>
    <p class="lead">
      Livros do Ken Imoto disponíveis em português brasileiro. Os demais livros estão em inglês ou japonês.
    </p>

    <section class="book-list">
      {ptBooks.map((book) => {
        const slug = book.id.replace(/^pt\//, '');
        return (
          <a href={`/pt/books/${slug}/`} class="book-row">
            {book.data.cover_image && (
              <img src={coverThumb(book.data.cover_image)} alt={`${book.data.title} capa`} class="book-row-cover" loading="lazy" />
            )}
            <div class="book-row-body">
              <h2>{book.data.title}</h2>
              {book.data.subtitle && <p class="book-row-subtitle">{book.data.subtitle}</p>}
              {book.data.tagline && <p class="book-row-tagline">{book.data.tagline}</p>}
            </div>
          </a>
        );
      })}
    </section>

    <section class="article-list">
      <h2 class="article-list-label">Artigos recentes</h2>
      {ptPosts.map((post) => {
        const slug = post.id.replace(/^pt\//, '');
        return (
          <a href={`/pt/blog/${slug}/`} class="article-row">
            <p class="article-row-title">{post.data.title}</p>
            <p class="article-row-desc">{post.data.description}</p>
          </a>
        );
      })}
      <a href="/pt/blog/" class="article-list-more">Ver todos os artigos →</a>
    </section>

    <section class="other-langs-cta">
      <h2>Procurando outros livros?</h2>
      <p>
        A coleção completa está disponível em <a href="/">inglês</a> e <a href="/ja/">japonês</a>.
      </p>
    </section>
  </main>
</BaseLayout>

<style>
  .pt-home {
    max-width: 760px;
    margin: 0 auto;
    padding: 2.5rem 2rem 4rem;
  }
  .pt-home h1 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.75rem;
    color: var(--text-primary);
  }
  .pt-home .lead {
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0 0 2.5rem;
  }
  .book-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .book-row {
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem;
    background: var(--bg-card);
    border-radius: 8px;
    text-decoration: none;
    color: var(--text-secondary);
    transition: outline 0.15s;
    align-items: flex-start;
  }
  .book-row:hover {
    outline: 1px solid var(--accent-blue);
    text-decoration: none;
  }
  .book-row-cover {
    width: 90px;
    height: auto;
    aspect-ratio: 5 / 7;
    object-fit: cover;
    border-radius: 4px;
    flex-shrink: 0;
    background: var(--bg-primary);
  }
  .book-row-body {
    flex: 1;
    min-width: 0;
  }
  .book-row h2 {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.3rem;
    color: var(--text-primary);
    line-height: 1.35;
  }
  .book-row-subtitle {
    font-size: 0.9rem;
    color: var(--text-label);
    margin: 0 0 0.5rem;
    line-height: 1.4;
  }
  .book-row-tagline {
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
  }
  .article-list {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--text-separator);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .article-list-label {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin: 0 0 0.5rem;
  }
  .article-row {
    display: block;
    padding: 0.85rem 1rem;
    background: var(--bg-card);
    border-radius: 8px;
    text-decoration: none;
    transition: outline 0.15s;
  }
  .article-row:hover {
    outline: 1px solid var(--accent-blue);
    text-decoration: none;
  }
  .article-row-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 0.3rem;
    line-height: 1.4;
  }
  .article-row-desc {
    font-size: 0.82rem;
    color: var(--text-label);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article-list-more {
    font-size: 0.875rem;
    color: var(--accent-blue);
    text-decoration: none;
    margin-top: 0.25rem;
  }
  .article-list-more:hover {
    text-decoration: underline;
  }
  .other-langs-cta {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--text-separator);
  }
  .other-langs-cta h2 {
    font-size: 1.2rem;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
  }
  .other-langs-cta p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
  }
  @media (max-width: 640px) {
    .pt-home {
      padding: 1.5rem 1rem 3rem;
    }
  }
</style>
