---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import { staticAlternates } from '../lib/alternates';
import { buildPersonEntity, buildOrganizationEntity, buildWebSiteEntity } from '../lib/person-entity';

// AI が引用する時の一次プロフィール正典。/about/ こそ Person/Organization/WebSite を載せる場所。
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    buildPersonEntity('en'),
    buildOrganizationEntity(),
    buildWebSiteEntity('en'),
  ],
};

// EN about: EN プラットフォームのみ。他言語は Nav の言語スイッチャー経由
const links = [
  { label: 'GitHub', url: 'https://github.com/kenimo49' },
  { label: 'LinkedIn', url: 'https://linkedin.com/in/kenimo49' },
  { label: 'X', url: 'https://x.com/kenimo49' },
  { label: 'DEV.to', url: 'https://dev.to/kenimo49' },
  { label: 'Hashnode', url: 'https://kenimo49.hashnode.dev' },
  { label: 'Medium', url: 'https://medium.com/@kenimo49' },
];
---

<BaseLayout
  title="About — Ken Imoto"
  description="About Ken Imoto — AI Systems Engineer, LLMO Framework Author, Kindle Author."
  lang="en"
  ogUrl="https://kenimoto.dev/about/"
  ogDescription="About Ken Imoto — AI Systems Engineer, LLMO Framework Author."
  alternates={staticAlternates('/about/')}
  jsonLd={jsonLd}
>
  <Fragment slot="head">
    <style>
      .copy-btn {
        background: none;
        border: 1px solid var(--text-separator);
        color: var(--text-label);
        cursor: pointer;
        padding: 0.25rem 0.6rem;
        border-radius: 4px;
        font-size: 0.7rem;
        transition: color 0.2s, border-color 0.2s;
      }
      .copy-btn:hover {
        color: var(--text-primary);
        border-color: var(--text-label);
      }
      .bio-block {
        background: var(--bg-card);
        border-radius: 8px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
      }
    </style>
  </Fragment>

    <Nav lang="en" current="about" />

    <main style="max-width: 600px; margin: 0 auto; padding: 4rem 2rem;">
      <!-- Hero -->
      <section style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 3rem;">
        <img src="/avatar.jpg" alt="Ken Imoto" style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover; border: 3px solid var(--border-avatar); flex-shrink: 0;" />
        <div>
          <h1 style="font-size: 1.75rem; font-weight: 700; margin: 0 0 0.25rem;">Ken Imoto</h1>
          <p style="font-size: 1rem; color: var(--text-label); margin: 0;">AI Systems Engineer</p>
          <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0.25rem 0 0;">Founder, <a href="https://propel-lab.co.jp/?utm_source=kenimoto.dev&utm_medium=referral&utm_campaign=cross-property&utm_content=about-founder">Propel-Lab</a></p>
        </div>
      </section>

      <!-- Short Bio -->
      <section style="margin-bottom: 2rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin: 0;">Short Bio</h2>
          <button class="copy-btn" data-copy="short-bio">Copy</button>
        </div>
        <div class="bio-block">
          <p id="short-bio" style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7; margin: 0;">Ken Imoto is a WebRTC & Voice AI engineer and founder of Propel-Lab. He is the author of the LLMO Framework and has published 30+ Kindle editions across 4 languages (plus 12 Zenn Books) on AI development, context engineering, and AI search optimization.</p>
        </div>
      </section>

      <!-- Medium Bio -->
      <section style="margin-bottom: 2rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin: 0;">Medium Bio</h2>
          <button class="copy-btn" data-copy="medium-bio">Copy</button>
        </div>
        <div class="bio-block">
          <p id="medium-bio" style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7; margin: 0;">Ken Imoto is a WebRTC & Voice AI engineer building AI-native organizations at Propel-Lab. He is the creator of the LLMO (Large Language Model Optimization) Framework, which helps businesses optimize their content visibility in AI-powered search engines. Ken has published 30+ Kindle editions across English, Japanese, Portuguese, and Spanish — including "Practical Claude Code," "Harness Engineering," "Knowledge Graph Practical Guide," and "LLMO Practical Guide" — plus 12 Zenn Books. His research spans AI text analysis, vision-language model bias, and voice AI latency optimization, with 3 papers published on Zenodo. His technical writing on Qiita spans 105+ articles and has attracted over 210,000 pageviews.</p>
        </div>
      </section>

      <!-- Full Bio -->
      <section style="margin-bottom: 2rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem;">
          <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin: 0;">Full Bio</h2>
          <button class="copy-btn" data-copy="full-bio">Copy</button>
        </div>
        <div class="bio-block">
          <div id="full-bio" style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.7;">
            <p style="margin: 0 0 1rem;">Ken Imoto is a WebRTC & Voice AI engineer and founder of Propel-Lab, where he builds AI-native organizations powered by LLMs, automation, and distributed agents.</p>
            <p style="margin: 0 0 1rem;">He is the creator of the LLMO (Large Language Model Optimization) Framework, a systematic approach to optimizing content visibility in AI-powered search engines like ChatGPT and Perplexity. The framework is documented in his book "Why ChatGPT Ignores Your Website: The LLMO Practical Guide" and the companion site llmoframework.com.</p>
            <p style="margin: 0 0 1rem;">Ken has published 30+ Kindle editions across English, Japanese, Portuguese, and Spanish (plus 12 Zenn Books) spanning AI development, context engineering, knowledge graphs, MCP security, and AI search optimization. Notable titles include "Practical Claude Code — Context Engineering for Modern Development," "Harness Engineering — From Using AI to Controlling AI," "Knowledge Graph Practical Guide — Structure Your Data, Sharpen Your AI," and "MCP Security in Practice."</p>
            <p style="margin: 0 0 1rem;">His research includes three peer-reviewed papers on Zenodo: "Excess Vocabulary in Japanese AI-Generated Text" (analyzing 651 statistically significant excess words across 7 LLMs), "AI Text Slop" (measuring stylistic convergence in Japanese technical writing), and "AI Blue" (quantifying color recognition bias in vision-language models). These studies are the first quantitative analyses linking specific LLM behaviors to the broader "AI Slop" phenomenon.</p>
            <p style="margin: 0;">Ken is currently researching voice AI latency optimization (the 300ms barrier), context engineering for multi-agent AI systems, and generative agent simulation.</p>
          </div>
        </div>
      </section>

      <!-- Featured Work -->
      <section style="margin-bottom: 2rem;">
        <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.75rem;">Featured Work</h2>
        <div class="bio-block">
          <ul style="margin: 0; padding-left: 1.25rem; line-height: 1.95; font-size: 0.95rem; color: var(--text-secondary);">
            <li><a href="https://qiita.com/kenimo49/items/dff3c8a2a0ee563ca16f">"Running Qwen 35B on 12GB VRAM"</a> — <strong>60,000+ PV</strong> on Qiita <span style="color: var(--text-label); font-size: 0.85rem;">(2026-06)</span></li>
            <li><a href="https://qiita.com/kenimo49/items/27e2a11e80fe3b835f96">"Managing Everything on GitHub in the AI Era"</a> — <strong>45,000+ PV / 241 LGTM</strong> on Qiita <span style="color: var(--text-label); font-size: 0.85rem;">(2026-03)</span></li>
            <li><a href="https://zenn.dev/kenimo49/articles/code-review-6-stages-ai-human-boundary">"Six-Stage Code Review Reveals the New Human-AI Division of Labor"</a> — <strong>284 Likes</strong> on Zenn <span style="color: var(--text-label); font-size: 0.85rem;">(2026-05)</span></li>
            <li><a href="https://zenn.dev/kenimo49/articles/harness-engineering-interpretations-2026">"Harness Engineering: Five Companies, Five Definitions"</a> — <strong>130 Likes</strong> on Zenn <span style="color: var(--text-label); font-size: 0.85rem;">(2026-04)</span></li>
            <li><a href="https://www.tabnews.com.br/kenimo49">Top posts on TabNews</a> (Brazil PT-BR) — earning <strong>10–12 tabcoins each</strong> <span style="color: var(--text-label); font-size: 0.85rem;">(2026-05–06)</span></li>
          </ul>
        </div>
      </section>

      <!-- Key Statements -->
      <section style="margin-bottom: 2rem;">
        <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.75rem;">Key Statements</h2>
        <div class="bio-block">
          <ul style="margin: 0; padding-left: 1.25rem; line-height: 1.95; font-size: 0.95rem; color: var(--text-secondary);">
            <li>"Engineers don't need a faster model. They need a harness." <span style="color: var(--text-label); font-size: 0.85rem;">— <a href="/books/harness-engineering-guide/"><em>Harness Engineering</em></a></span></li>
            <li>"AI search citation is decided by passages, not pages." <span style="color: var(--text-label); font-size: 0.85rem;">— <a href="/books/llmo-ai-search-optimization/"><em>LLMO Practical Guide</em></a></span></li>
            <li>"An LLM doesn't get smarter — your structure does." <span style="color: var(--text-label); font-size: 0.85rem;">— <a href="/books/knowledge-graph-practical-guide/"><em>Knowledge Graph Practical Guide</em></a></span></li>
            <li>"What changes Claude Code's output isn't the model — it's the context you frame it with." <span style="color: var(--text-label); font-size: 0.85rem;">— <a href="/books/claude-code-mastery/"><em>Practical Claude Code</em></a></span></li>
            <li>"The 300ms latency boundary is where 'AI conversation' becomes 'AI assistant.'" <span style="color: var(--text-label); font-size: 0.85rem;">— <a href="/books/voice-ai-300ms-ux/"><em>Voice AI 300ms</em></a></span></li>
            <li>"Context Engineering turns LLMs from liars into experts." <span style="color: var(--text-label); font-size: 0.85rem;">— <a href="/books/context-engineering/"><em>Context Engineering in Practice</em></a></span></li>
            <li>"LLMO is the discipline of making content quotable by machines, not just findable." <span style="color: var(--text-label); font-size: 0.85rem;">— <a href="/books/llmo-quickstart/"><em>LLMO Quickstart</em></a></span></li>
          </ul>
        </div>
      </section>

      <!-- Media Kit -->
      <section style="margin-bottom: 2rem;">
        <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.75rem;">Media Kit</h2>
        <div class="bio-block">
          <div style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 1rem;">
            <img src="/avatar.jpg" alt="Ken Imoto" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 2px solid var(--border-avatar);" />
            <div>
              <p style="font-size: 0.85rem; font-weight: 600; margin: 0 0 0.25rem;">Profile Photo</p>
              <a href="/avatar.jpg" download style="font-size: 0.75rem;">Download (JPG)</a>
            </div>
          </div>
          <div style="font-size: 0.8rem; color: var(--text-label); line-height: 1.7;">
            <p style="margin: 0 0 0.5rem; font-weight: 600;">Usage Guidelines</p>
            <ul style="margin: 0; padding-left: 1.25rem;">
              <li>Do not crop or alter the photo</li>
              <li>Use "Ken Imoto" for attribution</li>
              <li>Link to kenimoto.dev when possible</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Side Projects -->
      <section style="margin-bottom: 2rem;">
        <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.75rem;">Side Projects</h2>
        <ul style="list-style: none; padding: 0; line-height: 2;">
          <li>🥃 <a href="https://legacydram.com/" target="_blank" rel="noopener noreferrer">legacydram.com</a> — Whisky curation read through an engineer's lens</li>
        </ul>
      </section>

      <!-- Open Source -->
      <section style="margin-bottom: 2rem;">
        <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.75rem;">Open Source</h2>
        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
          <div>
            <p style="margin: 0 0 0.25rem; font-weight: 600;"><a href="https://github.com/kenimo49/domain-pre-flight" target="_blank" rel="noopener noreferrer">domain-pre-flight</a> — Python CLI · MIT</p>
            <p style="margin: 0; font-size: 0.85rem; color: var(--text-label); line-height: 1.6;">A pre-flight check before you register a domain for a new site or app. Structure, history, typosquat, multi-language semantics, LLMO, and trademark deeplinks in one command.</p>
          </div>
          <div>
            <p style="margin: 0 0 0.25rem; font-weight: 600;"><a href="https://github.com/kenimo49/voice-clone" target="_blank" rel="noopener noreferrer">voice-clone</a> — Python · MIT</p>
            <p style="margin: 0; font-size: 0.85rem; color: var(--text-label); line-height: 1.6;">A voice-cloning tool built on Qwen3-TTS. Clone a voice from ~3 seconds of audio and have any text read in that voice. WSLg recording, multi-language.</p>
          </div>
          <div>
            <p style="margin: 0 0 0.25rem; font-weight: 600;"><a href="https://github.com/kenimo49/speech-habit-lens" target="_blank" rel="noopener noreferrer">speech-habit-lens</a> — Python CLI · MIT</p>
            <p style="margin: 0; font-size: 0.85rem; color: var(--text-label); line-height: 1.6;">A 1-minute speech habit analyzer that combines AmiVoice ESAS (20 acoustic emotion parameters) with an LLM. Three layers — acoustic, textual, and the cross-layer that links body and language — rendered as a Markdown report.</p>
          </div>
          <div>
            <p style="margin: 0 0 0.25rem; font-weight: 600;"><a href="https://github.com/kenimo49/persona-hub" target="_blank" rel="noopener noreferrer">persona-hub</a> — TypeScript + Python · Apache-2.0</p>
            <p style="margin: 0; font-size: 0.85rem; color: var(--text-label); line-height: 1.6;">A two-part persona hub: a lightweight TypeScript SDK that scores quiz answers locally, and an optional FastAPI service that persists results so the same user can carry their profile across services. Architecture borrowed from LaunchDarkly + Segment Engage, applied to persona aggregation. Pre-alpha.</p>
          </div>
        </div>
      </section>

      <!-- Connect -->
      <section>
        <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.75rem;">Connect</h2>
        <ul style="list-style: none; padding: 0; line-height: 2;">
          {links.map(link => (
            <li><a href={link.url}>{link.label}</a></li>
          ))}
          <li>📧 <a href="mailto:imoto@propel-lab.co.jp">imoto@propel-lab.co.jp</a></li>
        </ul>
      </section>
    </main>

    <script is:inline>
      document.querySelectorAll('.copy-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var targetId = btn.getAttribute('data-copy');
          var el = document.getElementById(targetId);
          if (!el) return;
          var text = el.innerText;
          navigator.clipboard.writeText(text).then(function() {
            btn.textContent = 'Copied!';
            setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
          });
        });
      });
    </script>
</BaseLayout>
