---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'ja'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Collect all tags with counts
const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}
const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);

// Group posts by year
const postsByYear = new Map<number, typeof posts>();
for (const post of posts) {
  const year = post.data.date.getFullYear();
  if (!postsByYear.has(year)) postsByYear.set(year, []);
  postsByYear.get(year)!.push(post);
}
---

<BaseLayout
  title="ブログ — 井本 賢"
  description="LLMO、AI開発、コンテキストエンジニアリング、ハーネスエンジニアリングの技術記事。"
  lang="ja"
  ogUrl="https://kenimoto.dev/ja/blog"
  ogDescription="井本 賢の技術記事。"
>
  <Fragment slot="head">
    <link rel="alternate" type="application/rss+xml" title="井本 賢 — ブログ (JA)" href="/ja/blog.xml" />
    <link rel="alternate" hreflang="en" href="https://kenimoto.dev/blog" />
    <style>
      .tag-filter {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 2rem;
      }
      .tag-btn {
        background: none;
        border: 1px solid var(--text-separator);
        color: var(--text-label);
        padding: 0.25rem 0.65rem;
        border-radius: 4px;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.15s;
      }
      .tag-btn:hover {
        color: var(--text-primary);
        border-color: var(--text-label);
      }
      .tag-btn.active {
        background: var(--accent-blue);
        color: #fff;
        border-color: var(--accent-blue);
      }
      .post-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .post-item {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        padding: 0.5rem 0;
      }
      .post-item time {
        font-size: 0.85rem;
        color: var(--text-muted);
        white-space: nowrap;
        min-width: 5.5rem;
      }
      .post-item a {
        font-size: 1rem;
        color: var(--text-primary);
        text-decoration: none;
      }
      .post-item a:hover {
        color: var(--link-color);
      }
      .post-item.hidden {
        display: none;
      }
      .year-group.hidden {
        display: none;
      }
      .year-heading {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 2.5rem 0 0.75rem;
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
      }
      .year-heading:first-child {
        margin-top: 0;
      }
      .year-count {
        font-size: 0.8rem;
        font-weight: 400;
        color: var(--text-muted);
      }
      @media (max-width: 480px) {
        .post-item {
          flex-direction: column;
          gap: 0.15rem;
        }
      }
    </style>
  </Fragment>

  <Nav lang="ja" current="blog" />

  <main style="max-width: 720px; margin: 0 auto; padding: 4rem 2rem;">
    <h1 style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem;">ブログ</h1>
    <p style="color: var(--text-muted); margin-bottom: 1.5rem; font-size: 0.95rem;">
      AI開発、LLMO、コンテキストエンジニアリング、ハーネスエンジニアリングの技術記事。
    </p>

    {sortedTags.length > 0 && (
      <div class="tag-filter">
        <button class="tag-btn active" data-tag="all">All</button>
        {sortedTags.map(([tag, count]) => (
          <button class="tag-btn" data-tag={tag}>{tag} <span style="opacity: 0.6;">{count}</span></button>
        ))}
      </div>
    )}

    {posts.length === 0 && (
      <p style="color: var(--text-muted);">まだ記事がありません。</p>
    )}

    {[...postsByYear.entries()].map(([year, yearPosts]) => (
      <div class="year-group">
        <h2 class="year-heading">
          {year}
          <span class="year-count">{yearPosts.length}件</span>
        </h2>
        <ul class="post-list">
          {yearPosts.map(post => {
            const slug = post.id.replace(/^ja\//, '');
            const d = post.data.date;
            const monthDay = `${d.getMonth() + 1}月${d.getDate()}日`;
            return (
              <li class="post-item" data-tags={post.data.tags.join(',')}>
                <time datetime={d.toISOString().split('T')[0]}>{monthDay}</time>
                <a href={`/ja/blog/${slug}`}>{post.data.title}</a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}

    <div style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--text-separator); font-size: 0.85rem; color: var(--text-muted);">
      <a href="/ja/blog.xml" style="color: var(--link-color);">RSS フィード</a>
    </div>
  </main>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var buttons = document.querySelectorAll('.tag-btn');
      buttons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var tag = btn.getAttribute('data-tag');
          buttons.forEach(function(b) { b.classList.remove('active'); });
          btn.classList.add('active');

          var items = document.querySelectorAll('.post-item');
          items.forEach(function(item) {
            if (tag === 'all') {
              item.classList.remove('hidden');
            } else {
              var tags = (item.getAttribute('data-tags') || '').split(',');
              item.classList.toggle('hidden', tags.indexOf(tag) === -1);
            }
          });

          // Hide year groups where all posts are hidden
          document.querySelectorAll('.year-group').forEach(function(group) {
            var visible = group.querySelectorAll('.post-item:not(.hidden)');
            group.classList.toggle('hidden', visible.length === 0);
          });
        });
      });
    });
  </script>
</BaseLayout>
