---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('books');
const books = all.filter((b) => b.data.lang === 'ja');

const SITE_URL = 'https://kenimoto.dev';
const canonicalUrl = `${SITE_URL}/ja/books/`;

const sorted = [...books].sort((a, b) => {
  const ad = a.data.published_date instanceof Date ? a.data.published_date.getTime() : 0;
  const bd = b.data.published_date instanceof Date ? b.data.published_date.getTime() : 0;
  return bd - ad;
});

const collectionPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${canonicalUrl}#collection`,
  name: '書籍一覧',
  url: canonicalUrl,
  inLanguage: 'ja-JP',
  isPartOf: { '@id': `${SITE_URL}/#website` },
  hasPart: sorted.map((b) => {
    const slug = b.id.replace(/^ja\//, '');
    return { '@type': 'Book', '@id': `${SITE_URL}/ja/books/${slug}/#book`, name: b.data.title, url: `${SITE_URL}/ja/books/${slug}/` };
  }),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: `${SITE_URL}/ja/` },
    { '@type': 'ListItem', position: 2, name: '書籍', item: canonicalUrl },
  ],
};

const alternates = [
  { hreflang: 'en', href: `${SITE_URL}/books/` },
  { hreflang: 'ja', href: `${SITE_URL}/ja/books/` },
  { hreflang: 'pt', href: `${SITE_URL}/pt/books/` },
  { hreflang: 'es', href: `${SITE_URL}/es/books/` },
  { hreflang: 'x-default', href: `${SITE_URL}/books/` },
];
---

<BaseLayout
  title="書籍一覧 — 井本 賢"
  description="井本 賢の書籍一覧。Claude Code、Context Engineering、LLMO、ハーネスエンジニアリング、ナレッジグラフ、音声AI、MCPセキュリティなど。"
  lang="ja"
  ogUrl={canonicalUrl}
  ogDescription="井本 賢の書籍一覧。AIエンジニアリングと現代開発に関する書籍。"
  alternates={alternates}
  jsonLd={[collectionPageJsonLd, breadcrumbJsonLd]}
>
  <Nav lang="ja" current="" alternates={alternates} />

  <main class="books-index">
    <h1>書籍一覧</h1>
    <p class="lead">井本 賢の書籍一覧。AIエンジニアリングと現代開発に関する書籍をまとめています。</p>

    <ul class="books-grid">
      {sorted.map((b) => {
        const slug = b.id.replace(/^ja\//, '');
        const href = `/ja/books/${slug}/`;
        return (
          <li>
            <a href={href} class="book-card" aria-label={b.data.title}>
              {b.data.cover_image ? (
                <img src={b.data.cover_image} alt={`${b.data.title} 表紙`} class="book-card-cover" loading="lazy" />
              ) : (
                <div class="book-card-cover book-card-fallback">No cover</div>
              )}
              <div class="book-card-body">
                <p class="book-card-title">{b.data.title}</p>
                {b.data.subtitle && <p class="book-card-subtitle">{b.data.subtitle}</p>}
                {b.data.series_role && <p class="book-card-role">{b.data.series_role}</p>}
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </main>
</BaseLayout>

<style>
  .books-index {
    max-width: 960px;
    margin: 0 auto;
    padding: 2.5rem 2rem 4rem;
  }
  .books-index h1 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0.5rem 0 0.5rem;
    color: var(--text-primary);
  }
  .books-index .lead {
    color: var(--text-secondary);
    margin: 0 0 2rem;
    line-height: 1.7;
  }
  .books-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  @media (min-width: 640px) {
    .books-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .books-grid li { margin: 0; }
  .book-card {
    display: flex;
    gap: 1rem;
    background: var(--bg-card);
    padding: 1rem;
    border-radius: 8px;
    text-decoration: none;
    color: var(--text-secondary);
    transition: outline 0.15s;
    align-items: flex-start;
    height: 100%;
  }
  .book-card:hover { outline: 1px solid var(--accent-blue); text-decoration: none; }
  .book-card-cover {
    width: 84px;
    aspect-ratio: 5 / 7;
    object-fit: cover;
    border-radius: 4px;
    flex-shrink: 0;
    background: var(--bg-primary);
  }
  .book-card-fallback {
    display: flex; align-items: center; justify-content: center;
    color: var(--text-muted); font-size: 0.7rem;
  }
  .book-card-body { flex: 1; min-width: 0; }
  .book-card-title {
    font-size: 0.98rem; font-weight: 700; color: var(--text-primary);
    margin: 0 0 0.25rem; line-height: 1.35;
  }
  .book-card-subtitle {
    font-size: 0.82rem; color: var(--text-label);
    margin: 0 0 0.5rem; line-height: 1.45;
  }
  .book-card-role {
    font-size: 0.75rem; color: var(--text-label);
    margin: 0; line-height: 1.4;
  }
  @media (max-width: 640px) {
    .books-index { padding: 1.5rem 1rem 3rem; }
  }
</style>
