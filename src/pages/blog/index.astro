---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group posts by year
const postsByYear = new Map<number, typeof posts>();
for (const post of posts) {
  const year = post.data.date.getFullYear();
  if (!postsByYear.has(year)) postsByYear.set(year, []);
  postsByYear.get(year)!.push(post);
}
---

<BaseLayout
  title="Blog — Ken Imoto"
  description="Articles on LLMO, AI development, context engineering, harness engineering, and more."
  lang="en"
  ogUrl="https://kenimoto.dev/blog"
  ogDescription="Technical articles by Ken Imoto."
>
  <Fragment slot="head">
    <link rel="alternate" type="application/rss+xml" title="Ken Imoto — Blog (EN)" href="/blog.xml" />
    <link rel="alternate" hreflang="ja" href="https://kenimoto.dev/ja/blog" />
    <style>
      .post-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .post-item {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        padding: 0.5rem 0;
      }
      .post-item time {
        font-size: 0.85rem;
        color: var(--text-muted);
        white-space: nowrap;
        min-width: 5.5rem;
      }
      .post-item a {
        font-size: 1rem;
        color: var(--text-primary);
        text-decoration: none;
      }
      .post-item a:hover {
        color: var(--link-color);
      }
      .year-heading {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 2.5rem 0 0.75rem;
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
      }
      .year-heading:first-child {
        margin-top: 0;
      }
      .year-count {
        font-size: 0.8rem;
        font-weight: 400;
        color: var(--text-muted);
      }
      @media (max-width: 480px) {
        .post-item {
          flex-direction: column;
          gap: 0.15rem;
        }
      }
    </style>
  </Fragment>

  <Nav lang="en" current="blog" />

  <main style="max-width: 720px; margin: 0 auto; padding: 4rem 2rem;">
    <h1 style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem;">Blog</h1>
    <p style="color: var(--text-muted); margin-bottom: 2.5rem; font-size: 0.95rem;">
      Articles on AI development, LLMO, context engineering, and harness engineering.
    </p>

    {posts.length === 0 && (
      <p style="color: var(--text-muted);">No articles yet. Check back soon.</p>
    )}

    {[...postsByYear.entries()].map(([year, yearPosts]) => (
      <div>
        <h2 class="year-heading">
          {year}
          <span class="year-count">{yearPosts.length} {yearPosts.length === 1 ? 'post' : 'posts'}</span>
        </h2>
        <ul class="post-list">
          {yearPosts.map(post => {
            const slug = post.id.replace(/^en\//, '');
            const d = post.data.date;
            const monthDay = d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
            return (
              <li class="post-item">
                <time datetime={d.toISOString().split('T')[0]}>{monthDay}</time>
                <a href={`/blog/${slug}`}>{post.data.title}</a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}

    <div style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--text-separator); font-size: 0.85rem; color: var(--text-muted);">
      <a href="/blog.xml" style="color: var(--link-color);">RSS Feed</a>
    </div>
  </main>
</BaseLayout>
