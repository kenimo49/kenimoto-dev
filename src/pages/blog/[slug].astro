---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection, render } from 'astro:content';
import { alternatesFor, normalizeCanonical } from '../../lib/alternates';
import { estimateReadingTime } from '../../lib/reading-time';

export async function getStaticPaths() {
  const all = await getCollection('blog');
  const posts = all.filter(p => p.data.lang === 'en');
  return posts.map(post => {
    const slug = post.id.replace(/^en\//, '');
    return {
      params: { slug },
      props: { post, alternates: alternatesFor(all, 'blog', slug, post.data.translation_key) },
    };
  });
}

const { post, alternates } = Astro.props;
const { Content, headings } = await render(post);
const slug = post.id.replace(/^en\//, '');
const canonicalUrl = normalizeCanonical(post.data.canonical_url, `https://kenimoto.dev/blog/${slug}/`);
const readingTime = estimateReadingTime(post.body ?? '', 'en');
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  lang="en"
  date={post.data.date}
  updated={post.data.updated}
  tags={post.data.tags}
  canonicalUrl={canonicalUrl}
  ogImage={post.data.og_image}
  alternates={alternates}
  headings={headings}
  readingTime={readingTime}
>
  <Content />
</BlogLayout>
