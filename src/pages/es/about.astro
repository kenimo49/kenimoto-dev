---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';
import { staticAlternates } from '../../lib/alternates';
import { buildPersonEntity, buildOrganizationEntity, buildWebSiteEntity } from '../../lib/person-entity';

const esBooks = (await getCollection('books', ({ data }) => data.lang === 'es'))
  .sort((a, b) => b.data.published_date.valueOf() - a.data.published_date.valueOf());

// AI が引用する時の一次プロフィール正典。/about/ こそ Person/Organization/WebSite を載せる場所。
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    buildPersonEntity('es'),
    buildOrganizationEntity(),
    buildWebSiteEntity('es'),
  ],
};

// ES about: ES 関連プラットフォーム + cross-platform。AI が同一人物性を解決しやすいよう、sameAs と HTML 本文を一致させる
const links = [
  { label: 'Amazon ES', url: 'https://www.amazon.es/stores/author/B0GQNPRCGF' },
  { label: 'GitHub', url: 'https://github.com/kenimo49' },
  { label: 'LinkedIn', url: 'https://linkedin.com/in/kenimo49' },
  { label: 'X', url: 'https://x.com/kenimo49' },
  { label: 'DEV.to', url: 'https://dev.to/kenimo49' },
  { label: 'Medium', url: 'https://medium.com/@kenimo49' },
  { label: 'Hashnode', url: 'https://kenimo49.hashnode.dev' },
  { label: 'Zenn', url: 'https://zenn.dev/kenimo49' },
  { label: 'Qiita', url: 'https://qiita.com/kenimo49' },
  { label: 'Docswell', url: 'https://www.docswell.com/user/kenimo49' },
  { label: 'SpeakerDeck', url: 'https://speakerdeck.com/kenimo49' },
  { label: 'TabNews', url: 'https://www.tabnews.com.br/kenimo49' },
];
---

<BaseLayout
  title="Sobre Ken Imoto"
  description="Sobre Ken Imoto: ingeniero de WebRTC y Voice AI, fundador de Propel-Lab, autor del LLMO Framework y de 30+ ediciones Kindle en 4 idiomas sobre desarrollo con IA."
  lang="es"
  ogUrl="https://kenimoto.dev/es/about/"
  ogDescription="Sobre Ken Imoto: ingeniero de WebRTC y Voice AI, autor del LLMO Framework."
  alternates={staticAlternates('/about/')}
  jsonLd={jsonLd}
>
  <Fragment slot="head">
    <style>
      .bio-block {
        background: var(--bg-card);
        border-radius: 8px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
      }
      .book-row {
        display: flex;
        gap: 1rem;
        padding: 1rem;
        background: var(--bg-card);
        border-radius: 8px;
        text-decoration: none;
        color: var(--text-secondary);
        transition: outline 0.15s;
        align-items: flex-start;
      }
      .book-row:hover {
        outline: 1px solid var(--accent-blue);
        text-decoration: none;
      }
      .book-row-cover {
        width: 70px;
        aspect-ratio: 5 / 7;
        object-fit: cover;
        border-radius: 4px;
        flex-shrink: 0;
      }
      .book-row h3 {
        font-size: 1rem;
        font-weight: 700;
        margin: 0 0 0.2rem;
        color: var(--text-primary);
        line-height: 1.35;
      }
      .book-row p {
        font-size: 0.85rem;
        color: var(--text-label);
        margin: 0;
        line-height: 1.4;
      }
    </style>
  </Fragment>

  <Nav lang="es" current="about" />

  <main style="max-width: 600px; margin: 0 auto; padding: 4rem 2rem;">
    <section style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 3rem;">
      <img src="/avatar.jpg" alt="Ken Imoto" style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover; border: 3px solid var(--border-avatar); flex-shrink: 0;" />
      <div>
        <h1 style="font-size: 1.75rem; font-weight: 700; margin: 0 0 0.25rem;">Ken Imoto</h1>
        <p style="font-size: 1rem; color: var(--text-label); margin: 0;">Ingeniero de WebRTC y Voice AI</p>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0.25rem 0 0;">Fundador, <a href="https://propel-lab.co.jp/?utm_source=kenimoto.dev&utm_medium=referral&utm_campaign=cross-property&utm_content=about-founder">Propel-Lab</a></p>
      </div>
    </section>

    <section style="margin-bottom: 2rem;">
      <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.75rem;">Biografía</h2>
      <div class="bio-block">
        <p style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.75; margin: 0 0 1rem;">
          Ken Imoto es ingeniero de WebRTC y Voice AI, fundador de Propel-Lab. Construye organizaciones AI-native usando LLMs, automatización y agentes distribuidos.
        </p>
        <p style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.75; margin: 0 0 1rem;">
          Es el creador del LLMO (Large Language Model Optimization) Framework, una metodología para optimizar la visibilidad del contenido en buscadores impulsados por IA como ChatGPT y Perplexity. El framework está documentado en el libro <em>Why ChatGPT Ignores Your Website: The LLMO Practical Guide</em> y en el sitio complementario <a href="https://llmoframework.com">llmoframework.com</a>.
        </p>
        <p style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.75; margin: 0 0 1rem;">
          Ha publicado 30+ ediciones Kindle en 4 idiomas (inglés, japonés, portugués y español) y 12 Zenn Books sobre desarrollo con IA, ingeniería de contexto, knowledge graphs, seguridad de MCP y optimización para búsqueda con IA. Títulos destacados: <em>Practical Claude Code</em>, <em>Harness Engineering</em>, <em>Knowledge Graph Practical Guide</em> y <em>MCP Security in Practice</em>.
        </p>
        <p style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.75; margin: 0;">
          Investigación actual: optimización de latencia en Voice AI (la barrera de los 300ms), ingeniería de contexto para sistemas multi-agente y simulación de agentes generativos. Cuatro artículos publicados en Zenodo: tres sobre análisis cuantitativo de texto generado por IA, sesgo de color en modelos de visión-lenguaje y patrones estilísticos en escritura técnica japonesa, más uno sobre la comparación de Pareto entre configuraciones de coding agente ("When Free Executors Cost More").
        </p>
      </div>
    </section>

    <section style="margin-bottom: 2rem;">
      <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.75rem;">Trabajos destacados</h2>
      <div class="bio-block">
        <ul style="margin: 0; padding-left: 1.25rem; line-height: 1.95; font-size: 0.95rem; color: var(--text-secondary);">
          <li><a href="https://qiita.com/kenimo49/items/dff3c8a2a0ee563ca16f">"Ejecutando Qwen 35B en 12GB de VRAM"</a> — <strong>60.000+ PV</strong> en Qiita <span style="color: var(--text-label); font-size: 0.85rem;">(2026-06)</span></li>
          <li><a href="https://qiita.com/kenimo49/items/27e2a11e80fe3b835f96">"Gestionando todo en GitHub en la era de la IA"</a> — <strong>45.000+ PV / 241 LGTM</strong> en Qiita <span style="color: var(--text-label); font-size: 0.85rem;">(2026-03)</span></li>
          <li><a href="https://zenn.dev/kenimo49/articles/code-review-6-stages-ai-human-boundary">"Revisión de código en 6 etapas revela la nueva división de trabajo humano-IA"</a> — <strong>284 Likes</strong> en Zenn <span style="color: var(--text-label); font-size: 0.85rem;">(2026-05)</span></li>
          <li><a href="https://zenn.dev/kenimo49/articles/harness-engineering-interpretations-2026">"Harness Engineering: 5 empresas, 5 definiciones"</a> — <strong>130 Likes</strong> en Zenn <span style="color: var(--text-label); font-size: 0.85rem;">(2026-04)</span></li>
          <li><a href="https://www.tabnews.com.br/kenimo49">Posts destacados en TabNews (Brasil)</a> — <strong>10–12 tabcoins por post</strong> <span style="color: var(--text-label); font-size: 0.85rem;">(2026-05–06)</span></li>
        </ul>
      </div>
    </section>

    <section style="margin-bottom: 2rem;">
      <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.75rem;">Frases clave</h2>
      <div class="bio-block">
        <ul style="margin: 0; padding-left: 1.25rem; line-height: 1.95; font-size: 0.95rem; color: var(--text-secondary);">
          <li>"Los ingenieros no necesitan un modelo más rápido. Necesitan un harness." <span style="color: var(--text-label); font-size: 0.85rem;">— <a href="/es/books/harness-engineering-guide/"><em>Harness Engineering</em></a></span></li>
          <li>"La cita en búsqueda por IA se decide por pasajes, no por páginas." <span style="color: var(--text-label); font-size: 0.85rem;">— <a href="/books/llmo-ai-search-optimization/"><em>LLMO Practical Guide</em></a></span></li>
          <li>"Un LLM no se vuelve más inteligente — tu estructura sí." <span style="color: var(--text-label); font-size: 0.85rem;">— <a href="/books/knowledge-graph-practical-guide/"><em>Knowledge Graph Practical Guide</em></a></span></li>
          <li>"Lo que cambia el resultado de Claude Code no es el modelo — es el contexto en que lo enmarcas." <span style="color: var(--text-label); font-size: 0.85rem;">— <a href="/es/books/claude-code-mastery/"><em>Practical Claude Code</em></a></span></li>
          <li>"La frontera de los 300ms de latencia es donde 'conversación con IA' se vuelve 'asistente de IA'." <span style="color: var(--text-label); font-size: 0.85rem;">— <a href="/books/voice-ai-300ms-ux/"><em>Voice AI 300ms</em></a></span></li>
          <li>"La Ingeniería de Contexto convierte a los LLMs de mentirosos en expertos." <span style="color: var(--text-label); font-size: 0.85rem;">— <a href="/books/context-engineering/"><em>Context Engineering in Practice</em></a></span></li>
          <li>"LLMO es la disciplina de hacer que el contenido sea citable por máquinas, no solo localizable." <span style="color: var(--text-label); font-size: 0.85rem;">— <a href="/books/llmo-quickstart/"><em>LLMO Quickstart</em></a></span></li>
        </ul>
      </div>
    </section>

    <section style="margin-bottom: 2rem;">
      <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.75rem;">
        Ediciones en español ({esBooks.length})
      </h2>
      {esBooks.length === 0 ? (
        <div class="bio-block">
          <p style="font-size: 0.9rem; color: var(--text-muted); margin: 0;">
            No hay ediciones en español disponibles aún. Próximamente. Mientras tanto, consulta la colección completa en <a href="/">inglés</a> o <a href="/ja/">japonés</a>.
          </p>
        </div>
      ) : (
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
          {esBooks.map((book) => {
            const slug = book.id.replace(/^es\//, '');
            return (
              <a href={`/es/books/${slug}/`} class="book-row">
                {book.data.cover_image && (
                  <img src={book.data.cover_image} alt={`${book.data.title} portada`} class="book-row-cover" loading="lazy" />
                )}
                <div>
                  <h3>{book.data.title}</h3>
                  {book.data.subtitle && <p>{book.data.subtitle}</p>}
                </div>
              </a>
            );
          })}
        </div>
      )}
      <p style="font-size: 0.85rem; color: var(--text-muted); margin: 1rem 0 0;">
        La colección completa (en inglés y japonés) está en <a href="/">kenimoto.dev</a>.
      </p>
    </section>

    <section>
      <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.75rem;">Contacto</h2>
      <ul style="list-style: none; padding: 0; line-height: 2;">
        {links.map(link => (
          <li><a href={link.url}>{link.label}</a></li>
        ))}
        <li>📧 <a href="mailto:imoto@propel-lab.co.jp">imoto@propel-lab.co.jp</a></li>
      </ul>
    </section>
  </main>
</BaseLayout>
