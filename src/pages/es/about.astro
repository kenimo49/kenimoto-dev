---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

const esBooks = (await getCollection('books', ({ data }) => data.lang === 'es'))
  .sort((a, b) => b.data.published_date.valueOf() - a.data.published_date.valueOf());

const links = [
  { label: 'GitHub', url: 'https://github.com/kenimo49' },
  { label: 'LinkedIn', url: 'https://linkedin.com/in/kenimo49' },
  { label: 'X', url: 'https://x.com/kenimo49' },
  { label: 'DEV.to', url: 'https://dev.to/kenimo49' },
  { label: 'Amazon ES', url: 'https://www.amazon.es/stores/author/B0GQNPRCGF' },
];
---

<BaseLayout
  title="Sobre Ken Imoto"
  description="Sobre Ken Imoto: ingeniero de WebRTC y Voice AI, fundador de Propel-Lab, autor del LLMO Framework y de 11 libros sobre desarrollo con IA."
  lang="es"
  ogUrl="https://kenimoto.dev/es/about/"
  ogDescription="Sobre Ken Imoto: ingeniero de WebRTC y Voice AI, autor del LLMO Framework."
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="en" href="https://kenimoto.dev/about/" />
    <link rel="alternate" hreflang="ja" href="https://kenimoto.dev/ja/about/" />
    <link rel="alternate" hreflang="es" href="https://kenimoto.dev/es/about/" />
    <link rel="alternate" hreflang="x-default" href="https://kenimoto.dev/about/" />
    <style>
      .bio-block {
        background: var(--bg-card);
        border-radius: 8px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
      }
      .book-row {
        display: flex;
        gap: 1rem;
        padding: 1rem;
        background: var(--bg-card);
        border-radius: 8px;
        text-decoration: none;
        color: var(--text-secondary);
        transition: outline 0.15s;
        align-items: flex-start;
      }
      .book-row:hover {
        outline: 1px solid var(--accent-blue);
        text-decoration: none;
      }
      .book-row-cover {
        width: 70px;
        aspect-ratio: 5 / 7;
        object-fit: cover;
        border-radius: 4px;
        flex-shrink: 0;
      }
      .book-row h3 {
        font-size: 1rem;
        font-weight: 700;
        margin: 0 0 0.2rem;
        color: var(--text-primary);
        line-height: 1.35;
      }
      .book-row p {
        font-size: 0.85rem;
        color: var(--text-label);
        margin: 0;
        line-height: 1.4;
      }
    </style>
  </Fragment>

  <Nav lang="es" current="about" />

  <main style="max-width: 600px; margin: 0 auto; padding: 4rem 2rem;">
    <section style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 3rem;">
      <img src="/avatar.jpg" alt="Ken Imoto" style="width: 100px; height: 100px; border-radius: 50%; object-fit: cover; border: 3px solid var(--border-avatar); flex-shrink: 0;" />
      <div>
        <h1 style="font-size: 1.75rem; font-weight: 700; margin: 0 0 0.25rem;">Ken Imoto</h1>
        <p style="font-size: 1rem; color: var(--text-label); margin: 0;">Ingeniero de WebRTC y Voice AI</p>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0.25rem 0 0;">Fundador, <a href="https://propel-lab.co.jp">Propel-Lab</a></p>
      </div>
    </section>

    <section style="margin-bottom: 2rem;">
      <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.75rem;">Biografía</h2>
      <div class="bio-block">
        <p style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.75; margin: 0 0 1rem;">
          Ken Imoto es ingeniero de WebRTC y Voice AI, fundador de Propel-Lab. Construye organizaciones AI-native usando LLMs, automatización y agentes distribuidos.
        </p>
        <p style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.75; margin: 0 0 1rem;">
          Es el creador del LLMO (Large Language Model Optimization) Framework, una metodología para optimizar la visibilidad del contenido en buscadores impulsados por IA como ChatGPT y Perplexity. El framework está documentado en el libro <em>Why ChatGPT Ignores Your Website: The LLMO Practical Guide</em> y en el sitio complementario <a href="https://llmoframework.com">llmoframework.com</a>.
        </p>
        <p style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.75; margin: 0 0 1rem;">
          Ha publicado 11 libros sobre desarrollo con IA, ingeniería de contexto, seguridad de MCP y optimización para búsqueda con IA. Títulos destacados: <em>Practical Claude Code</em>, <em>Harness Engineering</em> y <em>MCP Security in Practice</em>.
        </p>
        <p style="font-size: 0.95rem; color: var(--text-secondary); line-height: 1.75; margin: 0;">
          Investigación actual: optimización de latencia en Voice AI (la barrera de los 300ms), ingeniería de contexto para sistemas multi-agente y simulación de agentes generativos. Tres artículos publicados en Zenodo sobre análisis cuantitativo de texto generado por IA, sesgo de color en modelos de visión-lenguaje, y patrones estilísticos en escritura técnica japonesa.
        </p>
      </div>
    </section>

    <section style="margin-bottom: 2rem;">
      <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.75rem;">
        Ediciones en español ({esBooks.length})
      </h2>
      {esBooks.length === 0 ? (
        <div class="bio-block">
          <p style="font-size: 0.9rem; color: var(--text-muted); margin: 0;">
            No hay ediciones en español disponibles aún. Próximamente. Mientras tanto, consulta la colección completa en <a href="/">inglés</a> o <a href="/ja/">japonés</a>.
          </p>
        </div>
      ) : (
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
          {esBooks.map((book) => {
            const slug = book.id.replace(/^es\//, '');
            return (
              <a href={`/es/books/${slug}/`} class="book-row">
                {book.data.cover_image && (
                  <img src={book.data.cover_image} alt={`${book.data.title} portada`} class="book-row-cover" loading="lazy" />
                )}
                <div>
                  <h3>{book.data.title}</h3>
                  {book.data.subtitle && <p>{book.data.subtitle}</p>}
                </div>
              </a>
            );
          })}
        </div>
      )}
      <p style="font-size: 0.85rem; color: var(--text-muted); margin: 1rem 0 0;">
        La colección completa (en inglés y japonés) está en <a href="/">kenimoto.dev</a>.
      </p>
    </section>

    <section>
      <h2 style="font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 0.75rem;">Contacto</h2>
      <ul style="list-style: none; padding: 0; line-height: 2;">
        {links.map(link => (
          <li><a href={link.url}>{link.label}</a></li>
        ))}
        <li>📧 <a href="mailto:imoto@propel-lab.co.jp">imoto@propel-lab.co.jp</a></li>
      </ul>
    </section>
  </main>
</BaseLayout>
