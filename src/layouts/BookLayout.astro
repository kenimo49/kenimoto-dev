---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import { getCollection } from 'astro:content';
import type { Alternate } from '../lib/alternates';
import { withAffiliateTag } from '../lib/affiliate';
import { proof } from '../data/proof';

interface Chapter {
  title: string;
  free?: boolean;
  summary?: string;
}

interface Part {
  name: string;
  summary?: string;
  chapters: Chapter[];
}

interface Comparison {
  book: string;
  difference: string;
}

interface Props {
  title: string;
  subtitle?: string;
  tagline?: string;
  heroMessage?: string;
  seriesRole?: string;
  positionStatement: string[];
  description: string;
  lang: 'en' | 'ja' | 'pt' | 'es';
  slug: string;
  publishedDate: Date;
  updatedDate?: Date;
  kindleUrl?: string;
  zennUrl?: string;
  otherUrls?: { label: string; url: string }[];
  price?: number;
  currency?: string;
  coverImage?: string;
  ogImage?: string;
  topics: string[];
  outcomes: string[];
  targetReaders: string[];
  differentiation: string[];
  chapters: Chapter[];
  parts?: Part[];
  competitorComparison: Comparison[];
  painPoints: string[];
  relatedBooks: string[];
  relatedArticles: { slug: string; title: string }[];
  keywords: string[];
  ctaLabel?: string;
  affiliateDisclosure?: boolean;
  canonicalUrl: string;
  alternates?: Alternate[];
}

const {
  title,
  subtitle,
  tagline,
  heroMessage,
  seriesRole,
  positionStatement,
  description,
  lang,
  slug,
  publishedDate,
  updatedDate,
  kindleUrl,
  zennUrl,
  otherUrls = [],
  price,
  currency = 'JPY',
  coverImage,
  ogImage,
  topics,
  outcomes,
  targetReaders,
  differentiation,
  chapters,
  parts,
  competitorComparison,
  painPoints,
  relatedBooks,
  relatedArticles,
  keywords,
  ctaLabel,
  affiliateDisclosure = false,
  canonicalUrl,
  alternates = [],
} = Astro.props;

const siteName = lang === 'ja' ? '井本 賢' : 'Ken Imoto';
const langPrefix = lang === 'en' ? '' : `/${lang}`;
const homeUrl = `${langPrefix}/` || '/';
const aboutUrl = `${langPrefix}/about/`;

// codex 指摘: kindle_url がある書籍は disclosure を自動表示 (frontmatter false でも上書き)
const showAffiliateDisclosure = !!kindleUrl || affiliateDisclosure;

const translations = {
  ja: {
    back: '← トップに戻る',
    overview: '本書の概要',
    outcomes: 'この本でできるようになること',
    position: 'この本の立ち位置',
    targetReaders: '対象読者',
    toc: '目次',
    freeChapter: '無料公開',
    whyThisBook: 'なぜこの本か',
    diffFromOthers: '他のAI本との違い',
    painPointsHeading: 'この本で解決できる悩み',
    relatedBooks: 'シリーズ・関連書籍',
    relatedArticles: '関連記事で深掘りする',
    cta: 'Kindleで購入する',
    ctaSub: 'Kindle Unlimitedで読み放題対象',
    primaryCta: '今すぐKindleで読む →',
    ctaZenn: 'Zennで読む',
    ctaZennSub: 'Zennで全文を読む',
    primaryCtaZenn: '今すぐZennで読む →',
    affiliateNote: '※ 本ページにはAmazonアソシエイトリンクが含まれます。クリック先での購入により著者に紹介料が入る場合があります。',
    publishedAt: '公開',
    updatedAt: '更新',
    readSampleZenn: 'Zennで試し読み',
    topicsLabel: 'トピック',
    compareCol1: '比較対象',
    compareCol2: '本書の違い',
    coverAlt: '表紙',
    otherLanguages: '他の言語版',
  },
  en: {
    back: '← Back to home',
    overview: 'Overview',
    outcomes: 'What you will be able to do',
    position: 'Where this book stands',
    targetReaders: 'Who is this book for',
    toc: 'Table of contents',
    freeChapter: 'Free preview',
    whyThisBook: 'Why this book',
    diffFromOthers: 'How this differs from other AI books',
    painPointsHeading: 'Problems this book solves',
    relatedBooks: 'Related books',
    relatedArticles: 'Dive deeper with related articles',
    cta: 'Buy on Kindle',
    ctaSub: 'Available on Kindle Unlimited',
    primaryCta: 'Read now on Kindle →',
    ctaZenn: 'Read on Zenn',
    ctaZennSub: 'Full text on Zenn',
    primaryCtaZenn: 'Read now on Zenn →',
    affiliateNote: '* This page contains Amazon Associates links. Purchases may earn the author a referral fee.',
    publishedAt: 'Published',
    updatedAt: 'Updated',
    readSampleZenn: 'Read sample on Zenn',
    topicsLabel: 'Topics',
    compareCol1: 'Compared to',
    compareCol2: "This book's difference",
    coverAlt: 'cover',
    otherLanguages: 'Other editions',
  },
  pt: {
    back: '← Voltar ao início',
    overview: 'Visão geral',
    outcomes: 'O que você será capaz de fazer',
    position: 'Onde este livro se posiciona',
    targetReaders: 'Para quem é este livro',
    toc: 'Sumário',
    freeChapter: 'Amostra grátis',
    whyThisBook: 'Por que este livro',
    diffFromOthers: 'Como este livro difere de outros sobre IA',
    painPointsHeading: 'Problemas que este livro resolve',
    relatedBooks: 'Livros relacionados',
    relatedArticles: 'Aprofunde com artigos relacionados',
    cta: 'Comprar no Kindle',
    ctaSub: 'Disponível no Kindle Unlimited',
    primaryCta: 'Ler agora no Kindle →',
    ctaZenn: 'Ler no Zenn',
    ctaZennSub: 'Texto completo no Zenn',
    primaryCtaZenn: 'Ler agora no Zenn →',
    affiliateNote: '* Esta página contém links da Amazon Associados. Compras podem gerar uma comissão para o autor.',
    publishedAt: 'Publicado em',
    updatedAt: 'Atualizado em',
    readSampleZenn: 'Ler amostra no Zenn',
    topicsLabel: 'Tópicos',
    compareCol1: 'Comparado com',
    compareCol2: 'Diferença deste livro',
    coverAlt: 'capa',
    otherLanguages: 'Outras edições',
  },
  es: {
    back: '← Volver al inicio',
    overview: 'Resumen',
    outcomes: 'Lo que podrás hacer',
    position: 'Dónde se sitúa este libro',
    targetReaders: 'Para quién es este libro',
    toc: 'Índice',
    freeChapter: 'Vista previa',
    whyThisBook: 'Por qué este libro',
    diffFromOthers: 'En qué se diferencia de otros libros sobre IA',
    painPointsHeading: 'Problemas que resuelve este libro',
    relatedBooks: 'Libros relacionados',
    relatedArticles: 'Profundiza con artículos relacionados',
    cta: 'Comprar en Kindle',
    ctaSub: 'Disponible en Kindle Unlimited',
    primaryCta: 'Leer ahora en Kindle →',
    ctaZenn: 'Leer en Zenn',
    ctaZennSub: 'Texto completo en Zenn',
    primaryCtaZenn: 'Leer ahora en Zenn →',
    affiliateNote: '* Esta página contiene enlaces de Amazon Afiliados. Las compras pueden generar una comisión para el autor.',
    publishedAt: 'Publicado',
    updatedAt: 'Actualizado',
    readSampleZenn: 'Leer muestra en Zenn',
    topicsLabel: 'Temas',
    compareCol1: 'Comparado con',
    compareCol2: 'Diferencia de este libro',
  coverAlt: 'portada',
    otherLanguages: 'Otras ediciones',
  },
};
const t = translations[lang];

// 他言語版ピル: alternates のうち x-default と現言語以外を表示
const langLabels: Record<string, string> = {
  en: 'English',
  ja: '日本語',
  pt: 'Português',
  es: 'Español',
};
const otherLangAlternates = alternates.filter(
  (a) => a.hreflang !== 'x-default' && a.hreflang !== lang
);

// CTA先決定: kindleUrl 優先、無ければ zennUrl
// Amazon URL は PUBLIC_AMAZON_TAG が設定されていれば ?tag= を自動注入
const amazonTag = import.meta.env.PUBLIC_AMAZON_TAG ?? '';
const taggedKindleUrl = withAffiliateTag(kindleUrl, amazonTag);
const isZennOnly = !kindleUrl && !!zennUrl;
const destinationUrl = taggedKindleUrl || zennUrl;
const heroPrimaryLabel = isZennOnly ? t.primaryCtaZenn : t.primaryCta;
const footerCtaLabel = isZennOnly ? t.ctaZenn : t.cta;
const footerCtaSubLabel = isZennOnly ? t.ctaZennSub : t.ctaSub;

// 関連書籍のメタ情報を取得 (表紙・タイトル・series_role 表示用)
const allBooks = await getCollection('books');
const relatedBookEntries = relatedBooks
  .map((rbSlug) => {
    const sameLang = allBooks.find((b) => {
      const entrySlug = b.id.replace(/^(ja|en|pt|es)\//, '');
      return entrySlug === rbSlug && b.data.lang === lang;
    });
    if (sameLang) return { slug: rbSlug, data: sameLang.data, lang };
    const enFallback = allBooks.find((b) => {
      const entrySlug = b.id.replace(/^(ja|en|pt|es)\//, '');
      return entrySlug === rbSlug && b.data.lang === 'en';
    });
    if (enFallback) return { slug: rbSlug, data: enFallback.data, lang: 'en' as const };
    return null;
  })
  .filter((x): x is { slug: string; data: typeof allBooks[number]['data']; lang: typeof lang | 'en' } => x !== null);
const formattedPrice = price !== undefined
  ? (currency === 'JPY' ? `¥${price.toLocaleString()}` : `${currency} ${price}`)
  : null;

// 案B: parts が定義されていればそれを使い、無ければ chapters を 1part として扱う(後方互換)
const effectiveParts: Part[] = parts && parts.length > 0
  ? parts
  : (chapters.length > 0 ? [{ name: '', chapters }] : []);

// partsを使うとき、章番号は通しで振り直す
const partChapterStartIndex: number[] = [];
{
  let acc = 0;
  for (const p of effectiveParts) {
    partChapterStartIndex.push(acc);
    acc += p.chapters.length;
  }
}

// hero CTA に試し読みを並べる(Kindle商品ページ "サンプルを読む" 機能への踏み台)
const sampleUrl = taggedKindleUrl;

// 社会的証明: proof.ts の指標を現言語に解決
const proofMetrics = proof.metrics.map((m) => ({
  id: m.id,
  icon: m.icon,
  value: m.value,
  label: m.labels[lang],
}));
const proofAuthorBio = proof.authorBio[lang];
const proofSectionHeading = proof.sectionHeading[lang];
const proofSampleLabel = proof.sampleLabel[lang];
const proofKuBadge = proof.kuBadge[lang];
const proofGuarantee = proof.guarantee[lang];
const proofPartCta = proof.partCta[lang];

const SITE_URL = 'https://kenimoto.dev';
const homeAbsUrl = `${SITE_URL}${homeUrl}`;
const booksIndexUrl = `${SITE_URL}${langPrefix}/books/`;

const inLanguageTag = lang === 'ja' ? 'ja-JP' : (lang === 'pt' ? 'pt-BR' : (lang === 'es' ? 'es-ES' : 'en-US'));
const sameAsList = [kindleUrl, zennUrl].filter(Boolean);

// Book + Product 双型 (codex 指摘: LP として販売文脈を強化)
const bookSchema = {
  '@context': 'https://schema.org',
  '@type': ['Book', 'Product'],
  '@id': `${canonicalUrl}#book`,
  name: title + (subtitle ? ` — ${subtitle}` : ''),
  description,
  inLanguage: inLanguageTag,
  bookFormat: 'EBook',
  author: {
    '@type': 'Person',
    '@id': `${SITE_URL}/#person`,
    name: siteName,
    url: `${SITE_URL}/`,
  },
  publisher: { '@id': `${SITE_URL}/#organization` },
  url: canonicalUrl,
  ...(coverImage ? { image: coverImage } : {}),
  ...(sameAsList.length > 0 ? { sameAs: sameAsList } : {}),
  isPartOf: { '@id': `${SITE_URL}/#website` },
  ...(price ? {
    offers: {
      '@type': 'Offer',
      price: String(price),
      priceCurrency: currency,
      url: kindleUrl || zennUrl,
      availability: 'https://schema.org/InStock',
      seller: { '@id': `${SITE_URL}/#organization` },
    },
  } : {}),
  about: topics,
  datePublished: publishedDate.toISOString().split('T')[0],
  ...(updatedDate ? { dateModified: updatedDate.toISOString().split('T')[0] } : {}),
  ...(keywords.length > 0 ? { keywords: keywords.join(', ') } : {}),
  ...(seriesRole ? { genre: seriesRole } : {}),
};

const T_NAV = {
  en: { home: 'Home', books: 'Books' },
  ja: { home: 'ホーム', books: '書籍' },
  pt: { home: 'Início', books: 'Livros' },
  es: { home: 'Inicio', books: 'Libros' },
}[lang];

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: T_NAV.home, item: homeAbsUrl },
    { '@type': 'ListItem', position: 2, name: T_NAV.books, item: booksIndexUrl },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
  ],
};

const bookJsonLd = [bookSchema, breadcrumbJsonLd];
---

<BaseLayout
  title={`${title} — ${siteName}`}
  description={description}
  lang={lang}
  ogUrl={canonicalUrl}
  ogDescription={description}
  ogImage={ogImage || coverImage}
  ogType="book"
  alternates={alternates}
  jsonLd={bookJsonLd}
>
  <Fragment slot="head">
    {topics.map(t => <meta property="book:tag" content={t} />)}
    <style>
      .book-lp {
        max-width: 760px;
        margin: 0 auto;
        padding: 2.5rem 2rem 4rem;
      }
      .book-lp h1 {
        font-size: 2rem;
        font-weight: 700;
        margin: 0.5rem 0 0.5rem;
        line-height: 1.3;
        color: var(--text-primary);
      }
      .book-lp .subtitle {
        font-size: 1.1rem;
        color: var(--text-secondary);
        margin: 0 0 0.5rem;
      }
      .book-lp .tagline {
        font-size: 0.95rem;
        color: var(--text-label);
        margin: 0 0 1.5rem;
        font-weight: 500;
        letter-spacing: 0.01em;
      }
      .hero-message {
        background: var(--bg-card);
        border-left: 3px solid var(--accent-blue);
        padding: 1rem 1.25rem;
        margin: 0 0 1rem;
        border-radius: 4px;
      }
      .hero-message p {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-primary);
        line-height: 1.55;
      }
      .series-role-badge {
        display: inline-block;
        background: var(--bg-card);
        color: var(--text-label);
        border: 1px solid var(--text-separator);
        padding: 0.45rem 0.9rem;
        border-radius: 6px;
        font-size: 0.85rem;
        margin: 0 0 1.5rem;
        line-height: 1.5;
      }
      .series-role-badge::before {
        content: "▸ ";
        color: var(--accent-blue);
        margin-right: 0.15rem;
      }
      .hero-cta-row {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin: 0 0 2rem;
      }
      .hero-cta-primary {
        background: var(--accent-amber);
        color: white;
        padding: 0.85rem 1.75rem;
        border-radius: 6px;
        font-weight: 700;
        font-size: 1rem;
        text-decoration: none;
        transition: opacity 0.15s;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
      }
      .hero-cta-primary:hover {
        opacity: 0.9;
        text-decoration: none;
      }
      .hero-cta-secondary {
        background: transparent;
        color: var(--text-secondary);
        padding: 0.85rem 1.5rem;
        border: 1px solid var(--text-separator);
        border-radius: 6px;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.15s;
      }
      .hero-cta-secondary:hover {
        border-color: var(--text-label);
        color: var(--text-primary);
        text-decoration: none;
      }
      .position-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0.75rem;
      }
      .position-list li {
        background: var(--bg-card);
        padding: 0.85rem 1.1rem;
        border-radius: 6px;
        color: var(--text-primary);
        font-weight: 500;
        line-height: 1.6;
        border-top: 3px solid var(--accent-blue);
      }
      .outcomes-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .outcomes-list li {
        position: relative;
        padding: 0.6rem 0 0.6rem 2rem;
        line-height: 1.7;
        color: var(--text-secondary);
        border-bottom: 1px solid var(--text-separator);
      }
      .outcomes-list li:last-child {
        border-bottom: none;
      }
      .outcomes-list li::before {
        content: "✓";
        position: absolute;
        left: 0.4rem;
        top: 0.65rem;
        color: var(--accent-green);
        font-weight: 700;
        font-size: 1rem;
      }
      .book-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1rem;
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
      }
      .book-meta .price {
        background: var(--accent-amber);
        color: white;
        padding: 0.15rem 0.6rem;
        border-radius: 4px;
        font-weight: 600;
      }
      .book-meta .ku-badge {
        background: var(--bg-elev);
        color: var(--text-primary);
        border: 1px solid var(--text-separator);
        padding: 0.15rem 0.6rem;
        border-radius: 4px;
        font-weight: 500;
        font-size: 0.8rem;
      }

      /* Hero下: 著者bio 1行 + 7日返品 */
      .author-bio-line {
        font-size: 0.85rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0 0 1.5rem;
        padding: 0.6rem 0.8rem;
        background: var(--bg-elev);
        border-left: 3px solid var(--accent-amber);
        border-radius: 2px;
      }
      .author-bio-line .guarantee-text {
        color: var(--text-muted);
        font-size: 0.8rem;
      }

      /* 案C: Social Proof Block (Hero直下) */
      .social-proof {
        margin: 0 0 2.5rem;
        padding: 1.25rem 1rem;
        background: var(--bg-elev);
        border-radius: 6px;
        border: 1px solid var(--text-separator);
      }
      .social-proof-heading {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        margin: 0 0 0.85rem;
        text-align: center;
      }
      .social-proof-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.75rem;
      }
      .social-proof-card {
        text-align: center;
        padding: 0.5rem 0.25rem;
      }
      .social-proof-icon {
        font-size: 1.4rem;
        line-height: 1;
        display: block;
        margin-bottom: 0.25rem;
      }
      .social-proof-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
        line-height: 1.1;
      }
      .social-proof-label {
        font-size: 0.72rem;
        color: var(--text-muted);
        line-height: 1.35;
        margin-top: 0.25rem;
      }
      @media (max-width: 640px) {
        .social-proof-grid {
          grid-template-columns: repeat(2, 1fr);
          gap: 0.5rem;
        }
        .social-proof-value {
          font-size: 1.25rem;
        }
        .social-proof-label {
          font-size: 0.68rem;
        }
      }

      /* 案B: TOC 3パート構造 + mini-CTA */
      .toc-part {
        margin: 0 0 2rem;
      }
      .toc-part-name {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 0.4rem;
        padding-bottom: 0.3rem;
        border-bottom: 1px dashed var(--text-separator);
      }
      .toc-part-summary {
        font-size: 0.85rem;
        color: var(--text-muted);
        margin: 0 0 0.75rem !important;
        line-height: 1.6;
      }
      .toc-part-cta {
        display: inline-block;
        margin-top: 0.75rem;
        padding: 0.55rem 1rem;
        background: var(--bg-elev);
        color: var(--accent-amber);
        border: 1px solid var(--accent-amber);
        border-radius: 4px;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.15s;
      }
      .toc-part-cta:hover {
        background: var(--accent-amber);
        color: white;
      }
      .book-cover {
        max-width: 240px;
        height: auto;
        border-radius: 4px;
        margin: 0 auto 1.5rem;
        display: block;
      }
      .book-section {
        margin: 2.5rem 0;
      }
      .book-section h2 {
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--text-separator);
      }
      .book-section p {
        line-height: 1.85;
        color: var(--text-secondary);
        margin: 0 0 1rem;
      }
      .book-section ul {
        padding-left: 1.5rem;
        line-height: 1.85;
        color: var(--text-secondary);
      }
      .book-section li {
        margin: 0.4rem 0;
      }
      .toc-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .toc-list li {
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--text-separator);
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
      }
      .toc-list li:last-child {
        border-bottom: none;
      }
      .toc-num {
        color: var(--text-muted);
        font-size: 0.85rem;
        font-variant-numeric: tabular-nums;
        min-width: 2.5rem;
      }
      .toc-title {
        flex: 1;
        color: var(--text-primary);
      }
      .toc-free {
        background: var(--accent-green);
        color: white;
        font-size: 0.7rem;
        padding: 0.1rem 0.5rem;
        border-radius: 3px;
        font-weight: 600;
      }
      .pain-points {
        background: var(--bg-card);
        border-left: 3px solid var(--accent-amber);
        padding: 1rem 1.25rem;
        border-radius: 4px;
      }
      .pain-points li {
        margin: 0.4rem 0;
      }
      .compare-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95rem;
      }
      .compare-table th, .compare-table td {
        text-align: left;
        padding: 0.65rem 1rem;
        border: 1px solid var(--text-separator);
        vertical-align: top;
      }
      .compare-table th {
        background: var(--bg-card);
        font-weight: 600;
        color: var(--text-primary);
      }
      .compare-table td {
        color: var(--text-secondary);
      }
      .related-cards {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
        list-style: none;
        padding: 0;
        margin: 0;
      }
      @media (min-width: 640px) {
        .related-cards {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      .related-cards li {
        margin: 0;
      }
      .related-card {
        display: flex;
        gap: 1rem;
        background: var(--bg-card);
        padding: 1rem;
        border-radius: 8px;
        text-decoration: none;
        color: var(--text-secondary);
        transition: outline 0.15s, transform 0.15s;
        align-items: flex-start;
        height: 100%;
      }
      .related-card:hover {
        outline: 1px solid var(--accent-blue);
        text-decoration: none;
      }
      .related-card-cover {
        width: 70px;
        height: auto;
        aspect-ratio: 5 / 7;
        object-fit: cover;
        border-radius: 4px;
        flex-shrink: 0;
        background: var(--bg-primary);
      }
      .related-card-body {
        flex: 1;
        min-width: 0;
      }
      .related-card-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 0.2rem;
        line-height: 1.35;
      }
      .related-card-subtitle {
        font-size: 0.8rem;
        color: var(--text-label);
        margin: 0 0 0.5rem;
        line-height: 1.4;
      }
      .related-card-role {
        font-size: 0.75rem;
        color: var(--text-label);
        margin: 0;
        line-height: 1.4;
      }
      .related-card-fallback {
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-primary);
        color: var(--text-muted);
        font-size: 0.7rem;
      }
      .related-articles {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .related-articles li {
        padding: 0.65rem 0;
        border-bottom: 1px solid var(--text-separator);
      }
      .related-articles li:last-child {
        border-bottom: none;
      }
      .related-articles a {
        color: var(--link-color);
        font-size: 0.95rem;
      }
      .related-articles a::before {
        content: "› ";
        color: var(--text-muted);
        margin-right: 0.3rem;
      }
      .cta-section {
        margin: 3rem 0 1.5rem;
        padding: 2rem;
        background: var(--bg-card);
        border-radius: 8px;
        text-align: center;
      }
      .cta-section h2 {
        margin: 0 0 0.5rem;
        font-size: 1.3rem;
        color: var(--text-primary);
      }
      .cta-section .cta-sub {
        font-size: 0.85rem;
        color: var(--text-muted);
        margin: 0 0 1.25rem;
      }
      .cta-button {
        display: inline-block;
        background: var(--accent-amber);
        color: white;
        padding: 0.85rem 2rem;
        border-radius: 6px;
        font-weight: 700;
        font-size: 1.05rem;
        text-decoration: none;
        transition: opacity 0.15s;
      }
      .cta-button:hover {
        opacity: 0.9;
        text-decoration: none;
      }
      .secondary-links {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin-top: 1rem;
        font-size: 0.9rem;
      }
      .other-langs {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
        margin: 0 0 1.5rem;
        font-size: 0.85rem;
      }
      .other-langs-label {
        color: var(--text-muted);
      }
      .other-lang-pill {
        padding: 0.2rem 0.7rem;
        border: 1px solid var(--text-separator);
        border-radius: 4px;
        color: var(--text-secondary);
        text-decoration: none;
        transition: border-color 0.15s, color 0.15s;
      }
      .other-lang-pill:hover {
        border-color: var(--accent-blue);
        color: var(--text-primary);
        text-decoration: none;
      }
      .topics-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 1rem;
      }
      .topic-tag {
        background: var(--bg-card);
        color: var(--text-secondary);
        padding: 0.2rem 0.7rem;
        border-radius: 4px;
        font-size: 0.8rem;
      }
      .affiliate-note {
        margin-top: 3rem;
        padding-top: 1rem;
        border-top: 1px solid var(--text-separator);
        color: var(--text-muted);
        font-size: 0.8rem;
        line-height: 1.6;
      }
      @media (max-width: 640px) {
        .book-lp {
          padding: 1.5rem 1rem 3rem;
        }
        .compare-table {
          display: block;
          overflow-x: auto;
        }
      }
    </style>
  </Fragment>

  <Nav lang={lang} current="" alternates={alternates} />

  <main class="book-lp">
    <a href={homeUrl} style="font-size: 0.85rem; color: var(--text-muted); text-decoration: none;">{t.back}</a>

    {coverImage && (
      <img src={coverImage} alt={`${title} ${t.coverAlt}`} class="book-cover" loading="eager" />
    )}

    <h1>{title}</h1>
    {subtitle && <p class="subtitle">{subtitle}</p>}
    {tagline && <p class="tagline">{tagline}</p>}

    {heroMessage && (
      <div class="hero-message">
        <p>{heroMessage}</p>
      </div>
    )}

    {seriesRole && (
      <div class="series-role-badge">{seriesRole}</div>
    )}

    {/* 案A: Hero CTAブロック — 価格・KUバッジ・著者bio・サンプル踏み台を CTA に並べる */}
    {destinationUrl && (
      <div class="hero-cta-row">
        <a
          href={destinationUrl}
          class="hero-cta-primary"
          data-cta-amazon
          data-slug={slug}
          data-position="hero"
          target="_blank"
          rel="noopener noreferrer"
        >
          {heroPrimaryLabel}
        </a>
        {!isZennOnly && sampleUrl && (
          <a
            href={sampleUrl}
            class="hero-cta-secondary"
            target="_blank"
            rel="noopener noreferrer"
            data-cta-sample
            data-slug={slug}
          >
            {proofSampleLabel}
          </a>
        )}
        {!isZennOnly && lang === 'ja' && zennUrl && <a href={zennUrl} class="hero-cta-secondary" rel="noopener">{t.readSampleZenn}</a>}
      </div>
    )}

    <div class="book-meta">
      {formattedPrice && <span class="price">{formattedPrice}</span>}
      {!isZennOnly && kindleUrl && <span class="ku-badge">{proofKuBadge}</span>}
      <span>{t.publishedAt}: <time datetime={publishedDate.toISOString()}>{publishedDate.toISOString().split('T')[0]}</time></span>
      {updatedDate && (
        <span>{t.updatedAt}: <time datetime={updatedDate.toISOString()}>{updatedDate.toISOString().split('T')[0]}</time></span>
      )}
    </div>

    {/* 著者bio 1行 + 7日返品 — heroの信用構築 */}
    <p class="author-bio-line">
      <span class="author-bio-text">{proofAuthorBio}</span>
      {!isZennOnly && kindleUrl && <span class="guarantee-text"> · {proofGuarantee}</span>}
    </p>

    {/* 案C: Social Proof Block — hero直下に4枚カードで指標を並列 */}
    <section class="social-proof" aria-label={proofSectionHeading}>
      <p class="social-proof-heading">{proofSectionHeading}</p>
      <div class="social-proof-grid">
        {proofMetrics.map((m) => (
          <div class="social-proof-card">
            <span class="social-proof-icon" aria-hidden="true">{m.icon}</span>
            <div class="social-proof-value">{m.value}</div>
            <div class="social-proof-label">{m.label}</div>
          </div>
        ))}
      </div>
    </section>

    {otherLangAlternates.length > 0 && (
      <div class="other-langs">
        <span class="other-langs-label">{t.otherLanguages}:</span>
        {otherLangAlternates.map((a) => (
          <a href={a.href} hreflang={a.hreflang} class="other-lang-pill">
            {langLabels[a.hreflang] || a.hreflang.toUpperCase()}
          </a>
        ))}
      </div>
    )}

    <section class="book-section">
      <h2>{t.overview}</h2>
      <p>{description}</p>
      <slot name="overview" />
    </section>

    {outcomes.length > 0 && (
      <section class="book-section">
        <h2>{t.outcomes}</h2>
        <ul class="outcomes-list">
          {outcomes.map((o) => <li>{o}</li>)}
        </ul>
      </section>
    )}

    {targetReaders.length > 0 && (
      <section class="book-section">
        <h2>{t.targetReaders}</h2>
        <ul>
          {targetReaders.map((r) => <li>{r}</li>)}
        </ul>
      </section>
    )}

    {painPoints.length > 0 && (
      <section class="book-section">
        <h2>{t.painPointsHeading}</h2>
        <ul class="pain-points">
          {painPoints.map((p) => <li>{p}</li>)}
        </ul>
      </section>
    )}

    {positionStatement.length > 0 && (
      <section class="book-section">
        <h2>{t.position}</h2>
        <ul class="position-list">
          {positionStatement.map((p) => <li>{p}</li>)}
        </ul>
      </section>
    )}

    {differentiation.length > 0 && (
      <section class="book-section">
        <h2>{t.whyThisBook}</h2>
        <ul>
          {differentiation.map((d) => <li>{d}</li>)}
        </ul>
      </section>
    )}

    {competitorComparison.length > 0 && (
      <section class="book-section">
        <h2>{t.diffFromOthers}</h2>
        <table class="compare-table">
          <thead>
            <tr>
              <th>{t.compareCol1}</th>
              <th>{t.compareCol2}</th>
            </tr>
          </thead>
          <tbody>
            {competitorComparison.map((c) => (
              <tr>
                <td>{c.book}</td>
                <td>{c.difference}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

    {effectiveParts.length > 0 && (
      <section class="book-section">
        <h2>{t.toc}</h2>
        {effectiveParts.map((p, pi) => (
          <div class="toc-part">
            {p.name && <h3 class="toc-part-name">{p.name}</h3>}
            {p.summary && <p class="toc-part-summary">{p.summary}</p>}
            <ol class="toc-list" start={partChapterStartIndex[pi] + 1}>
              {p.chapters.map((c, i) => (
                <li>
                  <span class="toc-num">{String(partChapterStartIndex[pi] + i + 1).padStart(2, '0')}</span>
                  <span class="toc-title">{c.title}</span>
                  {c.free && <span class="toc-free">{t.freeChapter}</span>}
                </li>
              ))}
            </ol>
            {/* mini-CTA: parts が複数あるときだけ、各partの後ろに差し込む */}
            {parts && parts.length > 1 && destinationUrl && (
              <a
                href={destinationUrl}
                class="toc-part-cta"
                data-cta-amazon
                data-slug={slug}
                data-position={`toc-part-${pi + 1}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                {proofPartCta}
              </a>
            )}
          </div>
        ))}
      </section>
    )}

    <section class="book-section">
      <slot />
    </section>

    {relatedBookEntries.length > 0 && (
      <section class="book-section">
        <h2>{t.relatedBooks}</h2>
        <ul class="related-cards">
          {relatedBookEntries.map((rb) => {
            const rbPrefix = rb.lang === 'en' ? '' : `/${rb.lang}`;
            const href = `${rbPrefix}/books/${rb.slug}/`;
            const titleFull = rb.data.subtitle ? `${rb.data.title} — ${rb.data.subtitle}` : rb.data.title;
            return (
              <li>
                <a href={href} class="related-card" aria-label={titleFull}>
                  {rb.data.cover_image ? (
                    <img src={rb.data.cover_image} alt={`${rb.data.title} ${t.coverAlt}`} class="related-card-cover" loading="lazy" />
                  ) : (
                    <div class="related-card-cover related-card-fallback">No cover</div>
                  )}
                  <div class="related-card-body">
                    <p class="related-card-title">{rb.data.title}</p>
                    {rb.data.subtitle && <p class="related-card-subtitle">{rb.data.subtitle}</p>}
                    {rb.data.series_role && <p class="related-card-role">{rb.data.series_role}</p>}
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    )}

    {relatedArticles.length > 0 && (
      <section class="book-section">
        <h2>{t.relatedArticles}</h2>
        <ul class="related-articles">
          {relatedArticles.map((a) => (
            <li>
              <a href={`${langPrefix}/blog/${a.slug}/`}>{a.title}</a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="cta-section">
      <h2>{ctaLabel || footerCtaLabel}</h2>
      <p class="cta-sub">{footerCtaSubLabel}</p>
      {destinationUrl && (
        <a
          href={destinationUrl}
          class="cta-button"
          data-cta-amazon
          data-slug={slug}
          data-position="footer"
          target="_blank"
          rel="noopener noreferrer"
        >
          {footerCtaLabel}
          {formattedPrice && ` (${formattedPrice})`}
        </a>
      )}
      <div class="secondary-links">
        {!isZennOnly && lang === 'ja' && zennUrl && <a href={zennUrl} rel="noopener">{t.readSampleZenn}</a>}
        {otherUrls.map((u) => <a href={u.url} rel="noopener">{u.label}</a>)}
      </div>
    </section>

    {topics.length > 0 && (
      <div class="topics-row">
        <span style="font-size: 0.8rem; color: var(--text-muted);">{t.topicsLabel}:</span>
        {topics.map((tp) => <span class="topic-tag">{tp}</span>)}
      </div>
    )}

    {showAffiliateDisclosure && <p class="affiliate-note">{t.affiliateNote}</p>}
  </main>

  <script is:inline>
    // GA4 cta_click イベント発火 (ヒーローCTA・フッターCTA共通)
    document.querySelectorAll('[data-cta-amazon]').forEach(function(link) {
      link.addEventListener('click', function() {
        if (typeof gtag === 'function') {
          gtag('event', 'cta_click', {
            event_category: 'book_lp',
            event_label: link.getAttribute('data-slug') || '',
            cta_position: link.getAttribute('data-position') || 'unknown',
            destination: link.href,
            transport_type: 'beacon',
          });
        }
      });
    });
  </script>
</BaseLayout>
