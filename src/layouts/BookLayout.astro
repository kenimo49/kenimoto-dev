        font-size: 0.8rem;
        line-height: 1.6;
      }
      @media (max-width: 640px) {
        .book-lp {
          padding: 1.5rem 1rem 3rem;
        }
        .compare-table {
          display: block;
          overflow-x: auto;
        }
      }
    </style>
  </Fragment>

  <Nav lang={lang} current="books" alternates={alternates} />

  <main class="book-lp">
    <a href={homeUrl} style="font-size: 0.85rem; color: var(--text-muted); text-decoration: none;">{t.back}</a>

    {coverImage && (
      <img src={coverImage} alt={`${title} ${t.coverAlt}`} class="book-cover" loading="eager" fetchpriority="high" decoding="async" />
    )}

    <h1>{title}</h1>
    {subtitle && <p class="subtitle">{subtitle}</p>}
    {tagline && <p class="tagline">{tagline}</p>}

    {heroMessage && (
      <div class="hero-message">
        <p>{heroMessage}</p>
      </div>
    )}

    {seriesRole && (
      <div class="series-role-badge">{seriesRole}</div>
    )}

    {/* 案A: Hero CTAブロック — 価格・KUバッジ・著者bio・サンプル踏み台を CTA に並べる */}
    {destinationUrl && (
      <div class="hero-cta-row">
        <a
          href={destinationUrl}
          class="hero-cta-primary"
          data-cta-amazon
          data-slug={slug}
          data-position="hero"
          target="_blank"
          rel="noopener noreferrer"
        >
          {heroPrimaryLabel}
        </a>
        {!isZennOnly && sampleUrl && (
          <a
            href={sampleUrl}
            class="hero-cta-secondary"
            target="_blank"
            rel="noopener noreferrer"
            data-cta-sample
            data-slug={slug}
            data-position="hero-sample"
          >
            {proofSampleLabel}
          </a>
        )}
        {!isZennOnly && lang === 'ja' && zennUrl && (
          <a href={zennUrl} class="hero-cta-secondary" rel="noopener" data-cta-zenn data-slug={slug} data-position="hero-zenn">{t.readSampleZenn}</a>
        )}
      </div>
    )}

    <div class="book-meta">
      {formattedPrice && <span class="price">{formattedPrice}</span>}
      {!isZennOnly && kindleUrl && <span class="ku-badge">{proofKuBadge}</span>}
      <span>{t.publishedAt}: <time datetime={publishedDate.toISOString()}>{publishedDate.toISOString().split('T')[0]}</time></span>
      {updatedDate && (
        <span>{t.updatedAt}: <time datetime={updatedDate.toISOString()}>{updatedDate.toISOString().split('T')[0]}</time></span>
      )}
    </div>

    {/* 著者bio 1行 + 7日返品 — heroの信用構築 */}
    <p class="author-bio-line">
      <span class="author-bio-text">{proofAuthorBio}</span>
      {!isZennOnly && kindleUrl && <span class="guarantee-text"> · {proofGuarantee}</span>}
    </p>

    {/* 案C: Social Proof Block — hero直下に4枚カードで指標を並列 */}
    <section class="social-proof" aria-label={proofSectionHeading}>
      <p class="social-proof-heading">{proofSectionHeading}</p>
      <div class="social-proof-grid">
        {proofMetrics.map((m) => (
          <div class="social-proof-card">
            <span class="social-proof-icon" aria-hidden="true">{m.icon}</span>
            <div class="social-proof-value">{m.value}</div>
            <div class="social-proof-label">{m.label}</div>
          </div>
        ))}
      </div>
    </section>

    {/* Free Preview: 3章をその場で読める (accordion全閉じ初期) */}
    {freePreviewRenders.length > 0 && (
      <section class="free-preview" aria-label={proofFreePreviewHeading}>
        <h2 class="free-preview-heading">📖 {proofFreePreviewHeading}</h2>
        <p class="free-preview-lead">{proofFreePreviewLead}</p>
        {freePreviewRenders.map(({ id, title, Content }, idx) => {
          const chSlug = id.split('/').pop()!.replace(/\.md$/, '');
          return (
            <details class="free-preview-chapter">
              <summary class="free-preview-chapter-summary">
                <span class="free-preview-chapter-num">{String(idx + 1).padStart(2, '0')}</span>
                <span class="free-preview-chapter-title">{title}</span>
                <span class="free-preview-chapter-toggle" aria-hidden="true">+</span>
              </summary>
              <div class="free-preview-chapter-body">
                <Content />
                {destinationUrl && (
                  <a
                    href={destinationUrl}
                    class="free-preview-end-cta"
                    data-cta-amazon
                    data-slug={slug}
                    data-position={`free-preview-${chSlug}`}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {proofFreePreviewChapterCta}
                  </a>
                )}
              </div>
            </details>
          );
        })}
      </section>
    )}

    {otherLangAlternates.length > 0 && (
      <div class="other-langs">
        <span class="other-langs-label">{t.otherLanguages}:</span>
        {otherLangAlternates.map((a) => (
          <a href={a.href} hreflang={a.hreflang} class="other-lang-pill">
            {langLabels[a.hreflang] || a.hreflang.toUpperCase()}
          </a>
        ))}
      </div>
    )}

    <section class="book-section">
      <h2>{t.overview}</h2>
      <p>{description}</p>
      <slot name="overview" />
    </section>

    {outcomes.length > 0 && (
      <section class="book-section">
        <h2>{t.outcomes}</h2>
        <ul class="outcomes-list">
          {outcomes.map((o) => <li>{o}</li>)}
        </ul>
      </section>
    )}

    {targetReaders.length > 0 && (
      <section class="book-section">
        <h2>{t.targetReaders}</h2>
        <ul>
          {targetReaders.map((r) => <li>{r}</li>)}
        </ul>
      </section>
    )}

    {painPoints.length > 0 && (
      <section class="book-section">
        <h2>{t.painPointsHeading}</h2>
        <ul class="pain-points">
          {painPoints.map((p) => <li>{p}</li>)}
        </ul>
      </section>
    )}

    {positionStatement.length > 0 && (
      <section class="book-section">
        <h2>{t.position}</h2>
        <ul class="position-list">
          {positionStatement.map((p) => <li>{p}</li>)}
        </ul>
      </section>
    )}

    {differentiation.length > 0 && (
      <section class="book-section">
        <h2>{t.whyThisBook}</h2>
        <ul>
          {differentiation.map((d) => <li>{d}</li>)}
        </ul>
      </section>
    )}

    {competitorComparison.length > 0 && (
      <section class="book-section">
        <h2>{t.diffFromOthers}</h2>
        <table class="compare-table">
          <thead>
            <tr>
              <th>{t.compareCol1}</th>
              <th>{t.compareCol2}</th>
            </tr>
          </thead>
          <tbody>
            {competitorComparison.map((c) => (
              <tr>
                <td>{c.book}</td>
                <td>{c.difference}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

    {effectiveParts.length > 0 && (
      <section class="book-section">
        <h2>{t.toc}</h2>
        {effectiveParts.map((p, pi) => (
          <div class="toc-part">
            {p.name && <h3 class="toc-part-name">{p.name}</h3>}
            {p.summary && <p class="toc-part-summary">{p.summary}</p>}
            <ol class="toc-list" start={partChapterStartIndex[pi] + 1}>
              {p.chapters.map((c, i) => (
                <li>
                  <span class="toc-num">{String(partChapterStartIndex[pi] + i + 1).padStart(2, '0')}</span>
                  <span class="toc-title">{c.title}</span>
                  {c.free && <span class="toc-free">{t.freeChapter}</span>}
                </li>
              ))}
            </ol>
            {/* mini-CTA: parts が複数あるときだけ、各partの後ろに差し込む */}
            {parts && parts.length > 1 && destinationUrl && (
              <a
                href={destinationUrl}
                class="toc-part-cta"
                data-cta-amazon
                data-slug={slug}
                data-position={`toc-part-${pi + 1}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                {proofPartCta}
              </a>
            )}
          </div>
        ))}
      </section>
    )}

    <section class="book-section">
      <slot />
    </section>

    {relatedBookEntries.length > 0 && (
      <section class="book-section">
        <h2>{t.relatedBooks}</h2>
        <ul class="related-cards">
          {relatedBookEntries.map((rb) => {
            const rbPrefix = rb.lang === 'en' ? '' : `/${rb.lang}`;
            const href = `${rbPrefix}/books/${rb.slug}/`;
            const titleFull = rb.data.subtitle ? `${rb.data.title} — ${rb.data.subtitle}` : rb.data.title;
            return (
              <li>
                <a href={href} class="related-card" aria-label={titleFull}>
                  {rb.data.cover_image ? (
                    <img src={rb.data.cover_image} alt={`${rb.data.title} ${t.coverAlt}`} class="related-card-cover" loading="lazy" />
                  ) : (
                    <div class="related-card-cover related-card-fallback">No cover</div>
                  )}
                  <div class="related-card-body">
                    <p class="related-card-title">{rb.data.title}</p>
                    {rb.data.subtitle && <p class="related-card-subtitle">{rb.data.subtitle}</p>}
                    {rb.data.series_role && <p class="related-card-role">{rb.data.series_role}</p>}
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    )}

    {resolvedRelatedArticles.length > 0 && (
      <section class="book-section">
        <h2>{t.relatedArticles}</h2>
        <ul class="related-articles">
          {resolvedRelatedArticles.map((a) => (
            <li>
              <a href={a.href}>{a.title}</a>
              {a.fallback && <span class="lang-fallback-note"> {enFallbackNote[lang]}</span>}
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="cta-section">
      <h2>{ctaLabel || footerCtaLabel}</h2>
      <p class="cta-sub">{footerCtaSubLabel}</p>
      {destinationUrl && (
        <a
          href={destinationUrl}
          class="cta-button"
          data-cta-amazon
          data-slug={slug}
          data-position="footer"
          target="_blank"
          rel="noopener noreferrer"
        >
          {footerCtaLabel}
          {formattedPrice && ` (${formattedPrice})`}
        </a>
      )}
      <div class="secondary-links">
        {!isZennOnly && lang === 'ja' && zennUrl && (
          <a href={zennUrl} rel="noopener" data-cta-zenn data-slug={slug} data-position="footer-zenn">{t.readSampleZenn}</a>
        )}
        {otherUrls.map((u) => (
          <a href={u.url} rel="noopener" data-cta-other data-slug={slug} data-position={`footer-other-${u.label.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>{u.label}</a>
        ))}
      </div>
    </section>

    {topics.length > 0 && (
      <div class="topics-row">
        <span style="font-size: 0.8rem; color: var(--text-muted);">{t.topicsLabel}:</span>
        {topics.map((tp) => <span class="topic-tag">{tp}</span>)}
      </div>
    )}

    {showAffiliateDisclosure && <p class="affiliate-note">{t.affiliateNote}</p>}
  </main>

  <script is:inline>
    // GA4 cta_click 発火 — Amazon / Sample / Zenn / Other の4種を統一計測
    // pointerdown でナビ前に確実に送る + middle click / Enter もカバー
    (function () {
      function ctaType(link) {
        if (link.hasAttribute('data-cta-amazon')) return 'amazon';
        if (link.hasAttribute('data-cta-sample')) return 'sample';
        if (link.hasAttribute('data-cta-zenn')) return 'zenn';
        if (link.hasAttribute('data-cta-other')) return 'other';
        return 'unknown';
      }
      function emitCta(link) {
        if (typeof gtag !== 'function') return;
        gtag('event', 'cta_click', {
          event_category: 'book_lp',
          event_label: link.getAttribute('data-slug') || '',
          cta_position: link.getAttribute('data-position') || 'unknown',
          cta_type: ctaType(link),
          destination: link.href,
          transport_type: 'beacon',
        });
      }
      function bind() {
        document.querySelectorAll('[data-cta-amazon], [data-cta-sample], [data-cta-zenn], [data-cta-other]').forEach(function (link) {
          if (link.__ctaBound) return;
          link.__ctaBound = true;
          link.addEventListener('pointerdown', function () { emitCta(link); });
          link.addEventListener('auxclick', function (e) { if (e.button === 1) emitCta(link); });
          link.addEventListener('keydown', function (e) { if (e.key === 'Enter') emitCta(link); });
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bind);
      } else {
        bind();
      }
    })();
  </script>
</BaseLayout>
