---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import { getCollection, getEntry, render } from 'astro:content';
import type { Alternate } from '../lib/alternates';
import { withAffiliateTag } from '../lib/affiliate';
import { proof } from '../data/proof';

interface Chapter {
  title: string;
  free?: boolean;
  summary?: string;
}

interface Part {
  name: string;
  summary?: string;
  chapters: Chapter[];
}

interface Comparison {
  book: string;
  difference: string;
}

interface Props {
  title: string;
  subtitle?: string;
  tagline?: string;
  heroMessage?: string;
  seriesRole?: string;
  positionStatement: string[];
  description: string;
  lang: 'en' | 'ja' | 'pt' | 'es';
  slug: string;
  publishedDate: Date;
  updatedDate?: Date;
  kindleUrl?: string;
  zennUrl?: string;
  otherUrls?: { label: string; url: string }[];
  price?: number;
  currency?: string;
  coverImage?: string;
  ogImage?: string;
  topics: string[];
  outcomes: string[];
  targetReaders: string[];
  differentiation: string[];
  chapters: Chapter[];
  parts?: Part[];
  competitorComparison: Comparison[];
  painPoints: string[];
  relatedBooks: string[];
  relatedArticles: { slug: string; title: string }[];
  keywords: string[];
  ctaLabel?: string;
  affiliateDisclosure?: boolean;
  canonicalUrl: string;
  alternates?: Alternate[];
}

const {
  title,
  subtitle,
  tagline,
  heroMessage,
  seriesRole,
  positionStatement,
  description,
  lang,
  slug,
  publishedDate,
  updatedDate,
  kindleUrl,
  zennUrl,
  otherUrls = [],
  price,
  currency = 'JPY',
  coverImage,
  ogImage,
  topics,
  outcomes,
  targetReaders,
  differentiation,
  chapters,
  parts,
  competitorComparison,
  painPoints,
  relatedBooks,
  relatedArticles,
  keywords,
  ctaLabel,
  affiliateDisclosure = false,
  canonicalUrl,
  alternates = [],
} = Astro.props;

const siteName = lang === 'ja' ? '井本 賢' : 'Ken Imoto';
const langPrefix = lang === 'en' ? '' : `/${lang}`;
const homeUrl = `${langPrefix}/` || '/';
const aboutUrl = `${langPrefix}/about/`;

// codex 指摘: kindle_url がある書籍は disclosure を自動表示 (frontmatter false でも上書き)
const showAffiliateDisclosure = !!kindleUrl || affiliateDisclosure;

const translations = {
  ja: {
    back: '← トップに戻る',
    overview: '本書の概要',
    outcomes: 'この本でできるようになること',
    position: 'この本の立ち位置',
    targetReaders: '対象読者',
    toc: '目次',
    freeChapter: '無料公開',
    whyThisBook: 'なぜこの本か',
    diffFromOthers: '他のAI本との違い',
    painPointsHeading: 'この本で解決できる悩み',
    relatedBooks: 'シリーズ・関連書籍',
    relatedArticles: '関連記事で深掘りする',
    cta: 'Kindleで購入する',
    ctaSub: 'Kindle Unlimitedで読み放題対象',
    primaryCta: '今すぐKindleで読む →',
    ctaZenn: 'Zennで読む',
    ctaZennSub: 'Zennで全文を読む',
    primaryCtaZenn: '今すぐZennで読む →',
    affiliateNote: '※ 本ページにはAmazonアソシエイトリンクが含まれます。クリック先での購入により著者に紹介料が入る場合があります。',
    publishedAt: '公開',
    updatedAt: '更新',
    readSampleZenn: 'Zennで試し読み',
    topicsLabel: 'トピック',
    compareCol1: '比較対象',
    compareCol2: '本書の違い',
    coverAlt: '表紙',
    otherLanguages: '他の言語版',
  },
  en: {
    back: '← Back to home',
    overview: 'Overview',
    outcomes: 'What you will be able to do',
    position: 'Where this book stands',
    targetReaders: 'Who is this book for',
    toc: 'Table of contents',
    freeChapter: 'Free preview',
    whyThisBook: 'Why this book',
    diffFromOthers: 'How this differs from other AI books',
    painPointsHeading: 'Problems this book solves',
    relatedBooks: 'Related books',
    relatedArticles: 'Dive deeper with related articles',
    cta: 'Buy on Kindle',
    ctaSub: 'Available on Kindle Unlimited',
    primaryCta: 'Read now on Kindle →',
    ctaZenn: 'Read on Zenn',
    ctaZennSub: 'Full text on Zenn',
    primaryCtaZenn: 'Read now on Zenn →',
    affiliateNote: '* This page contains Amazon Associates links. Purchases may earn the author a referral fee.',
    publishedAt: 'Published',
    updatedAt: 'Updated',
    readSampleZenn: 'Read sample on Zenn',
    topicsLabel: 'Topics',
    compareCol1: 'Compared to',
    compareCol2: "This book's difference",
    coverAlt: 'cover',
    otherLanguages: 'Other editions',
  },
  pt: {
    back: '← Voltar ao início',
    overview: 'Visão geral',
    outcomes: 'O que você será capaz de fazer',
    position: 'Onde este livro se posiciona',
    targetReaders: 'Para quem é este livro',
    toc: 'Sumário',
    freeChapter: 'Amostra grátis',
    whyThisBook: 'Por que este livro',
    diffFromOthers: 'Como este livro difere de outros sobre IA',
    painPointsHeading: 'Problemas que este livro resolve',
    relatedBooks: 'Livros relacionados',
    relatedArticles: 'Aprofunde com artigos relacionados',
    cta: 'Comprar no Kindle',
    ctaSub: 'Disponível no Kindle Unlimited',
    primaryCta: 'Ler agora no Kindle →',
    ctaZenn: 'Ler no Zenn',
    ctaZennSub: 'Texto completo no Zenn',
    primaryCtaZenn: 'Ler agora no Zenn →',
    affiliateNote: '* Esta página contém links da Amazon Associados. Compras podem gerar uma comissão para o autor.',
    publishedAt: 'Publicado em',
    updatedAt: 'Atualizado em',
    readSampleZenn: 'Ler amostra no Zenn',
    topicsLabel: 'Tópicos',
    compareCol1: 'Comparado com',
    compareCol2: 'Diferença deste livro',
    coverAlt: 'capa',
    otherLanguages: 'Outras edições',
  },
  es: {
    back: '← Volver al inicio',
    overview: 'Resumen',
    outcomes: 'Lo que podrás hacer',
    position: 'Dónde se sitúa este libro',
    targetReaders: 'Para quién es este libro',
    toc: 'Índice',
    freeChapter: 'Vista previa',
    whyThisBook: 'Por qué este libro',
    diffFromOthers: 'En qué se diferencia de otros libros sobre IA',
    painPointsHeading: 'Problemas que resuelve este libro',
    relatedBooks: 'Libros relacionados',
    relatedArticles: 'Profundiza con artículos relacionados',
    cta: 'Comprar en Kindle',
    ctaSub: 'Disponible en Kindle Unlimited',
    primaryCta: 'Leer ahora en Kindle →',
    ctaZenn: 'Leer en Zenn',
    ctaZennSub: 'Texto completo en Zenn',
    primaryCtaZenn: 'Leer ahora en Zenn →',
    affiliateNote: '* Esta página contiene enlaces de Amazon Afiliados. Las compras pueden generar una comisión para el autor.',
    publishedAt: 'Publicado',
    updatedAt: 'Actualizado',
    readSampleZenn: 'Leer muestra en Zenn',
    topicsLabel: 'Temas',
    compareCol1: 'Comparado con',
    compareCol2: 'Diferencia de este libro',
  coverAlt: 'portada',
    otherLanguages: 'Otras ediciones',
  },
};
const t = translations[lang];

// 他言語版ピル: alternates のうち x-default と現言語以外を表示
const langLabels: Record<string, string> = {
  en: 'English',
  ja: '日本語',
  pt: 'Português',
  es: 'Español',
};
const otherLangAlternates = alternates.filter(
  (a) => a.hreflang !== 'x-default' && a.hreflang !== lang
);

// CTA先決定: kindleUrl 優先、無ければ zennUrl
// Amazon URL は PUBLIC_AMAZON_TAG が設定されていれば ?tag= を自動注入
const amazonTag = import.meta.env.PUBLIC_AMAZON_TAG ?? '';
const taggedKindleUrl = withAffiliateTag(kindleUrl, amazonTag);
const isZennOnly = !kindleUrl && !!zennUrl;
const destinationUrl = taggedKindleUrl || zennUrl;
const heroPrimaryLabel = isZennOnly ? t.primaryCtaZenn : t.primaryCta;
const footerCtaLabel = isZennOnly ? t.ctaZenn : t.cta;
const footerCtaSubLabel = isZennOnly ? t.ctaZennSub : t.ctaSub;

// 関連記事の存在チェック: 該当言語のblog翻訳がなければEN版にfallback (404防止)
const allBlogPosts = await getCollection('blog');
const enFallbackNote: Record<string, string> = {
  ja: '（英語版）',
  pt: '(em inglês)',
  es: '(en inglés)',
  en: '',
};
const resolvedRelatedArticles = relatedArticles.map((a) => {
  const inLang = allBlogPosts.some((p) => p.id === `${lang}/${a.slug}`);
  if (inLang) {
    return { slug: a.slug, title: a.title, href: `${langPrefix}/blog/${a.slug}/`, fallback: false };
  }
  const inEn = allBlogPosts.some((p) => p.id === `en/${a.slug}`);
  if (inEn) {
    return { slug: a.slug, title: a.title, href: `/blog/${a.slug}/`, fallback: lang !== 'en' };
  }
  return null;
}).filter((x): x is { slug: string; title: string; href: string; fallback: boolean } => x !== null);

// 関連書籍のメタ情報を取得 (表紙・タイトル・series_role 表示用)
const allBooks = await getCollection('books');
const relatedBookEntries = relatedBooks
  .map((rbSlug) => {
    const sameLang = allBooks.find((b) => {
      const entrySlug = b.id.replace(/^(ja|en|pt|es)\//, '');
      return entrySlug === rbSlug && b.data.lang === lang;
    });
    if (sameLang) return { slug: rbSlug, data: sameLang.data, lang };
    const enFallback = allBooks.find((b) => {
      const entrySlug = b.id.replace(/^(ja|en|pt|es)\//, '');
      return entrySlug === rbSlug && b.data.lang === 'en';
    });
    if (enFallback) return { slug: rbSlug, data: enFallback.data, lang: 'en' as const };
    return null;
  })
  .filter((x): x is { slug: string; data: typeof allBooks[number]['data']; lang: typeof lang | 'en' } => x !== null);
const formattedPrice = price !== undefined
  ? (currency === 'JPY' ? `¥${price.toLocaleString()}` : `${currency} ${price}`)
  : null;

// 案B: parts が定義されていればそれを使い、無ければ chapters を 1part として扱う(後方互換)
const effectiveParts: Part[] = parts && parts.length > 0
  ? parts
  : (chapters.length > 0 ? [{ name: '', chapters }] : []);

// partsを使うとき、章番号は通しで振り直す
const partChapterStartIndex: number[] = [];
{
  let acc = 0;
  for (const p of effectiveParts) {
    partChapterStartIndex.push(acc);
    acc += p.chapters.length;
  }
}

// hero CTA に試し読みを並べる(Kindle商品ページ "サンプルを読む" 機能への踏み台)
const sampleUrl = taggedKindleUrl;

// 無料章 (Free Preview): src/content/free_chapters/{lang}/{slug}/*.md
// id形式: "{lang}/{slug}/{chapter}" — book と同じ {lang}/{slug} prefix で自動マッチング
// 並び順: intro系 (preface/introduction/chapter0) を先頭、続いてファイル名昇順 (ch01, ch02, ...)
const INTRO_NAMES = ['preface', 'introduction', 'chapter0', 'chapter00'];
const allFreeChapters = await getCollection('freeChapters', (entry) => {
  return entry.id.startsWith(`${lang}/${slug}/`);
});
type FreeChEntry = (typeof allFreeChapters)[number];
const introOrder = (s: string): number => {
  const idx = INTRO_NAMES.indexOf(s);
  return idx >= 0 ? idx : 100;
};
const chapterSlugOf = (e: FreeChEntry): string =>
  e.id.split('/').pop()!.replace(/\.md$/, '');
const orderedFreeChapters: FreeChEntry[] = [...allFreeChapters].sort((a, b) => {
  const ao = introOrder(chapterSlugOf(a));
  const bo = introOrder(chapterSlugOf(b));
  if (ao !== bo) return ao - bo;
  return chapterSlugOf(a).localeCompare(chapterSlugOf(b));
});

// 各章の本文Componentを事前にrender
const freePreviewRenders = await Promise.all(
  orderedFreeChapters.map(async (e) => {
    const { Content } = await render(e);
    return { id: e.id, title: e.data.title, Content };
  })
);

// 社会的証明: proof.ts の指標を現言語に解決
const proofMetrics = proof.metrics.map((m) => ({
  id: m.id,
  icon: m.icon,
  value: m.value,
  label: m.labels[lang],
}));
const proofAuthorBio = proof.authorBio[lang];
const proofSectionHeading = proof.sectionHeading[lang];
const proofSampleLabel = proof.sampleLabel[lang];
const proofKuBadge = proof.kuBadge[lang];
const proofGuarantee = proof.guarantee[lang];
const proofPartCta = proof.partCta[lang];
const proofFreePreviewHeading = proof.freePreviewHeading[lang];
const proofFreePreviewLead = proof.freePreviewLead[lang];
const proofFreePreviewChapterCta = proof.freePreviewChapterCta[lang];

const SITE_URL = 'https://kenimoto.dev';
const homeAbsUrl = `${SITE_URL}${homeUrl}`;
const booksIndexUrl = `${SITE_URL}${langPrefix}/books/`;

const inLanguageTag = lang === 'ja' ? 'ja-JP' : (lang === 'pt' ? 'pt-BR' : (lang === 'es' ? 'es-ES' : 'en-US'));
const sameAsList = [kindleUrl, zennUrl].filter(Boolean);

// Book + Product 双型は price がある場合のみ。
// price 未設定で Product 型にすると Search Console が「商品スニペット」エラー
// (offers/review/aggregateRating のいずれかが必須) を出す。
// EN 版は USD 価格未設定なので Book 単独にして Product 必須項目から外す。
const useProductType = !!price;
const bookSchema = {
  '@context': 'https://schema.org',
  '@type': useProductType ? ['Book', 'Product'] : 'Book',
  '@id': `${canonicalUrl}#book`,
  name: title + (subtitle ? ` — ${subtitle}` : ''),
  description,
  inLanguage: inLanguageTag,
  bookFormat: 'EBook',
  author: {
    '@type': 'Person',
    '@id': `${SITE_URL}/#person`,
    name: siteName,
    url: `${SITE_URL}/`,
  },
  publisher: { '@id': `${SITE_URL}/#organization` },
  url: canonicalUrl,
  ...(coverImage ? { image: coverImage } : {}),
  ...(sameAsList.length > 0 ? { sameAs: sameAsList } : {}),
  isPartOf: { '@id': `${SITE_URL}/#website` },
  ...(price ? {
    offers: {
      '@type': 'Offer',
      price: String(price),
      priceCurrency: currency,
      url: kindleUrl || zennUrl,
      availability: 'https://schema.org/InStock',
      seller: { '@id': `${SITE_URL}/#organization` },
    },
  } : {}),
  about: topics,
  datePublished: publishedDate.toISOString().split('T')[0],
  ...(updatedDate ? { dateModified: updatedDate.toISOString().split('T')[0] } : {}),
  ...(keywords.length > 0 ? { keywords: keywords.join(', ') } : {}),
  ...(seriesRole ? { genre: seriesRole } : {}),
};

const T_NAV = {
  en: { home: 'Home', books: 'Books' },
  ja: { home: 'ホーム', books: '書籍' },
  pt: { home: 'Início', books: 'Livros' },
  es: { home: 'Inicio', books: 'Libros' },
}[lang];

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: T_NAV.home, item: homeAbsUrl },
    { '@type': 'ListItem', position: 2, name: T_NAV.books, item: booksIndexUrl },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
  ],
};

const bookJsonLd = [bookSchema, breadcrumbJsonLd];
---

<BaseLayout
  title={`${title} — ${siteName}`}
  description={description}
  lang={lang}
  ogUrl={canonicalUrl}
  ogDescription={description}
  ogImage={ogImage || coverImage}
  ogType="book"
  alternates={alternates}
  jsonLd={bookJsonLd}
>
  <Fragment slot="head">
    {topics.map(t => <meta property="book:tag" content={t} />)}
    <style>
      .book-lp {
        max-width: 760px;
        margin: 0 auto;
        padding: 2.5rem 2rem 4rem;
      }
      .book-lp h1 {
        font-size: 2rem;
        font-weight: 700;
        margin: 0.5rem 0 0.5rem;
        line-height: 1.3;
        color: var(--text-primary);
      }
      .book-lp .subtitle {
        font-size: 1.1rem;
        color: var(--text-secondary);
        margin: 0 0 0.5rem;
      }
      .book-lp .tagline {
        font-size: 0.95rem;
        color: var(--text-label);
        margin: 0 0 1.5rem;
        font-weight: 500;
        letter-spacing: 0.01em;
      }
      .hero-message {
        background: var(--bg-card);
        border-left: 3px solid var(--accent-blue);
        padding: 1rem 1.25rem;
        margin: 0 0 1rem;
        border-radius: 4px;
      }
      .hero-message p {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text-primary);
        line-height: 1.55;
      }
      .series-role-badge {
        display: inline-block;
        background: var(--bg-card);
        color: var(--text-label);
        border: 1px solid var(--text-separator);
        padding: 0.45rem 0.9rem;
        border-radius: 6px;
        font-size: 0.85rem;
        margin: 0 0 1.5rem;
        line-height: 1.5;
      }
      .series-role-badge::before {
        content: "▸ ";
        color: var(--accent-blue);
        margin-right: 0.15rem;
      }
      .hero-cta-row {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin: 0 0 2rem;
      }
      .hero-cta-primary {
        background: var(--accent-amber);
        color: white;
        padding: 0.85rem 1.75rem;
        border-radius: 6px;
        font-weight: 700;
        font-size: 1rem;
        text-decoration: none;
        transition: opacity 0.15s;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
      }
      .hero-cta-primary:hover {
        opacity: 0.9;
        text-decoration: none;
      }
      .hero-cta-secondary {
        background: transparent;
        color: var(--text-secondary);
        padding: 0.85rem 1.5rem;
        border: 1px solid var(--text-separator);
        border-radius: 6px;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.15s;
      }
      .hero-cta-secondary:hover {
        border-color: var(--text-label);
        color: var(--text-primary);
        text-decoration: none;
      }
      .position-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0.75rem;
      }
      .position-list li {
        background: var(--bg-card);
        padding: 0.85rem 1.1rem;
        border-radius: 6px;
        color: var(--text-primary);
        font-weight: 500;
        line-height: 1.6;
        border-top: 3px solid var(--accent-blue);
      }
      .outcomes-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .outcomes-list li {
        position: relative;
        padding: 0.6rem 0 0.6rem 2rem;
        line-height: 1.7;
        color: var(--text-secondary);
        border-bottom: 1px solid var(--text-separator);
      }
      .outcomes-list li:last-child {
        border-bottom: none;
      }
      .outcomes-list li::before {
        content: "✓";
        position: absolute;
        left: 0.4rem;
        top: 0.65rem;
        color: var(--accent-green);
        font-weight: 700;
        font-size: 1rem;
      }
      .book-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1rem;
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
      }
      .book-meta .price {
        background: var(--accent-amber);
        color: white;
        padding: 0.15rem 0.6rem;
        border-radius: 4px;
        font-weight: 600;
      }
      .book-meta .ku-badge {
        background: var(--bg-elev);
        color: var(--text-primary);
        border: 1px solid var(--text-separator);
        padding: 0.15rem 0.6rem;
        border-radius: 4px;
        font-weight: 500;
        font-size: 0.8rem;
      }

      /* Hero下: 著者bio 1行 + 7日返品 */
      .author-bio-line {
        font-size: 0.85rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0 0 1.5rem;
        padding: 0.6rem 0.8rem;
        background: var(--bg-elev);
        border-left: 3px solid var(--accent-amber);
        border-radius: 2px;
      }
      .author-bio-line .guarantee-text {
        color: var(--text-muted);
        font-size: 0.8rem;
      }

      /* 案C: Social Proof Block (Hero直下) */
      .social-proof {
        margin: 0 0 2.5rem;
        padding: 1.25rem 1rem;
        background: var(--bg-elev);
        border-radius: 6px;
        border: 1px solid var(--text-separator);
      }
      .social-proof-heading {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        margin: 0 0 0.85rem;
        text-align: center;
      }
      .social-proof-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.75rem;
      }
      .social-proof-card {
        text-align: center;
        padding: 0.5rem 0.25rem;
      }
      .social-proof-icon {
        font-size: 1.4rem;
        line-height: 1;
        display: block;
        margin-bottom: 0.25rem;
      }
      .social-proof-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
        line-height: 1.1;
      }
      .social-proof-label {
        font-size: 0.72rem;
        color: var(--text-muted);
        line-height: 1.35;
        margin-top: 0.25rem;
      }
      @media (max-width: 640px) {
        .social-proof-grid {
          grid-template-columns: repeat(2, 1fr);
          gap: 0.5rem;
        }
        .social-proof-value {
          font-size: 1.25rem;
        }
        .social-proof-label {
          font-size: 0.68rem;
        }
      }

      /* Free Preview: 無料章を accordion で展開 */
      .free-preview {
        margin: 0 0 3rem;
        padding: 1.5rem 1.25rem;
        background: var(--bg-elev);
        border-radius: 8px;
        border: 1px solid var(--accent-amber);
      }
      .free-preview-heading {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0 0 0.4rem;
        padding: 0;
        border: none;
      }
      .free-preview-lead {
