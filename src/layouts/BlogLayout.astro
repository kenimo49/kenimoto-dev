---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import type { Alternate } from '../lib/alternates';

interface Props {
  title: string;
  description: string;
  lang: 'en' | 'ja' | 'pt' | 'es';
  date: Date;
  updated?: Date;
  tags: string[];
  canonicalUrl: string;
  ogImage?: string;
  alternates?: Alternate[];
}

const { title, description, lang, date, updated, tags, canonicalUrl, ogImage, alternates = [] } = Astro.props;
const formattedDate = date.toISOString().split('T')[0];
const siteName = lang === 'ja' ? '井本 賢' : 'Ken Imoto';
const SITE_URL = 'https://kenimoto.dev';
const langPrefix = lang === 'en' ? '' : `/${lang}`;
const blogIndexUrl = `${langPrefix}/blog/`;
const homeUrl = `${langPrefix}/` || '/';

// 4 言語 UI ラベル
const T = {
  en: { back: '← Back to Blog', helpful: 'Was this article helpful?', yes: 'Yes', no: 'No', thanks: 'Thank you for your feedback', home: 'Home', articles: 'Articles' },
  ja: { back: '← ブログに戻る', helpful: 'この記事は役に立ちましたか？', yes: 'はい', no: 'いいえ', thanks: 'ご回答ありがとうございます', home: 'ホーム', articles: '記事' },
  pt: { back: '← Voltar ao Blog', helpful: 'Este artigo foi útil?', yes: 'Sim', no: 'Não', thanks: 'Obrigado pelo seu feedback', home: 'Início', articles: 'Artigos' },
  es: { back: '← Volver al Blog', helpful: '¿Te resultó útil este artículo?', yes: 'Sí', no: 'No', thanks: 'Gracias por tus comentarios', home: 'Inicio', articles: 'Artículos' },
}[lang];

const ogImageAbs = ogImage
  ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, SITE_URL).href)
  : `${SITE_URL}/og-image.png`;

const blogPostingJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: ogImageAbs,
  datePublished: date.toISOString(),
  dateModified: (updated ?? date).toISOString(),
  author: {
    '@type': 'Person',
    '@id': `${SITE_URL}/#person`,
    name: siteName,
    url: `${SITE_URL}/`,
  },
  publisher: { '@id': `${SITE_URL}/#organization` },
  url: canonicalUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  ...(tags.length > 0 ? { keywords: tags.join(', ') } : {}),
  inLanguage: lang === 'ja' ? 'ja-JP' : (lang === 'pt' ? 'pt-BR' : (lang === 'es' ? 'es-ES' : 'en-US')),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: T.home, item: `${SITE_URL}${homeUrl}` },
    { '@type': 'ListItem', position: 2, name: T.articles, item: `${SITE_URL}${blogIndexUrl}` },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
  ],
};

const articleJsonLd = [blogPostingJsonLd, breadcrumbJsonLd];
---

<BaseLayout
  title={`${title} — ${siteName}`}
  description={description}
  lang={lang}
  ogUrl={canonicalUrl}
  ogDescription={description}
  ogImage={ogImage}
  ogType="article"
  alternates={alternates}
  jsonLd={articleJsonLd}
  articleMeta={{
    publishedTime: date.toISOString(),
    modifiedTime: (updated ?? date).toISOString(),
    author: siteName,
    tags,
  }}
>
  <Fragment slot="head">
    <style>
      .prose {
        font-size: 1rem;
        line-height: 1.85;
        color: var(--text-secondary);
      }
      .prose h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
        margin: 2.5rem 0 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--text-separator);
      }
      .prose h3 {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-primary);
        margin: 2rem 0 0.75rem;
      }
      .prose p {
        margin: 0 0 1.25rem;
      }
      .prose a {
        color: var(--link-color);
        text-decoration: underline;
      }
      .prose code {
        background: var(--bg-card);
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.9em;
      }
      .prose pre,
      .prose :global(pre) {
        background: #0a0a0a !important;
        color: #e2e8f0;
        border-radius: 8px;
        padding: 1.25rem !important;
        overflow-x: auto;
        margin: 1.5rem 0;
      }
      .prose pre code,
      .prose :global(pre) code {
        background: none !important;
        color: inherit;
        padding: 0;
      }
      .prose blockquote {
        border-left: 3px solid var(--accent-blue);
        padding-left: 1rem;
        color: var(--text-label);
        margin: 1.5rem 0;
        font-style: italic;
      }
      .prose ul, .prose ol {
        padding-left: 1.5rem;
        margin: 1rem 0;
      }
      .prose li {
        margin: 0.4rem 0;
      }
      .prose img,
      .prose :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin: 1.5rem 0;
      }
      .prose hr {
        border: none;
        border-top: 1px solid var(--text-separator);
        margin: 2rem 0;
      }
      .prose table,
      .prose :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 1.75rem 0;
        font-size: 0.95rem;
        display: block;
        overflow-x: auto;
        white-space: nowrap;
      }
      @media (min-width: 768px) {
        .prose table,
        .prose :global(table) {
          display: table;
          white-space: normal;
        }
      }
      .prose thead,
      .prose :global(thead) {
        background: var(--bg-card);
        border-bottom: 2px solid var(--text-separator);
      }
      .prose th, .prose td,
      .prose :global(th), .prose :global(td) {
        border: 1px solid var(--text-separator);
        padding: 0.65rem 1rem;
        text-align: left;
        vertical-align: top;
      }
      .prose th,
      .prose :global(th) {
        background: var(--bg-card);
        font-weight: 600;
        color: var(--text-primary);
      }
      .prose tbody tr:nth-child(even),
      .prose :global(tbody tr:nth-child(even)) {
        background: rgba(96, 165, 250, 0.05);
      }
      .prose tbody tr:hover,
      .prose :global(tbody tr:hover) {
        background: rgba(96, 165, 250, 0.10);
      }
      .prose strong {
        color: var(--text-primary);
        font-weight: 600;
      }
    </style>
  </Fragment>

  <Nav lang={lang} current="blog" alternates={alternates} />

  <main style="max-width: 720px; margin: 0 auto; padding: 4rem 2rem;">
    <article>
      <!-- Article header -->
      <header style="margin-bottom: 2.5rem;">
        <a href={blogIndexUrl} style="font-size: 0.85rem; color: var(--text-muted); text-decoration: none;">
          {T.back}
        </a>
        <h1 style="font-size: 2rem; font-weight: 700; margin: 1rem 0 0.75rem; line-height: 1.3;">{title}</h1>
        <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; font-size: 0.85rem; color: var(--text-muted);">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {tags.length > 0 && (
            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
              {tags.map(tag => (
                <span style="background: var(--bg-card); padding: 0.15rem 0.5rem; border-radius: 4px; font-size: 0.8rem;">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </header>

      <!-- Article body -->
      <div class="prose">
        <slot />
      </div>

      <div class="feedback" id="feedback-section">
        <p class="feedback-question">{T.helpful}</p>
        <div class="feedback-buttons">
          <button class="feedback-btn" data-reaction="helpful" aria-label="Helpful">
            <span class="feedback-icon">&#9650;</span>
            <span>{T.yes}</span>
          </button>
          <button class="feedback-btn" data-reaction="not_helpful" aria-label="Not helpful">
            <span class="feedback-icon">&#9660;</span>
            <span>{T.no}</span>
          </button>
        </div>
        <p class="feedback-thanks" style="display: none;">{T.thanks}</p>
      </div>

    </article>
  </main>

  <style>
    .feedback {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--text-separator);
      text-align: center;
    }
    .feedback-question {
      font-size: 0.9rem;
      color: var(--text-muted);
      margin-bottom: 0.75rem;
    }
    .feedback-buttons {
      display: flex;
      justify-content: center;
      gap: 1rem;
    }
    .feedback-btn {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.5rem 1.25rem;
      border: 1px solid var(--text-separator);
      border-radius: 20px;
      background: none;
      color: var(--text-muted);
      font-size: 0.85rem;
      font-family: inherit;
      cursor: pointer;
      transition: all 0.2s;
    }
    .feedback-btn:hover {
      border-color: var(--accent, #3D6B99);
      color: var(--accent, #3D6B99);
    }
    .feedback-icon {
      font-size: 0.7rem;
    }
    .feedback-thanks {
      font-size: 0.85rem;
      color: var(--accent, #3D6B99);
      margin-top: 0.75rem;
    }
  </style>

  <script define:vars={{ canonicalUrl }}>
    const section = document.getElementById('feedback-section');
    const buttons = section.querySelectorAll('.feedback-btn');
    const thanks = section.querySelector('.feedback-thanks');
    const btnContainer = section.querySelector('.feedback-buttons');

    const slug = canonicalUrl.split('/blog/').pop() || '';

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const reaction = btn.dataset.reaction;

        if (typeof gtag === 'function') {
          gtag('event', 'article_feedback', {
            reaction: reaction,
            article_slug: slug,
          });
        }

        btnContainer.style.display = 'none';
        thanks.style.display = '';
      });
    });
  </script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.prose pre').forEach(function(pre) {
        var wrapper = document.createElement('div');
        wrapper.style.position = 'relative';
        pre.parentNode.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);

        var btn = document.createElement('button');
        btn.textContent = 'Copy';
        btn.style.cssText = 'position:absolute;top:0.5rem;right:0.5rem;background:var(--bg-primary);color:var(--text-label);border:1px solid var(--text-separator);border-radius:4px;padding:0.2rem 0.5rem;font-size:0.75rem;cursor:pointer;opacity:0;transition:opacity 0.15s;';
        wrapper.appendChild(btn);

        wrapper.addEventListener('mouseenter', function() { btn.style.opacity = '1'; });
        wrapper.addEventListener('mouseleave', function() { btn.style.opacity = '0'; });

        btn.addEventListener('click', function() {
          var code = pre.querySelector('code');
          var text = (code || pre).textContent;
          navigator.clipboard.writeText(text).then(function() {
            btn.textContent = 'Copied!';
            setTimeout(function() { btn.textContent = 'Copy'; }, 1500);
          });
        });
      });
    });
  </script>
</BaseLayout>
