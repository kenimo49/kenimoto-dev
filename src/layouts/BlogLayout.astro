---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import type { Alternate } from '../lib/alternates';
import { buildPersonEntity, buildOrganizationEntity, buildWebSiteEntity, websiteId } from '../lib/person-entity';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface ReadingTime {
  minutes: number;
  label: string;
}

interface Props {
  title: string;
  description: string;
  lang: 'en' | 'ja' | 'pt' | 'es';
  date: Date;
  updated?: Date;
  tags: string[];
  canonicalUrl: string;
  ogImage?: string;
  alternates?: Alternate[];
  headings?: Heading[];
  readingTime?: ReadingTime;
}

const { title, description, lang, date, updated, tags, canonicalUrl, ogImage, alternates = [], headings = [], readingTime } = Astro.props;
const tocHeadings = headings.filter(h => h.depth === 2);
const showToc = tocHeadings.length >= 3;
const formattedDate = date.toISOString().split('T')[0];
const siteName = lang === 'ja' ? '井本 賢' : 'Ken Imoto';
const SITE_URL = 'https://kenimoto.dev';
const langPrefix = lang === 'en' ? '' : `/${lang}`;
const blogIndexUrl = `${langPrefix}/blog/`;
const homeUrl = `${langPrefix}/` || '/';

// 4 言語 UI ラベル
const T = {
  en: { back: '← Back to Blog', helpful: 'Was this article helpful?', yes: 'Yes', no: 'No', thanks: 'Thank you for your feedback', home: 'Home', articles: 'Articles' },
  ja: { back: '← ブログに戻る', helpful: 'この記事は役に立ちましたか？', yes: 'はい', no: 'いいえ', thanks: 'ご回答ありがとうございます', home: 'ホーム', articles: '記事' },
  pt: { back: '← Voltar ao Blog', helpful: 'Este artigo foi útil?', yes: 'Sim', no: 'Não', thanks: 'Obrigado pelo seu feedback', home: 'Início', articles: 'Artigos' },
  es: { back: '← Volver al Blog', helpful: '¿Te resultó útil este artículo?', yes: 'Sí', no: 'No', thanks: 'Gracias por tus comentarios', home: 'Inicio', articles: 'Artículos' },
}[lang];

const ogImageAbs = ogImage
  ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, SITE_URL).href)
  : `${SITE_URL}/og-image.png`;

const blogPostingJsonLd = {
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: ogImageAbs,
  datePublished: date.toISOString(),
  dateModified: (updated ?? date).toISOString(),
  // author/publisher は同じ @graph 内の Person/Organization 実体を参照する。
  author: { '@id': `${SITE_URL}/#person` },
  publisher: { '@id': `${SITE_URL}/#organization` },
  url: canonicalUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  isPartOf: { '@id': websiteId(lang) },
  ...(tags.length > 0 ? { keywords: tags.join(', ') } : {}),
  inLanguage: lang === 'ja' ? 'ja-JP' : (lang === 'pt' ? 'pt-BR' : (lang === 'es' ? 'es-ES' : 'en-US')),
};

const breadcrumbJsonLd = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: T.home, item: `${SITE_URL}${homeUrl}` },
    { '@type': 'ListItem', position: 2, name: T.articles, item: `${SITE_URL}${blogIndexUrl}` },
    { '@type': 'ListItem', position: 3, name: title, item: canonicalUrl },
  ],
};

// 単一ページで自己完結する @graph。著者の sameAs ネットワーク(Person)と
// 発行者(Organization)の実体を記事ページ自身に同梱し、AI が単一 URL を
// 取得しても著者の同一性を解決できるようにする。
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    blogPostingJsonLd,
    breadcrumbJsonLd,
    buildPersonEntity(lang),
    buildOrganizationEntity(),
    buildWebSiteEntity(lang),
  ],
};
---

<BaseLayout
  title={`${title} — ${siteName}`}
  description={description}
  lang={lang}
  ogUrl={canonicalUrl}
  ogDescription={description}
  ogImage={ogImage}
  ogType="article"
  alternates={alternates}
  jsonLd={articleJsonLd}
  articleMeta={{
    publishedTime: date.toISOString(),
    modifiedTime: (updated ?? date).toISOString(),
    author: siteName,
    tags,
  }}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" />
    <style>
      /* 記事ページのタイポグラフィ: Plex Sans 本文 × Plex Mono 見出し/メタ/code を
         signature element として 1 軸に boldness を集中。色とレイアウトは quiet に保つ。 */
      .article-root {
        font-family: 'IBM Plex Sans', system-ui, -apple-system, sans-serif;
      }
      .prose {
        font-size: 1.0625rem;
        line-height: 1.75;
        color: var(--text-primary);
        font-feature-settings: 'kern' 1, 'liga' 1;
      }
      .prose :global(h2) {
        font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 1.3125rem;
        font-weight: 600;
        color: var(--text-primary);
        margin: 3rem 0 1.25rem;
        letter-spacing: -0.01em;
        line-height: 1.45;
      }
      .prose :global(h3) {
        font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 1.0625rem;
        font-weight: 600;
        color: var(--text-primary);
        margin: 2.25rem 0 0.75rem;
        letter-spacing: -0.01em;
        line-height: 1.5;
      }
      .prose :global(p) {
        margin: 0 0 1.25rem;
      }
      .prose :global(a) {
        color: var(--link-color);
        text-decoration: underline;
        text-underline-offset: 2px;
        text-decoration-thickness: 1px;
      }
      .prose :global(a:hover) {
        text-decoration-thickness: 2px;
      }
      .prose :global(code) {
        background: var(--bg-card);
        border: 1px solid var(--text-separator);
        padding: 0.1rem 0.4rem;
        border-radius: 4px;
        font-size: 0.875em;
        font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
      }
      /* Shiki dual-theme: 背景・文字色は inline で var(--shiki-*) が刺さるので
         こちらは枠・余白・タイポグラフィだけ整える。!important で背景を潰さない。 */
      .prose :global(pre.astro-code) {
        border: 1px solid var(--text-separator);
        border-radius: 8px;
        padding: 1.25rem 1.5rem;
        overflow-x: auto;
        margin: 2rem 0;
        font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.875rem;
        line-height: 1.7;
        position: relative;
      }
      .prose :global(pre.astro-code code) {
        background: none !important;
        border: none;
        color: inherit;
        padding: 0;
        font-family: inherit;
      }
      /* light/dark で Shiki が出力する 2 色を切り替える。
         defaultColor: false にすると inline style では色が当たらず CSS 変数だけ
         置かれるため、ここでマッピングする必要がある。 */
      :global([data-theme='light']) .prose :global(pre.astro-code),
      :global([data-theme='light']) .prose :global(pre.astro-code span) {
        color: var(--shiki-light) !important;
        background-color: var(--shiki-light-bg) !important;
      }
      :global([data-theme='dark']) .prose :global(pre.astro-code),
      :global([data-theme='dark']) .prose :global(pre.astro-code span) {
        color: var(--shiki-dark) !important;
        background-color: var(--shiki-dark-bg) !important;
      }
      /* 言語ラベル — data-language が text/未指定でないときだけ右上に薄く出す */
      .prose :global(pre.astro-code[data-language]:not([data-language='text'])::before) {
        content: attr(data-language);
        position: absolute;
        top: 0.55rem;
        right: 0.75rem;
        font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.7rem;
        color: var(--text-muted);
        letter-spacing: 0.05em;
        text-transform: lowercase;
        pointer-events: none;
        opacity: 0.7;
      }
      .prose :global(blockquote) {
        border-left: 3px solid var(--accent-blue);
        padding-left: 1rem;
        color: var(--text-label);
        margin: 1.5rem 0;
        font-style: italic;
      }
      .prose :global(.book-callout) {
        background: var(--bg-card);
        border-left: 4px solid var(--accent-blue);
        border-radius: 6px;
        padding: 1.1rem 1.25rem;
        margin: 2rem 0;
        color: var(--text-secondary);
      }
      .prose :global(.book-callout > p:first-child) {
        margin-top: 0;
      }
      .prose :global(.book-callout > p:last-child) {
        margin-bottom: 0;
      }
      .prose :global(.book-callout strong) {
        color: var(--text-primary);
      }
      .prose :global(.book-callout a) {
        color: var(--accent-blue);
      }
      .prose :global(ul), .prose :global(ol) {
        padding-left: 1.5rem;
        margin: 1rem 0;
      }
      .prose :global(li) {
        margin: 0.4rem 0;
      }
      .prose img,
      .prose :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin: 1.5rem 0;
      }
      .prose :global(hr) {
        border: none;
        border-top: 1px solid var(--text-separator);
        margin: 2rem 0;
      }
      .prose table,
      .prose :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 1.75rem 0;
        font-size: 0.95rem;
      }
      /* モバイルでは横スクロールが必要な時だけスクロール、原則は wrap させて読ませる */
      @media (max-width: 600px) {
        .prose table,
        .prose :global(table) {
          font-size: 0.875rem;
        }
        .prose th, .prose td,
        .prose :global(th), .prose :global(td) {
          padding: 0.5rem 0.65rem;
        }
      }
      .prose thead,
      .prose :global(thead) {
        background: var(--bg-card);
        border-bottom: 2px solid var(--text-separator);
      }
      .prose th, .prose td,
      .prose :global(th), .prose :global(td) {
        border: 1px solid var(--text-separator);
        padding: 0.65rem 1rem;
        text-align: left;
        vertical-align: top;
      }
      .prose th,
      .prose :global(th) {
        background: var(--bg-card);
        font-weight: 600;
        color: var(--text-primary);
      }
      .prose tbody tr:nth-child(even),
      .prose :global(tbody tr:nth-child(even)) {
        background: rgba(96, 165, 250, 0.05);
      }
      .prose tbody tr:hover,
      .prose :global(tbody tr:hover) {
        background: rgba(96, 165, 250, 0.10);
      }
      .prose :global(strong) {
        color: var(--text-primary);
        font-weight: 700;
      }
    </style>
  </Fragment>

  <Nav lang={lang} current="blog" alternates={alternates} />

  <main class="article-shell">
    {showToc && (
      <aside class="article-toc" aria-label="Table of contents">
        <div class="article-toc-inner">
          <div class="toc-label">{lang === 'ja' ? '目次' : (lang === 'pt' ? 'Sumário' : (lang === 'es' ? 'Índice' : 'Contents'))}</div>
          <ol class="toc-list">
            {tocHeadings.map(h => (
              <li><a href={`#${h.slug}`}>{h.text}</a></li>
            ))}
          </ol>
        </div>
      </aside>
    )}
    <article class="article-root">
      <!-- Article header -->
      <header style="margin-bottom: 3rem;">
        <a href={blogIndexUrl} class="back-link">{T.back}</a>
        <h1 class="article-title">{title}</h1>
        <div class="article-meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {readingTime && (
            <>
              <span class="meta-sep">/</span>
              <span class="meta-reading-time">{readingTime.label}</span>
            </>
          )}
          {tags.length > 0 && (
            <>
              <span class="meta-sep">/</span>
              <span class="meta-tags">{tags.join(' · ')}</span>
            </>
          )}
        </div>
      </header>

      <!-- Article body -->
      <div class="prose">
        <slot />
      </div>

      <div class="feedback" id="feedback-section">
        <p class="feedback-question">{T.helpful}</p>
        <div class="feedback-buttons">
          <button class="feedback-btn" data-reaction="helpful" aria-label="Helpful">
            <span class="feedback-icon">&#9650;</span>
            <span>{T.yes}</span>
          </button>
          <button class="feedback-btn" data-reaction="not_helpful" aria-label="Not helpful">
            <span class="feedback-icon">&#9660;</span>
            <span>{T.no}</span>
          </button>
        </div>
        <p class="feedback-thanks" style="display: none;">{T.thanks}</p>
      </div>

    </article>
  </main>

  <style>
    .article-shell {
      max-width: 720px;
      margin: 0 auto;
      padding: 4rem 2rem;
      position: relative;
    }
    /* TOC: 右レール、sticky 配置。記事位置はずらさず、空いている右側スペースに置く。
       閾値 1240px は (vp-760)/2 + 760 + 40 + 200 ≤ vp の解。
       下回るとビューポート右端を超えるので非表示。 */
    .article-toc {
      display: none;
    }
    @media (min-width: 1240px) {
      .article-toc {
        display: block;
        position: absolute;
        top: 4rem;
        left: 100%;
        margin-left: 2.5rem;
        width: 200px;
      }
      .article-toc-inner {
        position: sticky;
        top: 2rem;
        max-height: calc(100vh - 4rem);
        overflow-y: auto;
      }
    }
    .toc-label {
      font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 0.75rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--text-separator);
    }
    .toc-list {
      list-style: none;
      padding: 0;
      margin: 0;
      font-size: 0.8125rem;
      line-height: 1.55;
    }
    .toc-list li {
      margin: 0.5rem 0;
    }
    .toc-list a {
      color: var(--text-label);
      text-decoration: none;
      transition: color 0.15s;
      display: block;
    }
    .toc-list a:hover {
      color: var(--text-primary);
      text-decoration: none;
    }
    .toc-list a.toc-active {
      color: var(--text-primary);
      font-weight: 500;
    }
    .back-link {
      font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.8rem;
      color: var(--text-muted);
      text-decoration: none;
      letter-spacing: 0.01em;
    }
    .back-link:hover {
      color: var(--text-primary);
      text-decoration: none;
    }
    .article-title {
      font-family: 'IBM Plex Sans', system-ui, -apple-system, sans-serif;
      font-size: 2.125rem;
      font-weight: 700;
      margin: 1.25rem 0 1rem;
      line-height: 1.3;
      letter-spacing: -0.015em;
      color: var(--text-primary);
    }
    .article-meta {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      flex-wrap: wrap;
      font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.8125rem;
      color: var(--text-muted);
      letter-spacing: 0.01em;
    }
    .meta-sep {
      color: var(--text-separator);
    }
    .meta-tags {
      color: var(--text-label);
    }
    .feedback {
      margin-top: 4rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--text-separator);
      text-align: center;
    }
    .feedback-question {
      font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.85rem;
      color: var(--text-muted);
      margin-bottom: 0.75rem;
      letter-spacing: 0.01em;
    }
    .feedback-buttons {
      display: flex;
      justify-content: center;
      gap: 1rem;
    }
    .feedback-btn {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.5rem 1.25rem;
      border: 1px solid var(--text-separator);
      border-radius: 20px;
      background: none;
      color: var(--text-muted);
      font-size: 0.85rem;
      font-family: inherit;
      cursor: pointer;
      transition: all 0.2s;
    }
    .feedback-btn:hover {
      border-color: var(--accent, #3D6B99);
      color: var(--accent, #3D6B99);
    }
    .feedback-icon {
      font-size: 0.7rem;
    }
    .feedback-thanks {
      font-size: 0.85rem;
      color: var(--accent, #3D6B99);
      margin-top: 0.75rem;
    }
  </style>

  <script define:vars={{ canonicalUrl }}>
    const section = document.getElementById('feedback-section');
    const buttons = section.querySelectorAll('.feedback-btn');
    const thanks = section.querySelector('.feedback-thanks');
    const btnContainer = section.querySelector('.feedback-buttons');

    const slug = canonicalUrl.split('/blog/').pop() || '';

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const reaction = btn.dataset.reaction;

        if (typeof gtag === 'function') {
          gtag('event', 'article_feedback', {
            reaction: reaction,
            article_slug: slug,
          });
        }

        btnContainer.style.display = 'none';
        thanks.style.display = '';
      });
    });

    // 読了計測: 記事末尾(feedback-section)が表示されたら article_read_complete を1回発火。
    // GA4 標準の scroll(90%) より強い「本文を読み切った」シグナルで、CTA露出と相関する。
    if (section && 'IntersectionObserver' in window) {
      let fired = false;
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !fired) {
            fired = true;
            if (typeof gtag === 'function') {
              gtag('event', 'article_read_complete', { article_slug: slug });
            }
            io.disconnect();
          }
        });
      }, { threshold: 0.5 });
      io.observe(section);
    }
  </script>

  <script is:inline>
    // TOC 追従: スクロール位置に最も近い h2 を toc-active としてハイライト。
    // IntersectionObserver で各 h2 の表示状態を追い、画面上半分にある最後の h2 をアクティブに。
    document.addEventListener('DOMContentLoaded', function() {
      var tocLinks = document.querySelectorAll('.toc-list a');
      if (tocLinks.length === 0) return;
      var slugToLink = {};
      tocLinks.forEach(function(a) {
        var id = a.getAttribute('href').replace(/^#/, '');
        slugToLink[id] = a;
      });
      var headings = Array.prototype.slice.call(document.querySelectorAll('.prose h2[id]'));
      if (headings.length === 0) return;
      var setActive = function(id) {
        tocLinks.forEach(function(a) { a.classList.remove('toc-active'); });
        if (id && slugToLink[id]) slugToLink[id].classList.add('toc-active');
      };
      var current = null;
      var update = function() {
        var threshold = window.innerHeight * 0.3;
        var found = null;
        for (var i = 0; i < headings.length; i++) {
          var r = headings[i].getBoundingClientRect();
          if (r.top <= threshold) found = headings[i].id;
          else break;
        }
        if (found !== current) { current = found; setActive(found); }
      };
      window.addEventListener('scroll', update, { passive: true });
      update();
    });
  </script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll('.prose pre').forEach(function(pre) {
        var wrapper = document.createElement('div');
        wrapper.style.cssText = 'position:relative;';
        pre.parentNode.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);

        // 言語ラベルが ::before で右上に出るので、Copy ボタンは下にずらす。
        // 言語が text/なしの記事もあるので位置は固定オフセットで OK。
        var lang = pre.getAttribute('data-language');
        var hasLangLabel = lang && lang !== 'text';
        var topOffset = hasLangLabel ? '2rem' : '0.55rem';

        var btn = document.createElement('button');
        btn.textContent = 'copy';
        btn.style.cssText = [
          'position:absolute',
          'top:' + topOffset,
          'right:0.55rem',
          'background:transparent',
          'color:var(--text-muted)',
          'border:1px solid var(--text-separator)',
          'border-radius:4px',
          'padding:0.15rem 0.55rem',
          'font-family:IBM Plex Mono, ui-monospace, monospace',
          'font-size:0.72rem',
          'letter-spacing:0.04em',
          'cursor:pointer',
          'opacity:0.45',
          'transition:opacity 0.15s, color 0.15s, border-color 0.15s',
        ].join(';');
        wrapper.appendChild(btn);

        wrapper.addEventListener('mouseenter', function() { btn.style.opacity = '1'; });
        wrapper.addEventListener('mouseleave', function() { btn.style.opacity = '0.45'; });
        btn.addEventListener('mouseenter', function() {
          btn.style.color = 'var(--text-primary)';
          btn.style.borderColor = 'var(--text-label)';
        });
        btn.addEventListener('mouseleave', function() {
          btn.style.color = 'var(--text-muted)';
          btn.style.borderColor = 'var(--text-separator)';
        });

        btn.addEventListener('click', function() {
          var code = pre.querySelector('code');
          var text = (code || pre).textContent;
          navigator.clipboard.writeText(text).then(function() {
            btn.textContent = 'copied';
            setTimeout(function() { btn.textContent = 'copy'; }, 1500);
          });
        });
      });
    });
  </script>
</BaseLayout>
