---
import type { Alternate } from '../lib/alternates';

interface ArticleMeta {
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  section?: string;
  tags?: string[];
}

interface Props {
  title: string;
  description: string;
  lang: string;
  ogUrl: string;
  ogDescription: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'book';
  noindex?: boolean;
  jsonLd?: object | object[];
  alternates?: Alternate[];
  articleMeta?: ArticleMeta;
}

const {
  title,
  description,
  lang,
  ogUrl,
  ogDescription,
  ogImage,
  ogType = 'website',
  noindex = false,
  jsonLd,
  alternates = [],
  articleMeta,
} = Astro.props;

const siteUrl = 'https://kenimoto.dev';
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).href)
  : `${siteUrl}/og-image.png`;
// 1200×630 と確信できる標準OG画像 (og-image.png / 記事の og*.png) のときだけ寸法を宣言する。
// Book LP が渡す縦長表紙 (1600×2560) では寸法を出さない (誤った aspect ratio 宣言を避ける)。
const isStandardOg = !ogImage || /(^|\/)og[\w-]*\.(png|jpe?g|webp)$/i.test(ogImage);
const gaId = import.meta.env.PUBLIC_GA_ID ?? 'G-K9SGJT785T';
const jsonLdArray = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <title>{title}</title>
    <link rel="canonical" href={ogUrl} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    {gaId && (
      <>
        <link rel="preconnect" href="https://www.googletagmanager.com" />
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={resolvedOgImage} />
    {isStandardOg && (
      <>
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
      </>
    )}
    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={lang === 'ja' ? 'ja_JP' : (lang === 'pt' ? 'pt_BR' : (lang === 'es' ? 'es_ES' : 'en_US'))} />
    {alternates.filter((a) => a.hreflang !== 'x-default' && a.hreflang !== lang).map((alt) => (
      <meta property="og:locale:alternate" content={alt.hreflang === 'ja' ? 'ja_JP' : (alt.hreflang === 'pt' ? 'pt_BR' : (alt.hreflang === 'es' ? 'es_ES' : 'en_US'))} />
    ))}
    <meta property="og:site_name" content={lang === 'ja' ? '井本 賢' : 'Ken Imoto'} />
    {ogType === 'article' && articleMeta?.publishedTime && (
      <meta property="article:published_time" content={articleMeta.publishedTime} />
    )}
    {ogType === 'article' && articleMeta?.modifiedTime && (
      <meta property="article:modified_time" content={articleMeta.modifiedTime} />
    )}
    {ogType === 'article' && articleMeta?.author && (
      <meta property="article:author" content={articleMeta.author} />
    )}
    {ogType === 'article' && articleMeta?.section && (
      <meta property="article:section" content={articleMeta.section} />
    )}
    {ogType === 'article' && articleMeta?.tags && articleMeta.tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@kenimo49" />
    <meta name="twitter:creator" content="@kenimo49" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />
    {jsonLdArray.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme');
        if (!t) t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <slot name="head" />
    <style is:global>
      @import "tailwindcss";

      :root,
      [data-theme="dark"] {
        --bg-primary: #0f172a;
        --bg-card: #1e293b;
        --bg-elev: #243246;
        --bg-base: #0f172a;
        --text-primary: #e2e8f0;
        --text-secondary: #cbd5e1;
        --text-label: #94a3b8;
        --text-muted: #64748b;
        --text-separator: #475569;
        --link-color: #60a5fa;
        --accent-blue: #60a5fa;
        --accent-amber: #f59e0b;
        --accent-green: #10b981;
        --border-avatar: #1e3a5f;
      }

      [data-theme="light"] {
        --bg-primary: #f8fafc;
        --bg-card: #ffffff;
        --bg-elev: #eef2f7;
        --bg-base: #f8fafc;
        --text-primary: #1e293b;
        --text-secondary: #334155;
        --text-label: #64748b;
        --text-muted: #64748b;
        --text-separator: #cbd5e1;
        --link-color: #2563eb;
        --accent-blue: #2563eb;
        --accent-amber: #d97706;
        --accent-green: #059669;
        --border-avatar: #93c5fd;
      }

      body {
        font-family: system-ui, -apple-system, sans-serif;
        background-color: var(--bg-primary);
        color: var(--text-primary);
        margin: 0;
        min-height: 100vh;
        transition: background-color 0.2s, color 0.2s;
      }

      a {
        color: var(--link-color);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }

      .theme-toggle {
        background: none;
        border: 1px solid var(--text-separator);
        color: var(--text-label);
        cursor: pointer;
        padding: 0.35rem 0.5rem;
        border-radius: 6px;
        font-size: 1rem;
        line-height: 1;
        transition: color 0.2s, border-color 0.2s;
      }
      .theme-toggle:hover {
        color: var(--text-primary);
        border-color: var(--text-label);
      }

      [data-theme="dark"] .icon-sun { display: inline; }
      [data-theme="dark"] .icon-moon { display: none; }
      [data-theme="light"] .icon-sun { display: none; }
      [data-theme="light"] .icon-moon { display: inline; }

    </style>
  </head>
  <body>
    <slot />
    <footer class="site-footer">
      <div class="footer-inner">
        <span class="footer-brand">{lang === 'ja' ? '井本 賢' : 'Ken Imoto'}</span>
        <nav class="footer-links" aria-label={lang === 'ja' ? 'フッターナビ' : 'Footer'}>
          <a href={lang === 'en' ? '/about/' : `/${lang}/about/`}>{lang === 'ja' ? 'プロフィール' : (lang === 'pt' ? 'Sobre' : (lang === 'es' ? 'Sobre' : 'About'))}</a>
          <a href={lang === 'en' ? '/blog/' : `/${lang}/blog/`}>Blog</a>
          <a href={lang === 'en' ? '/books/' : `/${lang}/books/`}>{lang === 'ja' ? '書籍' : (lang === 'pt' ? 'Livros' : (lang === 'es' ? 'Libros' : 'Books'))}</a>
          <a href="https://propel-lab.co.jp/?utm_source=kenimoto.dev&utm_medium=referral&utm_campaign=cross-property&utm_content=footer" rel="noopener" target="_blank">Propel-Lab</a>
          <a href="/llms.txt" rel="noopener">llms.txt</a>
        </nav>
        <span class="footer-copy">© 2026 Ken Imoto</span>
      </div>
    </footer>
    <style is:global>
      .site-footer {
        max-width: 720px;
        margin: 4rem auto 0;
        padding: 2rem 2rem 3rem;
        border-top: 1px solid var(--text-separator);
      }
      .footer-inner {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem 1.5rem;
        align-items: baseline;
        justify-content: space-between;
        font-size: 0.85rem;
        color: var(--text-muted);
      }
      .footer-brand {
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-label);
        letter-spacing: -0.01em;
      }
      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1rem;
      }
      .footer-links a {
        color: var(--text-muted);
        text-decoration: none;
      }
      .footer-links a:hover {
        color: var(--text-primary);
        text-decoration: underline;
      }
      .footer-copy {
        font-size: 0.78rem;
        color: var(--text-muted);
      }
      @media (max-width: 480px) {
        .site-footer {
          padding: 1.5rem 1rem 2rem;
        }
      }

      /* Publications grid cards (top pages). Scoped to .book-grid descendants
         so es/books/index.astro の独立 .book-card と衝突しない。
         元は scoped <style> にあったが Astro の scoped CSS は <slot/> 経由の
         ページ DOM に届かないためデッドコード化していた (memory: feedback_astro_scoped_style_slot.md)。*/
      .book-grid .book-card {
        background: var(--bg-card);
        border-radius: 8px;
        padding: 0.75rem;
        text-align: center;
        transition: outline 0.15s;
        outline: none;
      }
      .book-grid .book-card img {
        aspect-ratio: 5 / 7;
        object-fit: cover;
      }
      .book-grid .book-card:hover {
        outline: 2px solid var(--accent-blue);
      }
      .book-grid .book-card.accent-amber:hover {
        outline-color: var(--accent-amber);
      }
      .book-grid .book-card.accent-green:hover {
        outline-color: var(--accent-green);
      }
      .book-grid .book-card.accent-purple:hover {
        outline-color: var(--accent-purple, #7c3aed);
      }
      .book-grid .book-card.accent-rose:hover {
        outline-color: var(--accent-rose, #e11d48);
      }

      @media (max-width: 640px) {
        main {
          padding: 1.5rem 1rem !important;
        }
        .book-grid {
          grid-template-columns: repeat(2, 1fr) !important;
        }
      }
      @media (min-width: 641px) and (max-width: 900px) {
        main {
          padding: 2rem 1.5rem !important;
        }
        .book-grid {
          grid-template-columns: repeat(3, 1fr) !important;
        }
      }
    </style>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        var btn = document.getElementById('theme-toggle');
        if (btn) {
          function applyState(theme) {
            var isDark = theme === 'dark';
            btn.setAttribute('aria-pressed', isDark ? 'true' : 'false');
          }
          applyState(document.documentElement.getAttribute('data-theme') || 'dark');
          btn.addEventListener('click', function() {
            var current = document.documentElement.getAttribute('data-theme') || 'dark';
            var next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('theme', next);
            applyState(next);
          });
        }

        // Make book cards clickable.
        // Priority: data-lp-url (LP page, same tab) > Kindle/Amazon link (new tab) > first link.
        // Anchor clicks (Kindle/Zenn text) bubble through unchanged.
        document.querySelectorAll('.book-grid > div').forEach(function(card) {
          var lpUrl = card.getAttribute('data-lp-url');
          var fallbackTarget = null;
          if (!lpUrl) {
            var links = card.querySelectorAll('a');
            if (!links.length) return;
            for (var i = 0; i < links.length; i++) {
              var href = links[i].href;
              if (href.indexOf('amzn') !== -1 || href.indexOf('amazon') !== -1) {
                fallbackTarget = href;
                break;
              }
            }
            if (!fallbackTarget) fallbackTarget = links[0].href;
          }
          card.style.cursor = 'pointer';
          card.addEventListener('click', function(e) {
            if (e.target.tagName === 'A') return;
            if (lpUrl) {
              window.location.href = lpUrl;
            } else {
              window.open(fallbackTarget, '_blank');
            }
          });
        });
      });
    </script>

    <!-- サイト全体のアウトバウンドCTA計測。ブログ記事内の book CTA リンク(data-cta無し)を
         cta_click として拾う。BookLayout の data-cta-* ボタンは既に専用計測されるため二重発火を避けてスキップする。 -->
    <script is:inline>
      (function () {
        var SELF = location.hostname.replace(/^www\./, '');
        function destHost(href) {
          try { return new URL(href, location.href).hostname.replace(/^www\./, ''); }
          catch (e) { return ''; }
        }
        function ctaType(host) {
          if (/(^|\.)(amazon\.|amzn\.)/.test(host) || /amazon|amzn/.test(host)) return 'amazon';
          if (/zenn\.dev$/.test(host)) return 'zenn';
          if (/docswell\.com$/.test(host)) return 'docswell';
          if (/github\.com$/.test(host)) return 'github';
          return 'other';
        }
        function emit(a) {
          var host = destHost(a.href);
          if (!host || host === SELF) return;            // 内部リンクは無視
          if (a.hasAttribute('data-cta-amazon') || a.hasAttribute('data-cta-sample') ||
              a.hasAttribute('data-cta-zenn') || a.hasAttribute('data-cta-toc') ||
              a.hasAttribute('data-cta-other')) return;  // LP 専用計測に委譲(二重発火回避)
          var params = {
            event_category: 'outbound',
            event_label: location.pathname,
            cta_position: 'in-article',
            cta_type: ctaType(host),
            destination: a.href,
            transport_type: 'beacon',
          };
          // gtag.js ロード前でも dataLayer に積んで取りこぼしを防ぐ
          if (typeof gtag === 'function') gtag('event', 'cta_click', params);
          else (window.dataLayer = window.dataLayer || []).push(['event', 'cta_click', params]);
        }
        function handler(e) {
          var a = e.target && e.target.closest && e.target.closest('a[href]');
          if (a) emit(a);
        }
        // 左クリックは pointerdown(primary のみ)、中クリックは auxclick 専任。
        // pointerdown を全ボタンで拾うと中クリックが auxclick と二重計測になるため button===0 に限定。
        document.addEventListener('pointerdown', function (e) { if (e.button === 0) handler(e); }, true);
        document.addEventListener('auxclick', function (e) { if (e.button === 1) handler(e); }, true);
      })();
    </script>
  </body>
</html>
