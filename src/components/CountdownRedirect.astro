---
interface Props {
  destinationUrl: string;
  delaySeconds?: number;
  lang: 'en' | 'ja';
  bookSlug: string;
}

const { destinationUrl, delaySeconds = 5, lang, bookSlug } = Astro.props;

const labels = {
  ja: {
    counting: '秒後にAmazonへ移動します',
    goNow: '今すぐ移動',
    stay: 'このページに留まる',
    canceled: 'カウントダウンを停止しました。詳細をどうぞ。',
  },
  en: {
    counting: 'seconds until Amazon',
    goNow: 'Go now',
    stay: 'Stay on this page',
    canceled: 'Auto-redirect canceled. Read on.',
  },
};

const t = labels[lang];
---

<aside class="countdown-banner" aria-live="polite" data-destination={destinationUrl} data-delay={delaySeconds} data-slug={bookSlug}>
  <noscript>
    <meta http-equiv="refresh" content={`${delaySeconds}; url=${destinationUrl}`} />
    <p class="countdown-noscript">
      {lang === 'ja' ? `${delaySeconds}秒後にAmazonへ移動します。移動しない場合は ` : `Redirecting to Amazon in ${delaySeconds} seconds. If not redirected, `}
      <a href={destinationUrl} rel="noopener">{lang === 'ja' ? 'こちらをクリック' : 'click here'}</a>。
    </p>
  </noscript>

  <div class="countdown-active" data-state="counting">
    <span class="countdown-text">
      <span class="countdown-num" data-countdown-num>{delaySeconds}</span>
      {' '}{t.counting}
    </span>
    <div class="countdown-actions">
      <button type="button" class="btn btn-primary" data-action="go-now">{t.goNow}</button>
      <button type="button" class="btn btn-secondary" data-action="stay">{t.stay}</button>
    </div>
  </div>

  <div class="countdown-canceled" data-state="canceled" hidden>
    <p>{t.canceled}</p>
  </div>
</aside>

<style>
  .countdown-banner {
    background: var(--bg-card);
    border: 1px solid var(--accent-blue);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .countdown-active {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .countdown-text {
    font-size: 1rem;
    color: var(--text-primary);
  }
  .countdown-num {
    font-weight: 700;
    color: var(--accent-blue);
    font-size: 1.4rem;
    font-variant-numeric: tabular-nums;
  }
  .countdown-actions {
    display: flex;
    gap: 0.5rem;
  }
  .btn {
    padding: 0.55rem 1.1rem;
    border-radius: 6px;
    font-size: 0.9rem;
    font-family: inherit;
    cursor: pointer;
    border: 1px solid var(--text-separator);
    transition: all 0.15s;
  }
  .btn-primary {
    background: var(--accent-blue);
    color: white;
    border-color: var(--accent-blue);
    font-weight: 600;
  }
  .btn-primary:hover {
    opacity: 0.9;
  }
  .btn-secondary {
    background: transparent;
    color: var(--text-secondary);
  }
  .btn-secondary:hover {
    border-color: var(--text-label);
    color: var(--text-primary);
  }
  .countdown-canceled p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .countdown-noscript {
    margin: 0;
    color: var(--text-secondary);
  }
  @media (max-width: 640px) {
    .countdown-active {
      flex-direction: column;
      align-items: stretch;
    }
    .countdown-actions {
      justify-content: stretch;
    }
    .btn {
      flex: 1;
    }
  }
</style>

<script>
  function trackEvent(name: string, params: Record<string, unknown>) {
    const w = window as unknown as { gtag?: (...args: unknown[]) => void };
    if (typeof w.gtag === 'function') {
      w.gtag('event', name, params);
    }
  }

  function getReturning(): boolean {
    return new URLSearchParams(window.location.search).get('stay') === '1';
  }

  document.querySelectorAll<HTMLElement>('.countdown-banner').forEach((banner) => {
    const destination = banner.dataset.destination!;
    const delay = parseInt(banner.dataset.delay || '5', 10);
    const slug = banner.dataset.slug || '';

    const numEl = banner.querySelector<HTMLElement>('[data-countdown-num]');
    const activeEl = banner.querySelector<HTMLElement>('[data-state="counting"]');
    const canceledEl = banner.querySelector<HTMLElement>('[data-state="canceled"]');
    const goNowBtn = banner.querySelector<HTMLButtonElement>('[data-action="go-now"]');
    const stayBtn = banner.querySelector<HTMLButtonElement>('[data-action="stay"]');

    let remaining = delay;
    let timer: number | null = null;
    let canceled = getReturning();

    if (canceled) {
      activeEl?.setAttribute('hidden', '');
      canceledEl?.removeAttribute('hidden');
      return;
    }

    const tick = () => {
      remaining -= 1;
      if (numEl) numEl.textContent = String(Math.max(0, remaining));
      if (remaining <= 0) {
        if (timer) window.clearInterval(timer);
        trackEvent('outbound_redirect', {
          event_category: 'book_lp',
          event_label: slug,
          trigger: 'countdown',
          destination,
        });
        window.location.replace(destination);
      }
    };

    timer = window.setInterval(tick, 1000);

    goNowBtn?.addEventListener('click', () => {
      if (timer) window.clearInterval(timer);
      trackEvent('outbound_redirect', {
        event_category: 'book_lp',
        event_label: slug,
        trigger: 'go_now_button',
        destination,
      });
      window.location.assign(destination);
    });

    stayBtn?.addEventListener('click', () => {
      if (timer) window.clearInterval(timer);
      canceled = true;
      activeEl?.setAttribute('hidden', '');
      canceledEl?.removeAttribute('hidden');
      trackEvent('btn_stay', {
        event_category: 'book_lp',
        event_label: slug,
      });
      const url = new URL(window.location.href);
      url.searchParams.set('stay', '1');
      window.history.replaceState({}, '', url.toString());
    });
  });

  document.querySelectorAll<HTMLAnchorElement>('[data-cta-amazon]').forEach((link) => {
    link.addEventListener('click', () => {
      trackEvent('cta_click', {
        event_category: 'book_lp',
        event_label: link.dataset.slug || '',
        cta_position: link.dataset.position || 'unknown',
        destination: link.href,
      });
    });
  });
</script>
