---
interface Props {
  lang: 'en' | 'ja' | 'pt' | 'es';
  current?: 'home' | 'blog' | 'about';
}

const { lang, current = 'home' } = Astro.props;

const langPrefix = lang === 'en' ? '' : `/${lang}`;
const homeUrl = `${langPrefix}/` || '/';
const blogUrl = `${langPrefix}/blog/`;
const aboutUrl = `${langPrefix}/about/`;
const pathname = Astro.url.pathname;
const blogRe = lang === 'en' ? /^\/blog\/.+/ : new RegExp(`^/${lang}/blog/.+`);
const isBlogPost = blogRe.test(pathname);

// 言語切替: enからjaへ、それ以外(ja/pt/es)からはenへ
const altLang = lang === 'en' ? 'ja' : 'en';
const altLangLabel = altLang === 'ja' ? 'JP' : 'EN';
const altLangUrl = isBlogPost
  ? (altLang === 'en' ? '/blog/' : `/${altLang}/blog/`)
  : (altLang === 'en'
    ? (pathname.replace(/^\/(ja|pt|es)/, '') || '/')
    : `/${altLang}${lang === 'en' ? pathname : pathname.replace(/^\/(ja|pt|es)/, '')}`);
---

<nav class="site-nav">
  <a href={homeUrl} class="nav-logo">kenimoto.dev</a>
  <div class="nav-links">
    <a href={blogUrl} class:list={[{ active: current === 'blog' }]}>
      {lang === 'ja' ? 'Blog' : 'Blog'}
    </a>
    <a href={aboutUrl} class:list={[{ active: current === 'about' }]}>
      About
    </a>
    <a href={altLangUrl} class="nav-lang">
      {altLangLabel}
    </a>
    <button id="theme-toggle" class="theme-toggle" aria-label={lang === 'ja' ? 'テーマ切替' : 'Toggle theme'}>
      <span class="icon-sun">&#9788;</span>
      <span class="icon-moon">&#9790;</span>
    </button>
  </div>
</nav>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 720px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
  }

  .nav-logo {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary) !important;
    text-decoration: none !important;
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-size: 0.875rem;
  }

  .nav-links a {
    color: var(--text-label);
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--text-primary);
  }

  .nav-lang {
    font-size: 0.8rem;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--text-separator);
    border-radius: 4px;
  }

  @media (max-width: 480px) {
    .site-nav {
      padding: 1rem 1rem;
    }
    .nav-links {
      gap: 0.75rem;
      font-size: 0.8rem;
    }
  }
</style>
