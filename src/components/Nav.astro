---
import type { Alternate } from '../lib/alternates';

interface Props {
  lang: 'en' | 'ja' | 'pt' | 'es';
  current?: 'home' | 'blog' | 'books' | 'about' | '';
  alternates?: Alternate[];
}

const { lang, current = 'home', alternates = [] } = Astro.props;

const langPrefix = lang === 'en' ? '' : `/${lang}`;
const homeUrl = `${langPrefix}/` || '/';
const blogUrl = `${langPrefix}/blog/`;
const booksUrl = `${langPrefix}/books/`;
const aboutUrl = `${langPrefix}/about/`;
const pathname = Astro.url.pathname;

// 利用可能な言語(blog/aboutが存在する言語の組み合わせ)
const ALL_LANGS = ['en', 'ja', 'pt', 'es'] as const;
const LANG_LABEL: Record<string, string> = { en: 'EN', ja: 'JP', pt: 'PT', es: 'ES' };
const BLOG_LANGS = new Set(['en', 'ja', 'pt', 'es']); // blogがある言語

// alternates が渡されていれば該当言語の URL を使う（個別記事 → 対応言語版へ正しく遷移）
const alternateMap = new Map<string, string>();
for (const alt of alternates) {
  if (alt.hreflang === 'x-default') continue;
  alternateMap.set(alt.hreflang, alt.href);
}

// 現在のページ種別を推定
function pageKind(p: string): 'home' | 'blog-list' | 'blog-post' | 'about' | 'books-list' | 'books-post' | 'other' {
  const stripped = p.replace(/^\/(ja|pt|es)/, '') || '/';
  if (stripped === '/') return 'home';
  if (stripped === '/blog/' || stripped === '/blog') return 'blog-list';
  if (stripped.startsWith('/blog/')) return 'blog-post';
  if (stripped.startsWith('/about')) return 'about';
  if (stripped === '/books/' || stripped === '/books') return 'books-list';
  if (stripped.startsWith('/books/')) return 'books-post';
  return 'other';
}

function urlForLang(target: string): string {
  // alternates から個別記事の対応言語版が見つかれば優先
  const altHref = alternateMap.get(target);
  if (altHref) return altHref;

  const prefix = target === 'en' ? '' : `/${target}`;
  const kind = pageKind(pathname);
  switch (kind) {
    case 'home': return `${prefix}/` || '/';
    case 'blog-list':
    case 'blog-post':
      // 対応翻訳が無い場合は blog index にフォールバック
      return BLOG_LANGS.has(target) ? `${prefix}/blog/` : (`${prefix}/` || '/');
    case 'about': return `${prefix}/about/`;
    case 'books-list':
    case 'books-post': return `${prefix}/books/`;
    default: return `${prefix}/` || '/';
  }
}
---

<nav class="site-nav">
  <a href={homeUrl} class="nav-logo">kenimoto.dev</a>
  <div class="nav-links">
    {BLOG_LANGS.has(lang) && (
      <a href={blogUrl} class:list={[{ active: current === 'blog' }]}>
        Blog
      </a>
    )}
    <a href={booksUrl} class:list={[{ active: current === 'books' }]}>
      Books
    </a>
    <a href={aboutUrl} class:list={[{ active: current === 'about' }]}>
      About
    </a>
    <div class="nav-langs">
      {ALL_LANGS.map((l) => (
        l === lang
          ? <span class="nav-lang current" aria-current="true">{LANG_LABEL[l]}</span>
          : <a href={urlForLang(l)} class="nav-lang">{LANG_LABEL[l]}</a>
      ))}
    </div>
    <button
      id="theme-toggle"
      class="theme-toggle"
      type="button"
      aria-pressed="false"
      aria-label={lang === 'ja' ? 'テーマ切替' : 'Toggle theme'}
    >
      <span class="icon-sun" aria-hidden="true">&#9788;</span>
      <span class="icon-moon" aria-hidden="true">&#9790;</span>
    </button>
  </div>
</nav>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 720px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
  }

  .nav-logo {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary) !important;
    text-decoration: none !important;
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-size: 0.875rem;
  }

  .nav-links a {
    color: var(--text-label);
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--text-primary);
  }

  .nav-langs {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    border: 1px solid var(--text-separator);
    border-radius: 4px;
    padding: 0.05rem 0.15rem;
  }

  .nav-lang {
    font-size: 0.72rem;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    color: var(--text-label);
    text-decoration: none;
    letter-spacing: 0.04em;
  }

  .nav-lang:hover {
    color: var(--text-primary);
  }

  .nav-lang.current {
    background: var(--text-separator);
    color: var(--text-primary);
    font-weight: 700;
    cursor: default;
  }

  @media (max-width: 480px) {
    .site-nav {
      padding: 1rem 1rem;
    }
    .nav-links {
      gap: 0.75rem;
      font-size: 0.8rem;
    }
    .nav-langs { gap: 0.15rem; }
    .nav-lang { font-size: 0.7rem; padding: 0.1rem 0.3rem; }
  }
</style>
