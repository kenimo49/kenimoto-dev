---
interface Props {
  lang: 'en' | 'ja';
  current?: 'home' | 'blog' | 'about';
}

const { lang, current = 'home' } = Astro.props;

const homeUrl = lang === 'ja' ? '/ja' : '/';
const blogUrl = lang === 'ja' ? '/ja/blog' : '/blog';
const aboutUrl = lang === 'ja' ? '/ja/about' : '/about';
const altLangUrl = lang === 'ja'
  ? Astro.url.pathname.replace(/^\/ja/, '') || '/'
  : `/ja${Astro.url.pathname}`;
---

<nav class="site-nav">
  <a href={homeUrl} class="nav-logo">kenimoto.dev</a>
  <div class="nav-links">
    <a href={blogUrl} class:list={[{ active: current === 'blog' }]}>
      {lang === 'ja' ? 'Blog' : 'Blog'}
    </a>
    <a href={aboutUrl} class:list={[{ active: current === 'about' }]}>
      About
    </a>
    <a href={altLangUrl} class="nav-lang">
      {lang === 'ja' ? 'EN' : 'JP'}
    </a>
    <button id="theme-toggle" class="theme-toggle" aria-label={lang === 'ja' ? 'テーマ切替' : 'Toggle theme'}>
      <span class="icon-sun">&#9788;</span>
      <span class="icon-moon">&#9790;</span>
    </button>
  </div>
</nav>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 720px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
  }

  .nav-logo {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary) !important;
    text-decoration: none !important;
    letter-spacing: -0.01em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-size: 0.875rem;
  }

  .nav-links a {
    color: var(--text-label);
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--text-primary);
  }

  .nav-lang {
    font-size: 0.8rem;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--text-separator);
    border-radius: 4px;
  }

  @media (max-width: 480px) {
    .site-nav {
      padding: 1rem 1rem;
    }
    .nav-links {
      gap: 0.75rem;
      font-size: 0.8rem;
    }
  }
</style>
